remote="127.0.0.1"
key=your-daemon-key-here
port=3002
DEBUG=false
version=3.0.0
STATS_INTERVAL=10000

# Container Runtime
# Set to "docker" or "podman" (default: docker)
CONTAINER_RUNTIME=docker

# Security
REQUIRE_HMAC=true
ALLOWED_IPS=
BEHIND_PROXY=false

# TLS (optional — paths to cert and key files for HTTPS)
TLS_CERT=
TLS_KEY=
