{
  "name": "airlinkd",
  "version": "3.0.0-beta-rc1",
  "module": "src/app.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/app.ts",
    "start": "bun src/app.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint && bun test",
    "build": "bun run build.ts",
    "configure": "bun src/configure.ts"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dockerode": "^4.0.10",
    "long": "^5.3.2",
    "minecraft-status": "^1.1.0",
    "tar": "^7.5.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/dockerode": "^4.0.1",
    "@types/tar": "^7.0.87",
    "bun-types": "^1.3.12",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.12"
}
