<%- include('../../components/header', { title: 'Console' }) %>
<%- include('../../components/serverFeatures') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/css/xterm.css" />
<script nonce="<%- nonce %>" src="https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/lib/xterm.js"></script>
<script nonce="<%- nonce %>" src="https://cdn.jsdelivr.net/npm/@xterm/addon-fit@0.10.0/lib/addon-fit.js"></script>
<script nonce="<%- nonce %>" src="https://cdn.jsdelivr.net/npm/@xterm/addon-web-links@0.11.0/lib/addon-web-links.js"></script>
<script nonce="<%- nonce %>" src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    .stats-card {
        position: relative;
        overflow: hidden;
    }
    .stats-card > canvas {
        position: absolute;
        left: 0;
        top: 0;
        width: 100% !important;
        height: 100% !important;
        pointer-events: none;
    }

    #terminal {
        height: 300px;
        background: var(--theme-bg-card, #141414);
        /* Prevent the browser's pull-to-refresh gesture from firing when
           the user drags down inside the terminal */
        overscroll-behavior: contain;
        touch-action: none;
    }

    #terminal .xterm {
        padding: 6px;
        height: 100%;
    }

    #terminal-container {
        overscroll-behavior: contain;
        animation: console-appear 0.35s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @keyframes console-appear {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    #terminal .xterm-screen {
        background: var(--theme-bg-card, #141414);
    }
</style>

<main id="page-content" class="">
  <%- include('../../components/template') %>

  <!-- Static chrome: server name, tab nav, control buttons — never fades on nav -->
  <div class="mobile-server-chrome px-4 pt-5">

    <!-- Page Header -->
    <div class="mb-4">
      <div class="flex items-start justify-between gap-3">
        <%- include('../../components/serverHeader') %>
        <!-- Server meta: right side of header, 3 small lines -->
        <div class="shrink-0 text-right mt-0.5 space-y-0.5">
          <div class="flex items-center justify-end gap-1.5">
            <span class="text-[10px] text-neutral-500 dark:text-neutral-400 truncate max-w-[110px]"><%= server.image.name %></span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="h-2.5 w-2.5 shrink-0 text-neutral-400"><rect width="256" height="256" fill="none"/><path d="M243.31,136,144,36.69A15.86,15.86,0,0,0,132.69,32H40a8,8,0,0,0-8,8v92.69A15.86,15.86,0,0,0,36.69,144L136,243.31a16,16,0,0,0,22.63,0l84.68-84.68a16,16,0,0,0,0-22.63ZM84,96A12,12,0,1,1,96,84,12,12,0,0,1,84,96Z"/></svg>
          </div>
          <div class="flex items-center justify-end gap-1.5">
            <span class="text-[10px] text-neutral-500 dark:text-neutral-400 truncate max-w-[110px]"><%= server.node.name %></span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="h-2.5 w-2.5 shrink-0 text-neutral-400"><rect width="256" height="256" fill="none"/><path d="M208,40H48A16,16,0,0,0,32,56v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V56A16,16,0,0,0,208,40ZM180,92a12,12,0,1,1,12-12A12,12,0,0,1,180,92Z"/><path d="M208,136H48a16,16,0,0,0-16,16v48a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V152A16,16,0,0,0,208,136Zm-28,52a12,12,0,1,1,12-12A12,12,0,0,1,180,188Z"/></svg>
          </div>
          <div class="flex items-center justify-end gap-1.5">
            <span class="text-[10px] font-mono text-neutral-500 dark:text-neutral-400"><%= server.UUID.split('-')[0] %></span>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="h-2.5 w-2.5 shrink-0 text-neutral-400"><rect width="256" height="256" fill="none"/><path d="M116.25,112h31.5l-8,32h-31.5ZM224,48V208a16,16,0,0,1-16,16H48a16,16,0,0,1-16-16V48A16,16,0,0,1,48,32H208A16,16,0,0,1,224,48Zm-16,56a8,8,0,0,0-8-8H168.25l7.51-30.06a8,8,0,0,0-15.52-3.88L151.75,96h-31.5l7.51-30.06a8,8,0,0,0-15.52-3.88L103.75,96H64a8,8,0,0,0,0,16H99.75l-8,32H56a8,8,0,0,0,0,16H87.75l-7.51,30.06a8,8,0,0,0,5.82,9.7,8.13,8.13,0,0,0,2,.24,8,8,0,0,0,7.75-6.06L104.25,160h31.5l-7.51,30.06a8,8,0,0,0,5.82,9.7A8.13,8.13,0,0,0,136,200a8,8,0,0,0,7.75-6.06L152.25,160H192a8,8,0,0,0,0-16H156.25l8-32H200A8,8,0,0,0,208,104Z"/></svg>
          </div>
        </div>
      </div>

      <div class="px-0 mt-1">
        <%- include('../../components/loadingPopup') %>
      </div>

      <% if (server.Suspended) { %>
      <div class="mt-3 flex items-center gap-2.5 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 rounded-xl px-3 py-2.5">
        <%- icon('triangle-alert', { size: 16, class: 'text-red-500 shrink-0' }) %>
        <div class="min-w-0">
          <p class="text-xs font-medium text-red-700 dark:text-red-400">Server suspended</p>
          <p class="text-[11px] text-red-500 dark:text-red-400/70 truncate">Contact an administrator for assistance.</p>
        </div>
      </div>
      <% } %>

      <div id="daemonOfflineWarning" class="mt-3 flex items-center gap-2.5 bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 rounded-xl px-3 py-2.5<% if (typeof serverStatus === 'undefined' || !serverStatus.daemonOffline) { %> hidden<% } %>">
        <%- icon('triangle-alert', { size: 16, class: 'text-red-500 shrink-0' }) %>
        <div class="min-w-0 flex-1">
          <p class="text-xs font-medium text-red-700 dark:text-red-400">Connection Error</p>
          <p class="text-[11px] text-red-500 dark:text-red-400/70 truncate"><%= (typeof serverStatus !== 'undefined' && serverStatus.error) ? serverStatus.error : 'The daemon appears to be offline. Server controls unavailable.' %></p>
        </div>
        <button onclick="window.location.reload()" class="shrink-0 px-2.5 py-1 bg-red-600 hover:bg-red-500 text-white text-[11px] font-medium rounded-lg transition">
          Retry
        </button>
      </div>

      <div class="flex gap-2 mt-3">
        <button id="startButton" type="button"
          class="flex-1 flex items-center justify-center gap-1.5 rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white px-3 py-2 text-xs font-medium transition <%= server.Suspended ? 'opacity-50 cursor-not-allowed' : '' %>" <%= server.Suspended ? 'disabled' : '' %>>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
            <path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd" />
          </svg>
          <%= req.translations.start %>
        </button>
        <button id="restartButton" type="button"
          class="flex-1 flex items-center justify-center gap-1.5 rounded-xl bg-neutral-600 hover:bg-neutral-500 text-white px-3 py-2 text-xs font-medium transition <%= server.Suspended ? 'opacity-50 cursor-not-allowed' : '' %>" <%= server.Suspended ? 'disabled' : '' %>>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
            <path fill-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z" clip-rule="evenodd" />
          </svg>
          <%= req.translations.restart %>
        </button>
        <button id="stopButton" type="button"
          class="flex-1 flex items-center justify-center gap-1.5 rounded-xl bg-red-600 hover:bg-red-500 text-white px-3 py-2 text-xs font-medium transition <%= server.Suspended ? 'opacity-50 cursor-not-allowed' : '' %>" <%= server.Suspended ? 'disabled' : '' %>>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
            <path fill-rule="evenodd" d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z" clip-rule="evenodd" />
          </svg>
          <%= req.translations.stop %>
        </button>
      </div>
    </div>

    <%- include('../../components/serverTemplate') %>

  </div><!-- end .mobile-server-chrome -->

  <%- include('../../components/installHeader') %>

  <!-- Page content — fades on navigation -->
  <div class="px-4 pb-5">

    <!-- IP Address -->
    <div class="mt-3 mb-3">
      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-2.5 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" class="h-4 w-4 shrink-0 text-neutral-400"><rect width="256" height="256" fill="none"/><path d="M240,120a8,8,0,0,1-8,8H200v32h8a16,16,0,0,1,16,16v32a16,16,0,0,1-16,16H176a16,16,0,0,1-16-16V176a16,16,0,0,1,16-16h8V128H72v32h8a16,16,0,0,1,16,16v32a16,16,0,0,1-16,16H48a16,16,0,0,1-16-16V176a16,16,0,0,1,16-16h8V128H24a8,8,0,0,1,0-16h96V88h-8A16,16,0,0,1,96,72V40a16,16,0,0,1,16-16h32a16,16,0,0,1,16,16V72a16,16,0,0,1-16,16h-8v24h96A8,8,0,0,1,240,120Z"/></svg>
        <span class="text-[10px] font-medium text-neutral-500 shrink-0"><%= req.translations.addressIP %>:</span>
        <span class="text-xs font-medium text-neutral-800 dark:text-white font-mono truncate flex-1" id="server-ip-text"><%= server.node.address %>:<%= server.Ports ? JSON.parse(server.Ports).filter(Port => Port.primary).map(Port => Port.externalPort || String(Port.Port || '').split(':')[0]).pop() : '' %></span>
        <button id="copy-ip-btn" onclick="copyServerIP()" class="shrink-0 rounded-md p-1 bg-neutral-200 dark:bg-neutral-700/50 hover:bg-neutral-300 dark:hover:bg-neutral-600 transition-colors">
          <svg id="copy-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3.5 w-3.5 text-neutral-500">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <svg id="check-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="h-3.5 w-3.5 text-emerald-500 hidden">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </button>
      </div>
    </div>

      <!-- Terminal -->
      <div class="rounded-xl bg-[#141414] border border-neutral-800 overflow-hidden">
        <!-- Chrome bar -->
        <div class="flex items-center px-3 py-2 bg-[#1c1c1c] border-b border-neutral-800 shrink-0">
          <span class="text-[11px] font-medium text-neutral-600 select-none tracking-wide">console</span>
        </div>
        <div id="terminal-container" class="w-full relative">
          <div id="terminal"></div>
        </div>
        <% if (typeof features !== 'undefined' && features && features.includes('auto-complete')) { %>
        <div id="suggestion-bar" class="hidden border-t border-neutral-700 overflow-x-auto">
          <div id="suggestion-list" class="flex items-center gap-1 px-3 py-1.5 min-w-0">
          </div>
        </div>
        <% } %>
        <div class="relative border-t border-neutral-800">
          <input id="input" type="text" autocomplete="off" placeholder="<%= req.translations.typeACommand || 'Type a command...' %>"
            class="w-full px-4 py-3 bg-neutral-800 text-white text-sm outline-none placeholder:text-neutral-500">
        </div>
      </div>

      <!-- Stats grid -->
      <div class="grid grid-cols-2 gap-3 mt-3">

        <!-- Status -->
        <div class="stats-card rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3 h-auto min-h-[5rem]" style="--i:0">
          <canvas id="statusChart"></canvas>
          <div class="relative z-10">
            <p class="text-[10px] font-medium text-neutral-500"><%= req.translations.Status %></p>
            <p id="status" class="mt-0.5 text-base font-semibold text-neutral-800 dark:text-white leading-tight">—</p>
            <p id="status-log-text" class="text-[10px] text-neutral-400 truncate hidden"></p>
          </div>
        </div>

        <!-- RAM -->
        <div class="stats-card rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3 h-auto min-h-[5rem]" style="--i:1">
          <canvas id="ramChart"></canvas>
          <div class="relative z-10">
            <p class="text-[10px] font-medium text-neutral-500"><%= req.translations.ramUsage %></p>
            <p id="ramUsage" class="mt-0.5 text-xs font-medium text-neutral-800 dark:text-white leading-tight break-all">0%</p>
          </div>
        </div>

        <!-- CPU -->
        <div class="stats-card rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3 h-auto min-h-[5rem]" style="--i:2">
          <canvas id="cpuChart"></canvas>
          <div class="relative z-10">
            <p class="text-[10px] font-medium text-neutral-500"><%= req.translations.cpuUsage %></p>
            <p id="cpuUsage" class="mt-0.5 text-base font-semibold text-neutral-800 dark:text-white leading-tight">0%</p>
          </div>
        </div>

        <!-- Disk -->
        <div class="stats-card rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3 h-auto min-h-[5rem]" style="--i:3">
          <canvas id="diskChart" class="hidden"></canvas>
          <div class="relative z-10">
            <p class="text-[10px] font-medium text-neutral-500"><%= req.translations.diskUsage %></p>
            <p id="diskUsage" class="mt-0.5 text-xs font-medium text-neutral-800 dark:text-white leading-tight break-all">—</p>
          </div>
        </div>

      </div>

    </div>
  </div>
</main>

<%- include('../../components/toast') %>

<%- include('../../components/footer') %>

<script nonce="<%- nonce %>">
const termTheme = {
  foreground: '#c5c9d1',
  background: '#141414',
  selectionBackground: '#5DA5D580',
  black: '#1E1E1D',
  brightBlack: '#262625',
  red: '#E54B4B',
  green: '#9ECE58',
  yellow: '#FAED70',
  blue: '#396FE2',
  magenta: '#BB80B3',
  cyan: '#2DDAFD',
  white: '#d0d0d0',
  brightRed: '#FF5370',
  brightGreen: '#C3E88D',
  brightYellow: '#FFCB6B',
  brightBlue: '#82AAFF',
  brightMagenta: '#C792EA',
  brightCyan: '#89DDFF',
  brightWhite: '#ffffff',
  cursor: '#c5c9d1',
  cursorAccent: '#141414'
};

const term = new Terminal({
  disableStdin: true,
  lineHeight: 1.3,
  fontFamily: 'Menlo, Monaco, Consolas, monospace',
  fontSize: 11,
  theme: termTheme,
  scrollback: 1000,
  convertEol: true
});

const fitAddon = new FitAddon.FitAddon();
term.loadAddon(fitAddon);

// WebLinksAddon makes URLs in terminal output clickable
const webLinksAddon = new WebLinksAddon.WebLinksAddon();
term.loadAddon(webLinksAddon);

term.open(document.getElementById('terminal'));

function fitTerminal() {
  fitAddon.fit();
}

if (document.fonts && document.fonts.ready) {
  document.fonts.ready.then(() => requestAnimationFrame(fitTerminal));
} else {
  setTimeout(fitTerminal, 100);
}

window.addEventListener('resize', () => requestAnimationFrame(fitTerminal));

// Intercept wheel and touch events on the terminal container so the user
// scrolls the terminal buffer, not the page behind it.
(function () {
    const termEl = document.getElementById('terminal');
    if (!termEl) return;

    termEl.addEventListener('wheel', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const lines = e.deltaMode === 1 ? e.deltaY : Math.round(e.deltaY / 20);
        term.scrollLines(lines);
    }, { passive: false });

    let touchStartY = 0;
    termEl.addEventListener('touchstart', (e) => {
        touchStartY = e.touches[0].clientY;
    }, { passive: true });

    termEl.addEventListener('touchmove', (e) => {
        const dy = touchStartY - e.touches[0].clientY;
        touchStartY = e.touches[0].clientY;
        e.preventDefault();
        e.stopPropagation();
        term.scrollLines(Math.round(dy / 16));
    }, { passive: false });
})();

    const maxCommands = 10;
    let commandHistory = [];
    let currentCommandIndex = -1;

    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const host = window.location.host;
    const path = '/console/<%= server.UUID %>';

    const socketUrl = `${protocol}//${host}${path}`;

    let socket;

let isReconnecting = false;
let reconnectAttempts = 0;
let maxReconnectAttempts = 10;
let reconnectInterval = 2000;
let reconnectTimer = null;
let wsErrorCount = 0;

function connectWebSocket() {
    if (socket && (socket.readyState === WebSocket.CONNECTING || socket.readyState === WebSocket.OPEN)) {
        return;
    }

    if (reconnectTimer) {
        clearTimeout(reconnectTimer);
        reconnectTimer = null;
    }

    isReconnecting = true;

    if (socket) {
        try { socket.close(); } catch {}
        socket = null;
    }

    try {
        socket = new WebSocket(socketUrl);

        socket.onopen = () => {
            isReconnecting = false;
            reconnectAttempts = 0;
            reconnectInterval = 2000;
            wsErrorCount = 0;
            const warn = document.getElementById('daemonOfflineWarning');
            if (warn) warn.classList.add('hidden');
        };

        socket.onmessage = handleWebSocketMessage;

        socket.onerror = () => {
            wsErrorCount++;
            if (wsErrorCount >= 3) {
                const warn = document.getElementById('daemonOfflineWarning');
                if (warn) warn.classList.remove('hidden');
            }
        };

        socket.onclose = () => {
            socket = null;
            if (!isReconnecting) { scheduleReconnect(); }
        };
    } catch {
        socket = null;
        scheduleReconnect();
    }
}

function scheduleReconnect() {
    isReconnecting = true;
    reconnectAttempts++;

    const backoffTime = Math.min(30000, reconnectInterval * Math.pow(1.5, reconnectAttempts - 1));

    if (reconnectAttempts <= maxReconnectAttempts) {
        reconnectTimer = setTimeout(() => {

            connectWebSocket();
        }, backoffTime);
    } else {

        writeConsole('system', 'error', 'Maximum reconnect attempts reached. Please refresh the page.');
    }
}

connectWebSocket();

    function isDaemonInfraError(text) {
        return text.includes('Failed to attach to container') ||
               text.includes('no such container') ||
               text.includes('No such container') ||
               text.includes('container not available') ||
               text.includes('Attach failed') ||
               text.includes('HTTP code 404') ||
               text.includes('HTTP code 500');
    }

    const ANSI_RE   = /\x1b(?:\[[0-9;]*[A-Za-z]|\][^\x07\x1b]*(?:\x07|\x1b\\)|[@-Z\\-_]|[\u0080-\u009F])/g;
    const PROMPT_RE = /(?:[a-zA-Z0-9_-]+)@[^\s:#\])\r\n]+(?:[^$#\r\n]*?)[$#]\s*/g;

    function maskPrompts(raw) {
        const plain = raw.replace(ANSI_RE, '');
        if (!PROMPT_RE.test(plain)) { PROMPT_RE.lastIndex = 0; return raw; }
        PROMPT_RE.lastIndex = 0;
        const stripped = plain.replace(/[\r\n]/g, '').trim();
        const isOnlyPrompt = PROMPT_RE.test(stripped) && stripped.replace(PROMPT_RE, '').trim() === '';
        PROMPT_RE.lastIndex = 0;
        if (isOnlyPrompt) return '\r\nairlinkd~ ';
        return plain.replace(PROMPT_RE, 'airlinkd~ ');
    }

    function handleWebSocketMessage(msg) {
        if (msg.data instanceof Blob) {
            msg.data.arrayBuffer().then(buf => {
                const text = new TextDecoder().decode(buf);
                if (isDaemonInfraError(text)) return;
                if (text.includes('airlinkd server appears to be down')) {
                    socket.close();
                    wsErrorCount = 3;
                    const warn = document.getElementById('daemonOfflineWarning');
                    if (warn) warn.classList.remove('hidden');
                    return;
                }
                if (text.includes('Working on')) {
                    term.clear();
                    socket.close();
                    return;
                }
                hideConsolePlaceholder();
                term.write(maskPrompts(text));
            });
            return;
        }

        const text = typeof msg.data === 'string' ? msg.data : String(msg.data);
        if (isDaemonInfraError(text)) return;
        if (text.includes('airlinkd server appears to be down')) {
            socket.close();
            wsErrorCount = 3;
            const warn = document.getElementById('daemonOfflineWarning');
            if (warn) warn.classList.remove('hidden');
            return;
        }
        if (text.includes('Working on')) {
            term.clear();
            socket.close();
            return;
        }
        hideConsolePlaceholder();
        term.write(maskPrompts(text));
    }

    function writeConsole(prefix, type, message) {
        const ansi = {
            system: '\x1b[33m',
            error: '\x1b[31m',
            info: '\x1b[34m',
            success: '\x1b[32m',
            normal: '\x1b[0m'
        };

        const color = ansi[type.toLowerCase()] || '\x1b[0m';
        const prefixText = (prefix && type !== 'normal') ? `[${prefix}] ` : '';
        term.write(`${color}${prefixText}\x1b[37m${message}\x1b[0m\r\n`);
    }

    function restartWebSocket() {
        if (socket) {
            try { socket.close(); } catch {}
            socket = null;
        }
        setTimeout(connectWebSocket, 500);
    }

    function sendCommand() {
        const inputElement = document.getElementById('input');
        const command = inputElement.value.trim();
        if (command && socket) {
            term.write('\u001b[1m\u001b[33m~ \u001b[0m' + command + '\r\n');
            socket.send(JSON.stringify({
                event: 'CMD',
                command: command
            }));

            if (commandHistory.length === maxCommands) {
                commandHistory.shift();
            }
            commandHistory.push(command);
            currentCommandIndex = commandHistory.length;
        }

        inputElement.value = '';
        inputElement.dispatchEvent(new Event('input'));
    }

    function handleKeyUp(event) {
        if (event.key === 'ArrowUp') {
            if (currentCommandIndex > 0) {
                currentCommandIndex--;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            }
            event.preventDefault();
        } else if (event.key === 'ArrowDown') {
            if (currentCommandIndex < commandHistory.length - 1) {
                currentCommandIndex++;
                document.getElementById('input').value = commandHistory[currentCommandIndex];
            } else {
                currentCommandIndex = commandHistory.length;
                document.getElementById('input').value = '';
            }
            event.preventDefault();
        }
    }

