        el.className = 'mt-0.5 text-base font-semibold leading-tight ' + colorClass;
    }

    function setStatusLog(msg, eventType) {
        const logEl = document.getElementById('status-log-text');
        if (!logEl) return;
        if (statusMsgFadeTimer) { clearTimeout(statusMsgFadeTimer); statusMsgFadeTimer = null; }
        if (msg === null) {
            lifecycleActive = false;
            logEl.textContent = '';
            logEl.classList.add('hidden', 'opacity-0');
        } else {
            lifecycleActive = true;
            hideConsolePlaceholder();
            const label = statusCardLabels[eventType] || msg;
            const color = statusColors[eventType] || 'text-neutral-400';
            logEl.classList.add('opacity-0');
            statusMsgFadeTimer = setTimeout(() => {
                logEl.textContent = label;
                logEl.className = `text-[10px] font-medium truncate transition-opacity duration-200 ${color}`;
                logEl.classList.remove('hidden');
                void logEl.offsetHeight;
                logEl.classList.remove('opacity-0');
                statusMsgFadeTimer = null;
            }, 120);
        }
    }

