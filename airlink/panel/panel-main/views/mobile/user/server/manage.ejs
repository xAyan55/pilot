    function isValidJson(str) {
        try {
            JSON.parse(str);
        } catch (e) {
            return false;
        }
        return true;
    }

    initStatsWebSocket();

    // Passive lifecycle stream — receives daemon events, writes to console, manages input lock
    (function () {
        const proto = location.protocol === 'https:' ? 'wss' : 'ws';
        const lcSock = new WebSocket(`${proto}://${location.host}/events/<%= server.UUID %>`);
        const stateMap = {
            pulling:  { label: 'Pulling image',     color: 'text-blue-500' },
            creating: { label: 'Creating container', color: 'text-blue-500' },
            starting: { label: 'Starting container', color: 'text-yellow-500' },
            started:  { label: 'Starting server',    color: 'text-yellow-500' },
            stopping: { label: 'Stopping',           color: 'text-orange-500' },
            stopped:  { label: 'Offline',            color: 'text-red-500' },
            killed:   { label: 'Offline',            color: 'text-red-500' },
        };
        const lockingStates = new Set(['pulling', 'creating', 'starting']);
        lcSock.onmessage = (msg) => {
            let parsed;
            try { parsed = JSON.parse(msg.data); } catch { return; }
            if (parsed.event !== 'lifecycle') return;
            const { type, message } = parsed.data;
            const state = stateMap[type];
            if (state) setStatusText(state.label, state.color);
            setStatusLog(message, type);
            writeConsole('daemon', 'info', message);
            if (lockingStates.has(type)) { lockInput(state ? state.label + '...' : 'Waiting...'); }
            if (type === 'started') { unlockInput(); setStatusLog(null); }
            if (type === 'stopped' || type === 'killed') { setStatusLog(null); }
            if (type === 'error')   { unlockInput(); setStatusLog(null); }
        };
    })();

</script>
