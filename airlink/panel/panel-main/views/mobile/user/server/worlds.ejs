<%- include('../../components/header', { title: 'Worlds' }) %>

<main id="page-content" class="">
  <%- include('../../components/template') %>

  <section class="px-4 py-5">

    <header class="mb-5">
      <%- include('../../components/serverHeader') %>
    </header>

    <%- include('../../components/installHeader') %>

    <% if (errorMessage && errorMessage.message) { %>
    <div class="rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 px-4 py-3 mb-4 flex items-start gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <div>
        <p class="text-xs font-medium text-red-700 dark:text-red-400">Error</p>
        <p class="text-xs text-red-600 dark:text-red-400/70 mt-0.5"><%= errorMessage.message %></p>
      </div>
    </div>
    <% } %>

    <div class="collapsible-row no-anim<% if (worlds.length === 0) { %> open<% } %>" id="noWorldsMessageRow"><div><div id="noWorldsMessage" data-collapsible="true" class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-8 text-center mb-4">
      <p class="text-sm font-medium text-neutral-700 dark:text-neutral-300">No worlds found</p>
      <p class="text-xs text-neutral-500 mt-1">Worlds appear here once they are created on the server.</p>
    </div>

    <%- include('../../components/serverTemplate', { features: ['players', 'worlds'] }) %>

    <div class="collapsible-row no-anim<% if (worlds.length > 0) { %> open<% } %>" id="serverTableRow"><div><div class="space-y-2" id="serverTable">
      <% let wIdx = 0; worlds.forEach(function(world) { %>
        <%
          var iconPath = '/assets/world_icons/overworld.png';
          if (world.name === 'world_nether' || world.name.includes('nether')) {
            iconPath = '/assets/world_icons/nether.png';
          } else if (world.name === 'world_the_end' || world.name.includes('end')) {
            iconPath = '/assets/world_icons/end.png';
          }
        %>
        <div class="grid-item-animate rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3 flex items-center justify-between gap-3" style="--i:<%= wIdx++ %>">
          <div class="flex items-center gap-3 min-w-0">
            <img class="w-9 h-9 rounded-lg border border-neutral-200 dark:border-neutral-600 shrink-0" src="<%= iconPath %>" alt="World icon" />
            <div class="min-w-0">
              <p class="text-sm font-medium text-neutral-800 dark:text-white truncate"><%= world.name %></p>
              <p class="text-xs text-neutral-500">Minecraft World</p>
            </div>
          </div>
          <button
            type="button"
            class="shrink-0 rounded-xl bg-red-600 hover:bg-red-500 px-3 py-2 text-xs font-medium text-white transition"
            onclick="confirmDeleteWorld('<%= world.name %>')"
          >
            Delete
          </button>
        </div>
      <% }); %>
    </div>

  </section>
</main>

<%- include('../../components/toast') %>
<%- include('../../components/footer') %>

<script nonce="<%- nonce %>">
  document.addEventListener('DOMContentLoaded', function() {
    var wsCheck = new WebSocket((window.location.protocol === 'https:' ? 'wss:' : 'ws:') + '//' + window.location.host + '/ws/server/<%= server.UUID %>/status');
    wsCheck.onerror = function() {};
    window.addEventListener('beforeunload', function() {
      if (wsCheck && wsCheck.readyState === WebSocket.OPEN) wsCheck.close();
    });
  });

  function confirmDeleteWorld(worldName) {
    window.modal.confirm({
      title: 'Delete World',
      body: `Delete "${worldName}"? All world data will be permanently lost and cannot be recovered.`,
      danger: true,
      confirmLabel: 'Delete World',
      onConfirm: function() {
        fetch('/server/<%= server.UUID %>/files/rm/' + encodeURIComponent(worldName), { method: 'DELETE' })
          .then(function(r) {
            if (!r.ok) return r.json().then(function(d) { throw new Error(d.error || 'Failed'); });
            return r.json();
          })
          .then(function(data) {
            if (data.success) {
              showToast('World deleted.', 'success');
              setTimeout(function() { location.reload(); }, 800);
            } else {
              showToast(data.error || 'Failed to delete world.', 'error');
            }
          })
          .catch(function(err) {
            showToast(err.message || 'Failed to delete world.', 'error');
          });
      }
    });
  }
</script>
