<% if (typeof installed !== 'undefined') { %>
<% if (installed.failed) { %>
<div class="mx-4 mt-3 rounded-xl border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 px-3 py-2.5 flex items-center gap-2.5">
  <div class="h-7 w-7 rounded-lg bg-red-100 dark:bg-red-500/10 flex items-center justify-center shrink-0">
    <%- icon('x', { size: 14, class: 'text-red-400 shrink-0' }) %>
  </div>
  <div class="min-w-0">
    <p class="text-xs font-medium text-neutral-800 dark:text-neutral-100">Installation failed</p>
    <p class="text-[11px] text-neutral-500 dark:text-neutral-400 mt-0.5">Check logs or contact an administrator.</p>
  </div>
</div>
<% } else if (!installed.installed && !installed.error) { %>
<div id="installBanner" class="mx-4 mt-3 rounded-xl border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900 px-3 py-2.5 flex items-center gap-2.5">
  <div id="installIconWrap" class="h-7 w-7 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center shrink-0">
    <svg id="installSpinner" xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-neutral-500 dark:text-neutral-400 animate-spin" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/>
    </svg>
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-1.5">
      <p class="text-xs font-medium text-neutral-800 dark:text-neutral-100 shrink-0">Installing server</p>
      <span class="text-neutral-300 dark:text-neutral-600">·</span>
      <p id="installStateText" class="text-[11px] text-neutral-500 dark:text-neutral-400 truncate">Waiting for daemon…</p>
    </div>
  </div>
</div>

<script nonce="<%- nonce %>">
(function () {
  var serverUUID = '<%= server.UUID %>';
  var stateText  = document.getElementById('installStateText');
  var spinnerEl  = document.getElementById('installSpinner');
  var iconWrap   = document.getElementById('installIconWrap');

  var proto   = location.protocol === 'https:' ? 'wss' : 'ws';
  var evtSock = new WebSocket(proto + '://' + location.host + '/events/' + serverUUID);

  evtSock.onmessage = function(msg) {
    var parsed;
    try { parsed = JSON.parse(msg.data); } catch(e) { return; }
    if (parsed.event !== 'lifecycle') return;
    if (parsed.data.message) stateText.textContent = parsed.data.message;
  };

  function markDone() {
    evtSock.close();
    clearInterval(poller);
    stateText.textContent = 'Installation complete';
    if (spinnerEl) {
      spinnerEl.classList.remove('animate-spin', 'text-neutral-500');
      spinnerEl.setAttribute('stroke', 'currentColor');
      spinnerEl.setAttribute('stroke-width', '2');
      spinnerEl.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>';
      spinnerEl.classList.add('text-emerald-500');
    }
    if (iconWrap) {
      iconWrap.className = 'h-7 w-7 rounded-lg bg-emerald-50 dark:bg-emerald-500/10 flex items-center justify-center shrink-0';
    }
    setTimeout(function() { window.location.reload(); }, 1600);
  }

  function markFailed() {
    evtSock.close();
    clearInterval(poller);
    stateText.textContent = 'Installation failed';
    if (spinnerEl) {
      spinnerEl.classList.remove('animate-spin', 'text-neutral-500');
      spinnerEl.setAttribute('stroke', 'currentColor');
      spinnerEl.setAttribute('stroke-width', '2');
      spinnerEl.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>';
      spinnerEl.classList.add('text-red-500');
    }
    if (iconWrap) {
      iconWrap.className = 'h-7 w-7 rounded-lg bg-red-50 dark:bg-red-500/10 flex items-center justify-center shrink-0';
    }
  }

  function poll() {
    fetch('/server/' + serverUUID + '/status')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var state = data.state || (data.installed ? 'installed' : data.failed ? 'failed' : 'installing');
        if (state === 'installed') markDone();
        else if (state === 'failed') markFailed();
      })
      .catch(function() {});
  }

  var poller = setInterval(poll, 3000);
  poll();
})();
</script>
<% } %>
<% } %>
