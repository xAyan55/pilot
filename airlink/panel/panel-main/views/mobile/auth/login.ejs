<%- include('../components/header', { title: 'Sign in' }) %>

<style>
  /* Auth pages are full-bleed — no topbar/bottomnav padding */
  body { padding: 0 !important; }
  ::-webkit-scrollbar { display: none; }
  body, html { height: 100%; margin: 0; }

  /* Desktop: left panel + right image */
  .auth-split {
    display: flex; min-height: 100vh;
  }
  .auth-panel {
    width: 100%; max-width: 420px; flex-shrink: 0;
    display: flex; flex-direction: column; justify-content: center;
    padding: 48px 40px;
    background: var(--theme-bg-card, white);
    border-right: 1px solid var(--theme-border, #e5e5e5);
    position: relative; z-index: 1;
  }
  html.dark .auth-panel {
    background: var(--theme-bg-card, #141414);
    border-right-color: var(--theme-border-subtle, rgba(255,255,255,0.08));
  }
  .auth-image {
    flex: 1;
    background: url('<%= settings.loginWallpaper || "/assets/wallpapers/login.jpeg" %>') center/cover no-repeat;
  }

  /* Mobile: wallpaper fills background, form sits on top */
  @media (max-width: 768px) {
    .auth-split { position: relative; display: block; min-height: 100vh; }
    .auth-image {
      position: fixed;
      inset: 0;
      display: block;
      z-index: 0;
    }
    .auth-panel {
      position: relative;
      z-index: 1;
      max-width: 100%;
      border-right: none;
      padding: 40px 24px;
      min-height: 100vh;
      justify-content: center;
      background: var(--theme-bg-card, rgba(255, 255, 255, 0.95));
    }
    html.dark .auth-panel {
      background: var(--theme-bg-card, rgba(20, 20, 20, 0.95));
    }
  }

  .auth-input {
    width: 100%; padding: 10px 14px; border-radius: 10px;
    border: 1px solid var(--theme-border, #e5e5e5); background: var(--theme-bg-input, #f9fafb);
    font-size: 14px; color: var(--theme-text-strong, #171717); outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box; font-family: inherit;
  }
  html.dark .auth-input {
    background: var(--theme-bg-input, rgba(255,255,255,0.08)); border-color: var(--theme-border-subtle, rgba(255,255,255,0.08)); color: var(--theme-text, #e5e5e5);
  }
  .auth-input:focus {
    border-color: var(--theme-border, #a3a3a3); box-shadow: 0 0 0 3px var(--theme-border-subtle, rgba(0,0,0,0.06));
  }
  html.dark .auth-input:focus {
    border-color: var(--theme-border-subtle, rgba(255,255,255,0.08)); box-shadow: 0 0 0 3px var(--theme-border-subtle, rgba(255,255,255,0.08));
  }
  .auth-input::placeholder { color: var(--theme-text-placeholder, #a3a3a3); }
  html.dark .auth-input::placeholder { color: var(--theme-text-muted, #525252); }

  .auth-label { display: block; font-size: 13px; font-weight: 500; color: var(--theme-text-muted, #525252); margin-bottom: 6px; }
  html.dark .auth-label { color: var(--theme-text, #a3a3a3); }

  .auth-submit {
    width: 100%; padding: 11px; border-radius: 10px;
    background: var(--theme-text-strong, #171717); color: var(--theme-accent-text, white); font-size: 14px; font-weight: 500;
    border: none; cursor: pointer; transition: background 0.15s;
    font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 8px;
  }
  html.dark .auth-submit { background: var(--theme-bg-input, white); color: var(--theme-bg, #0a0a0a); }
  .auth-submit:hover:not(:disabled) { background: var(--theme-bg-hover, #404040); }
  html.dark .auth-submit:hover:not(:disabled) { background: var(--theme-bg-hover, #e5e5e5); }
  .auth-submit:disabled { opacity: 0.6; cursor: default; }

  .pw-wrapper { position: relative; }
  .pw-toggle {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    background: none; border: none; cursor: pointer; padding: 0; color: var(--theme-text-placeholder, #a3a3a3); line-height: 0;
  }
  .pw-toggle:hover { color: var(--theme-text-muted, #737373); }
  html.dark .pw-toggle:hover { color: var(--theme-text-strong, #d4d4d4); }

  /* Custom checkbox */
  .cb-row { display: flex; align-items: center; gap: 9px; cursor: pointer; user-select: none; }
  .cb-box {
    width: 16px; height: 16px; border-radius: 4px; flex-shrink: 0;
    border: 1.5px solid var(--theme-border-strong, #d4d4d4); background: var(--theme-bg-card, white);
    display: flex; align-items: center; justify-content: center;
    transition: background 0.12s, border-color 0.12s;
  }
  html.dark .cb-box { background: var(--theme-bg-card, #262626); border-color: var(--theme-text-muted, #404040); }
  .cb-check { display: none; }

  .spinner {
    width: 15px; height: 15px; flex-shrink: 0;
    border: 2px solid var(--theme-border-subtle, rgba(255,255,255,0.08)); border-top-color: var(--theme-accent-text, white);
    border-radius: 50%; animation: spin 0.65s linear infinite; display: none;
  }
  html.dark .spinner { border-color: var(--theme-border-subtle, rgba(0,0,0,0.25)); border-top-color: var(--theme-bg, #0a0a0a); }
  .auth-submit.loading .spinner { display: block; }
  .auth-submit.loading .btn-label { display: none; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* Entry animation for the panel */
  .auth-panel { opacity: 0; transform: translateX(-12px); transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16,1,0.3,1); }
  .auth-panel.visible { opacity: 1; transform: translateX(0); }
</style>

<div class="auth-split">
  <div class="auth-panel" id="authPanel">

    <div class="mb-8">
      <% if (settings.logo) { %>
      <img src="<%= settings.logo %>" alt="" class="h-10 w-10 rounded-xl object-contain mb-5">
      <% } %>
      <h1 class="text-2xl font-semibold text-neutral-900 dark:text-white">Sign in</h1>
      <p class="text-sm text-neutral-500 mt-1">to <%= settings.title %></p>
    </div>

    <% if (req.query.err) { %>
    <div class="rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 px-4 py-3 mb-5">
      <p class="text-sm font-medium text-red-700 dark:text-red-400">
        <% if (req.query.err === 'discord_config_error') { %>Discord settings are missing in environment configuration.
        <% } else if (req.query.err === 'discord_auth_failed') { %>Discord authorization request was denied or cancelled.
        <% } else if (req.query.err === 'discord_token_error') { %>Failed to exchange Discord authorization code.
        <% } else if (req.query.err === 'discord_user_error') { %>Failed to fetch user profile details from Discord.
        <% } else if (req.query.err === 'discord_invalid_user') { %>Invalid Discord user profile.
        <% } else if (req.query.err === 'discord_only') { %>Please authorize via Discord to sign in.
        <% } else { %>Something went wrong with Discord authentication. Try again.<% } %>
      </p>
    </div>
    <% } %>

    <div class="space-y-4">
      <a href="/auth/discord" class="auth-submit" id="submitBtn" style="background: #5865F2; color: white !important; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 10px; text-decoration: none;">
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" style="margin-right: 4px;">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994.021-.041.001-.09-.041-.106a13.094 13.094 0 0 1-1.873-.894.077.077 0 0 1-.008-.128c.126-.093.252-.19.372-.287a.075.075 0 0 1 .077-.011c3.92 1.793 8.18 1.793 12.061 0a.073.073 0 0 1 .078.009c.12.099.246.195.373.289a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.894.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.156-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.156 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.156-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.156 2.418z"/>
        </svg>
        <span>Authorize Cockpit via Discord</span>
      </a>
    </div>

  </div>
  <div class="auth-image"></div>
</div>

<script nonce="<%- nonce %>">
  requestAnimationFrame(function () {
    requestAnimationFrame(function () {
      document.getElementById('authPanel').classList.add('visible');
    });
  });

  document.getElementById('submitBtn').addEventListener('click', function () {
    this.classList.add('loading');
    this.style.pointerEvents = 'none';
  });
</script>

<%- include('../components/footer') %>
