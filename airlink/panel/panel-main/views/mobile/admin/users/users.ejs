<%- include('../../components/header', { title: req.translations.adminUsersTitle || 'Users' }) %>

<main id="page-content" class="">
  <%- include('../../components/template') %>
  <%- include('../../components/toast') %>

  <div class="px-4 py-5">

    <div class="flex items-start justify-between mb-5">
      <div>
        <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.adminUsersTitle %></h1>
        <p class="text-xs text-neutral-500 mt-0.5"><%= req.translations.adminUsersText %></p>
      </div>
      <a href="/admin/users/create">
        <button type="button" class="inline-flex items-center gap-1.5 rounded-xl bg-neutral-900 dark:bg-neutral-800 border border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-300 hover:bg-neutral-800 dark:hover:bg-neutral-700 transition shrink-0">
          <%- icon('plus', { size: 14, class: 'shrink-0' }) %>
          New User
        </button>
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 gap-3 mb-5">
      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
        <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1"><%= req.translations.totalUsers || 'Total Users' %></p>
        <p class="text-2xl font-semibold text-neutral-800 dark:text-white"><%= users.length %></p>
        <% if (onlineUsers.size > 0) { %>
          <p class="text-xs text-emerald-500 mt-1"><%= onlineUsers.size %> online now</p>
        <% } else { %>
          <p class="text-xs text-neutral-500 mt-1">None online</p>
        <% } %>
      </div>
      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3">
        <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1"><%= req.translations.admins || 'Admins' %></p>
        <p class="text-2xl font-semibold text-neutral-800 dark:text-white"><%= users.filter(u => u.isAdmin).length %></p>
        <p class="text-xs text-neutral-500 mt-1"><%= users.filter(u => !u.isAdmin).length %> regular</p>
      </div>
    </div>

    <% if (req.query.err == "none") { %>
      <div class="rounded-xl bg-emerald-50 dark:bg-emerald-800/10 border border-emerald-200 dark:border-emerald-500/20 px-4 py-3 mb-4 flex items-center gap-3">
        <%- icon('check-circle', { size: 16, class: 'text-emerald-500 shrink-0' }) %>
        <p class="text-sm text-emerald-700 dark:text-emerald-400"><%= req.translations.actionCompleted %></p>
      </div>
    <% } %>

    <!-- User cards -->
    <div class="space-y-2">
      <% let userIdx = 0; users.forEach(function(user) { %>
        <div class="grid-item-animate rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3" style="--i:<%= userIdx++ %>">
          <div class="flex items-center gap-3 mb-3">
            <div class="relative shrink-0">
              <img class="h-9 w-9 rounded-lg" src="<%= user.avatar ? user.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(user.username) %>" alt="">
              <% if (onlineUsers.has(user.username)) { %>
                <span class="absolute -bottom-0.5 -right-0.5 flex h-2.5 w-2.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500 border-2 border-white dark:border-[#141414]"></span>
                </span>
              <% } %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-neutral-800 dark:text-white truncate"><%= user.username %></p>
              <p class="text-xs text-neutral-500 truncate"><%= user.email || '—' %></p>
            </div>
            <span class="text-[10px] font-medium px-2 py-0.5 rounded-md shrink-0 <%= user.isAdmin ? 'bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20' : 'bg-amber-50 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-200 dark:border-amber-500/20' %>">
              <%= user.isAdmin ? 'Admin' : 'User' %>
            </span>
          </div>
          <div class="flex items-center justify-between">
            <p class="text-xs text-neutral-500"><%= user.servers ? user.servers.length : 0 %> server<%= (user.servers && user.servers.length !== 1) ? 's' : '' %></p>
            <div class="flex gap-2">
              <a href="/admin/users/view/<%= user.id %>/">
                <button type="button" class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-2.5 py-1.5 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">View</button>
              </a>
              <a href="/admin/users/edit/<%= user.id %>/">
                <button type="button" class="rounded-lg bg-blue-600 px-2.5 py-1.5 text-xs font-medium text-white hover:bg-blue-500 transition">Edit</button>
              </a>
              <button onclick="deleteUser('<%= user.id %>')" type="button" class="rounded-lg bg-red-600 px-2.5 py-1.5 text-xs font-medium text-white hover:bg-red-500 transition">Remove</button>
            </div>
          </div>
        </div>
      <% }); %>
    </div>

  </div>
</main>

<script nonce="<%- nonce %>">
  function deleteUser(userId) {
    window.modal.confirm({
      title: '<%= req.translations.deleteUser || "Delete User" %>',
      body: '<%= req.translations.areYouSureDeleteUser || "Are you sure you want to delete this user?" %>',
      danger: true,
      confirmLabel: 'Yeah, delete it',
      onConfirm: () => {
        fetch(`/admin/users/delete/${userId}`, { method: 'DELETE' })
          .then(response => {
            if (response.ok) {
              location.reload();
            } else {
              showToast('Failed to delete user.', 'error');
            }
          })
          .catch(() => showToast('Failed to delete user.', 'error'));
      }
    });
  }
</script>

<%- include('../../components/footer') %>
