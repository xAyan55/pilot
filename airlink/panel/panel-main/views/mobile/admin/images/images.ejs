<%- include('../../components/header', { title: req.translations.adminImagesTitle || 'Images' }) %>

<main id="page-content" class="">
  <%- include('../../components/template') %>
  <%- include('../../components/toast') %>

  <div class="px-4 py-5">

    <div class="flex items-start justify-between mb-5">
      <div>
        <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.adminImagesTitle %></h1>
        <p class="text-xs text-neutral-500 mt-0.5"><%= req.translations.adminImagesText %></p>
      </div>
      <div class="flex gap-2 shrink-0">
        <a href="/admin/images/store" class="inline-flex items-center gap-1.5 rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">
          Store
        </a>
        <button id="uploadimage" type="button" class="inline-flex items-center gap-1.5 rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">
          Upload
        </button>
        <button onclick="openModal('createModal')" type="button" class="inline-flex items-center gap-1.5 rounded-xl bg-neutral-900 dark:bg-neutral-800 border border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-300 hover:bg-neutral-800 dark:hover:bg-neutral-700 transition">
          <%- icon('plus', { size: 14, class: 'shrink-0' }) %>
          Create
        </button>
      </div>
    </div>

    <!-- Image cards -->
    <div class="space-y-2">
      <% let imgIdx = 0; images.forEach(function(image) { %>
        <div class="grid-item-animate rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3" style="--i:<%= imgIdx++ %>">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 flex items-center justify-center shrink-0">
              <%- icon('image', { size: 16, class: 'text-neutral-500 shrink-0' }) %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-neutral-800 dark:text-white truncate"><%= image.name %></p>
              <p class="text-xs text-neutral-500 truncate">by <%= image.author %></p>
            </div>
            <p class="text-xs text-neutral-500 shrink-0"><%= new Date(image.createdAt).toLocaleDateString() %></p>
          </div>
          <div class="flex gap-2 justify-end">
            <a href="/admin/images/edit/<%= image.id %>">
              <button type="button" class="rounded-lg bg-blue-600 px-2.5 py-1.5 text-xs font-medium text-white hover:bg-blue-500 transition">Edit</button>
            </a>
            <a href="/admin/images/export/<%= image.id %>">
              <button type="button" class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-2.5 py-1.5 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">Export</button>
            </a>
            <button onclick="deleteImage('<%= image.id %>')" type="button" class="rounded-lg bg-red-600 px-2.5 py-1.5 text-xs font-medium text-white hover:bg-red-500 transition">Delete</button>
          </div>
        </div>
      <% }); %>

      <% if (images.length === 0) { %>
        <div class="py-16 text-center">
          <%- icon('image', { size: 16, class: 'text-neutral-700 shrink-0' }) %>
          <p class="text-sm text-neutral-500">No images yet</p>
        </div>
      <% } %>
    </div>
  </div>
</main>

<!-- Create Image Modal -->
<div id="createModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/60">
  <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-white/5 rounded-2xl w-full shadow-xl max-h-[92vh] overflow-y-auto">

    <div class="flex items-start justify-between px-4 pt-4 pb-3 border-b border-neutral-100 dark:border-white/5">
      <div>
        <p class="text-sm font-semibold text-neutral-800 dark:text-white">Create Image</p>
        <p class="text-xs text-neutral-500 mt-0.5">Configure Docker images and variables after creation.</p>
      </div>
      <button onclick="closeModal('createModal')" class="shrink-0 w-7 h-7 flex items-center justify-center rounded-lg bg-neutral-100 dark:bg-neutral-800 text-neutral-500 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition ml-3">
        <%- icon('x', { size: 14, class: 'shrink-0' }) %>
      </button>
    </div>

    <form action="/admin/images/create" method="POST" class="px-4 py-4 space-y-3">

      <div class="flex flex-col gap-1">
        <label for="m-create-name" class="text-xs font-medium text-neutral-700 dark:text-neutral-300">
          Name <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="m-create-name"
          name="name"
          placeholder="e.g. Minecraft Java"
          required
          class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-neutral-100 dark:bg-neutral-800 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder:text-neutral-400 dark:placeholder:text-neutral-500 focus:outline-none focus:ring-1 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition"
        >
      </div>

      <div class="grid grid-cols-2 gap-2">
        <div class="flex flex-col gap-1">
          <label for="m-create-author" class="text-xs font-medium text-neutral-700 dark:text-neutral-300">Author</label>
          <input
            type="text"
            id="m-create-author"
            name="author"
            placeholder="github.com/you"
            class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-neutral-100 dark:bg-neutral-800 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder:text-neutral-400 dark:placeholder:text-neutral-500 focus:outline-none focus:ring-1 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition"
          >
        </div>
        <div class="flex flex-col gap-1">
          <label for="m-create-authorName" class="text-xs font-medium text-neutral-700 dark:text-neutral-300">Author Name</label>
          <input
            type="text"
            id="m-create-authorName"
            name="authorName"
            placeholder="Your Name"
            class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-neutral-100 dark:bg-neutral-800 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder:text-neutral-400 dark:placeholder:text-neutral-500 focus:outline-none focus:ring-1 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition"
          >
        </div>
      </div>

      <div class="flex flex-col gap-1">
        <label for="m-create-startup" class="text-xs font-medium text-neutral-700 dark:text-neutral-300">
          Startup Command <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="m-create-startup"
          name="startup"
          placeholder="java -Xms128M -jar server.jar"
          required
          class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-neutral-100 dark:bg-neutral-800 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder:text-neutral-400 dark:placeholder:text-neutral-500 focus:outline-none focus:ring-1 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition font-mono"
        >
        <p class="text-xs text-neutral-400 dark:text-neutral-500">Use <code class="px-1 py-0.5 rounded bg-neutral-100 dark:bg-neutral-700 font-mono text-neutral-500 dark:text-neutral-300">$ALVKT(VAR)</code> for variables.</p>
      </div>

      <div class="flex flex-col gap-1">
        <label for="m-create-description" class="text-xs font-medium text-neutral-700 dark:text-neutral-300">Description</label>
        <textarea
          id="m-create-description"
          name="description"
          rows="2"
          placeholder="What does this image run?"
          class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-neutral-100 dark:bg-neutral-800 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder:text-neutral-400 dark:placeholder:text-neutral-500 focus:outline-none focus:ring-1 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition resize-none"
        ></textarea>
      </div>

      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/40 border border-neutral-200 dark:border-white/5 px-3 py-2.5 flex items-start gap-2.5">
        <%- icon('play-circle', { size: 14, class: 'text-neutral-400 shrink-0' }) %>
        <p class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed">You'll be taken to the editor to add Docker images, variables, and scripts after creation.</p>
      </div>

      <div class="flex gap-2 pt-1">
        <button type="button" onclick="closeModal('createModal')"
          class="flex-1 rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-white/5 px-4 py-2.5 text-sm font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">
          Cancel
        </button>
        <button type="submit"
          class="flex-1 rounded-xl bg-neutral-900 dark:bg-white px-4 py-2.5 text-sm font-medium text-white dark:text-neutral-900 hover:bg-neutral-700 dark:hover:bg-neutral-100 transition">
          Create &amp; Edit
        </button>
      </div>

    </form>
  </div>
</div>

<script nonce="<%- nonce %>">
  function openModal(id) {
    const el = document.getElementById(id);
    el.classList.remove('hidden');
    el.classList.add('flex');
  }

  function closeModal(id) {
    const el = document.getElementById(id);
    el.classList.add('hidden');
    el.classList.remove('flex');
  }

  function showConfirmModal(title, message, onConfirm) {
    const modal = document.createElement('div');
    modal.className = 'fixed inset-0 bg-black/50 z-50 flex items-end justify-center opacity-0 pointer-events-none transition-opacity duration-200';
    modal.innerHTML = `
      <div class="bg-white dark:bg-neutral-900 border-t border-neutral-200 dark:border-neutral-700 rounded-t-2xl p-5 w-full translate-y-full transition-transform duration-200 shadow-2xl">
        <h2 class="text-sm font-semibold text-neutral-800 dark:text-white mb-1">${title}</h2>
        <p class="text-xs text-neutral-500 dark:text-neutral-400 mb-5">${message}</p>
        <div class="flex gap-2">
          <button id="modalCancel" class="flex-1 py-2.5 text-sm font-medium rounded-xl bg-neutral-100 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300">Cancel</button>
          <button id="modalConfirm" class="flex-1 py-2.5 text-sm font-medium rounded-xl bg-red-600 text-white">Delete</button>
        </div>
      </div>`;
    document.body.appendChild(modal);
    requestAnimationFrame(() => {
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modal.querySelector('div').classList.remove('translate-y-full');
      modal.querySelector('div').classList.add('translate-y-0');
    });
    const close = () => { modal.classList.add('opacity-0'); setTimeout(() => document.body.removeChild(modal), 200); };
    modal.querySelector('#modalCancel').addEventListener('click', close);
    modal.querySelector('#modalConfirm').addEventListener('click', () => { close(); onConfirm(); });
  }

  function deleteImage(imageId) {
    showConfirmModal('Delete image', 'This will permanently remove the image and cannot be undone.', async () => {
      try {
        const response = await fetch(`/admin/images/delete/${imageId}`, { method: 'DELETE' });
        if (response.ok) {
          showToast('Image deleted.', 'success');
          setTimeout(() => location.reload(), 800);
        } else {
          const msg = await response.text();
          showToast(msg || 'Failed to delete image', 'error');
        }
      } catch {
        showToast('Something went wrong.', 'error');
      }
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('uploadimage').addEventListener('click', () => {
      const input = document.createElement('input');
      input.type = 'file';
      input.accept = '.json';
      input.click();
      input.addEventListener('change', event => {
        const file = event.target.files[0];
        if (!file || file.type !== 'application/json') {
          showToast('Please select a JSON file', 'error');
          return;
        }
        showToast('Uploading...', 'info');
        const reader = new FileReader();
        reader.onload = e => {
          try {
            JSON.parse(e.target.result);
            const xhr = new XMLHttpRequest();
            xhr.open('POST', '/admin/images/upload', true);
            xhr.setRequestHeader('Content-Type', 'application/json');
            xhr.onload = () => {
              if (xhr.status === 200) {
                const res = JSON.parse(xhr.responseText);
                showToast(res.message || 'Image uploaded.', 'success');
                setTimeout(() => location.reload(), 800);
              } else {
                try {
                  const err = JSON.parse(xhr.responseText);
                  showToast(err.error || 'Upload failed', 'error');
                } catch { showToast('Upload failed', 'error'); }
              }
            };
            xhr.onerror = () => showToast('Network error', 'error');
            xhr.send(e.target.result);
          } catch (err) {
            showToast('Invalid JSON: ' + err.message, 'error');
          }
        };
        reader.readAsText(file);
      });
    });
  });
</script>

<%- include('../../components/footer') %>
