<%- include('../../components/header', { title: 'Menu' }) %>

<style>
  @keyframes menu-fade-up {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .menu-item-animate {
    opacity: 0;
    animation: menu-fade-up 0.35s cubic-bezier(0.16,1,0.3,1) forwards;
  }
</style>

<main class="">
  <%- include('../../components/template') %>

  <div class="px-4 py-5">
    <div class="mb-5">
      <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.menuTitle || 'Menu' %></h1>
      <p class="text-xs text-neutral-500 mt-0.5"><%= req.translations.menuSubtitle || 'Navigation and tools' %></p>
    </div>

    <div class="space-y-2">
      <%
      var allItems = regularMenuItems || (global.uiComponentStore ? global.uiComponentStore.getSidebarItems(undefined, false) : []);
      var adminItems = [
        { url: '/admin/overview', label: req.translations.navOverview || 'Overview', desc: req.translations.adminMenuOverviewDesc || 'Panel stats and activity', iconId: 'grid' },
        { url: '/admin/analytics', label: req.translations.navAnalytics || 'Analytics', desc: req.translations.adminMenuAnalyticsDesc || 'Server analytics', iconId: 'bar-chart' },
        { url: '/admin/settings', label: req.translations.navSettings || 'Settings', desc: req.translations.adminMenuSettingsDesc || 'Panel configuration', iconId: 'settings' },
        { url: '/admin/servers', label: req.translations.navServers || 'Servers', desc: req.translations.adminMenuServersDesc || 'Manage all servers', iconId: 'server' },
        { url: '/admin/users', label: req.translations.navUsers || 'Users', desc: req.translations.adminMenuUsersDesc || 'Manage accounts', iconId: 'users' },
        { url: '/admin/nodes', label: req.translations.navNodes || 'Nodes', desc: req.translations.adminMenuNodesDesc || 'Daemon nodes', iconId: 'network' },
        { url: '/admin/images', label: req.translations.navImages || 'Images', desc: req.translations.adminMenuImagesDesc || 'Docker images', iconId: 'box' },
        { url: '/admin/addons', label: req.translations.navAddons || 'Addons', desc: req.translations.adminMenuAddonsDesc || 'Extensions and plugins', iconId: 'puzzle' },
        { url: '/admin/airlink-cloud', label: req.translations.navAirlinkCloud || 'Airlink Cloud', desc: 'Cloud storage integration', iconId: 'cloud' },
        { url: '/admin/apikeys', label: req.translations.navApiKeys || 'API Keys', desc: req.translations.adminMenuApiKeysDesc || 'Access tokens', iconId: 'key' }
      ];
      var addonItems = adminMenuItems || [];
      var _itemIdx = 0;
      %>

      <% allItems.forEach(function(item) { %>
      <a href="<%= item.url %>" class="menu-item-animate flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100" style="animation-delay: <%= (_itemIdx++ * 40) %>ms">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0">
          <div class="w-5 h-5 flex items-center justify-center [&>svg]:w-5 [&>svg]:h-5 [&>svg]:shrink-0"><%- item.icon %></div>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= item.label %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>
      <% }); %>

      <% if (user.isAdmin === true) { %>
      <p class="menu-item-animate text-xs font-medium text-neutral-500 dark:text-neutral-400 pt-4 pb-1" style="animation-delay: <%= (_itemIdx++ * 40) %>ms"><%= req.translations.navAdminPanel || 'Admin Panel' %></p>
      <% adminItems.forEach(function(item) { %>
      <a href="<%= item.url %>" class="menu-item-animate flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100" style="animation-delay: <%= (_itemIdx++ * 40) %>ms">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0">
          <%- icon(item.iconId, { size: 18, class: 'text-neutral-600 shrink-0' }) %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= item.label %></p>
          <p class="text-xs text-neutral-500 truncate"><%= item.desc %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>
      <% }); %>
      <% } else { %>
      <p class="menu-item-animate text-xs font-medium text-neutral-500 dark:text-neutral-400 pt-4 pb-1" style="animation-delay: <%= (_itemIdx++ * 40) %>ms"><%= req.translations.navAdminPanel || 'Admin Panel' %></p>
      <% adminItems.forEach(function(item) { %>
      <div class="menu-item-animate flex items-center gap-3 px-4 py-3 rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-100 dark:border-neutral-700/10 opacity-40 pointer-events-none" style="animation-delay: <%= (_itemIdx++ * 40) %>ms">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/30 flex items-center justify-center shrink-0">
          <%- icon(item.iconId, { size: 18, class: 'text-neutral-400 shrink-0' }) %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-500 dark:text-neutral-500"><%= item.label %></p>
          <p class="text-xs text-neutral-400 truncate"><%= item.desc %></p>
        </div>
        <%- icon('lock', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </div>
      <% }); %>
      <% } %>

      <% if (addonItems.length > 0) { %>
      <p class="menu-item-animate text-xs font-medium text-neutral-500 dark:text-neutral-400 pt-4 pb-1" style="animation-delay: <%= (_itemIdx++ * 40) %>ms"><%= req.translations.navAddons || 'Addons' %></p>
      <% addonItems.forEach(function(item) { %>
      <a href="<%= item.url %>" class="menu-item-animate flex items-center gap-3 px-4 py-3 rounded-xl bg-white dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/30 active:scale-[0.98] transition-transform duration-100" style="animation-delay: <%= (_itemIdx++ * 40) %>ms">
        <div class="w-9 h-9 rounded-lg bg-neutral-100 dark:bg-neutral-700/50 flex items-center justify-center shrink-0 overflow-hidden">
          <div class="w-5 h-5 flex items-center justify-center [&>svg]:w-5 [&>svg]:h-5 [&>svg]:shrink-0">
            <%- item.icon %>
          </div>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-neutral-800 dark:text-white"><%= item.label %></p>
        </div>
        <%- icon('chevron-right', { size: 16, class: 'text-neutral-400 shrink-0' }) %>
      </a>
      <% }); %>
      <% } %>

    </div>
  </div>
</main>

<%- include('../../components/footer') %>
