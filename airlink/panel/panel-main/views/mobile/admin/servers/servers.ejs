<%- include('../../components/header', { title: req.translations.adminServersTitle || 'Servers' }) %>

<main id="page-content" class="">
  <%- include('../../components/template') %>
  <%- include('../../components/toast') %>
  <%- include('../../components/loadingPopup') %>

  <div class="px-4 py-5">

    <div class="flex items-start justify-between mb-4">
      <div>
        <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.adminServersTitle %></h1>
        <p class="text-xs text-neutral-500 mt-0.5"><%= req.translations.adminServersText %></p>
      </div>
      <button onclick="location.href='/admin/servers/create'" type="button"
        class="inline-flex items-center gap-1.5 rounded-xl bg-neutral-900 dark:bg-neutral-800 border border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-300 hover:bg-neutral-800 dark:hover:bg-neutral-700 transition shrink-0">
        <%- icon('plus', { size: 14, class: 'shrink-0' }) %>
        New Server
      </button>
    </div>

    <% if (req.query.err == "none") { %>
    <div class="rounded-xl bg-emerald-50 dark:bg-emerald-800/10 border border-emerald-200 dark:border-emerald-500/20 px-4 py-3 mb-4 flex items-center gap-3">
      <%- icon('check-circle', { size: 16, class: 'text-emerald-500 shrink-0' }) %>
      <p class="text-sm text-emerald-700 dark:text-emerald-400"><%= req.translations.actionCompleted %></p>
    </div>
    <% } %>

    <!-- Sentinel — watched by IntersectionObserver -->
    <div id="toolbarSentinel" class="h-px w-full" aria-hidden="true"></div>

    <!-- Bulk toolbar — hidden until a checkbox is checked -->
    <div id="bulkToolbarRow" style="display:none;overflow:hidden;transition:max-height 0.38s cubic-bezier(0.16,1,0.3,1),opacity 0.28s ease;max-height:0;opacity:0">
      <div class="mb-3">
        <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-neutral-100 dark:bg-neutral-800/60 border border-neutral-200 dark:border-neutral-700/40">
          <span class="selection-count text-xs font-medium text-neutral-600 dark:text-neutral-300 mr-1">0 selected</span>
          <div class="h-3.5 w-px bg-neutral-300 dark:bg-neutral-600 mx-0.5"></div>
          <button type="button" onclick="bulkRadarScan()"
            class="inline-flex items-center gap-1 rounded-lg bg-white dark:bg-neutral-700 border border-neutral-200 dark:border-neutral-600 px-2.5 py-1.5 text-xs font-medium text-neutral-700 dark:text-neutral-200 hover:bg-neutral-50 dark:hover:bg-neutral-600 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
            </svg>
            Radar
          </button>
          <button type="button" onclick="bulkDelete()"
            class="inline-flex items-center gap-1 rounded-lg bg-red-600 hover:bg-red-500 px-2.5 py-1.5 text-xs font-medium text-white transition-colors ml-auto">
            <%- icon('trash-2', { size: 14, class: 'shrink-0' }) %>
            Delete
          </button>
        </div>
      </div>
    </div>

    <!-- Floating pill — fixed below mobile topbar when toolbar scrolls off screen -->
    <div id="floatingToolbar"
      style="position:fixed;top:64px;left:50%;transform:translateX(-50%) translateY(-10px);z-index:40;opacity:0;pointer-events:none;transition:opacity 0.22s ease,transform 0.22s cubic-bezier(0.16,1,0.3,1);width:calc(100% - 2rem);max-width:420px">
      <div class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white dark:bg-neutral-900 shadow-xl border border-neutral-200 dark:border-neutral-700/60">
        <span class="selection-count text-xs font-medium text-neutral-600 dark:text-neutral-300 mr-1">0 selected</span>
        <div class="h-3.5 w-px bg-neutral-300 dark:bg-neutral-600 mx-0.5"></div>
        <button type="button" onclick="bulkRadarScan()"
          class="inline-flex items-center gap-1 rounded-lg bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-2.5 py-1.5 text-xs font-medium text-neutral-700 dark:text-neutral-200 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
          </svg>
          Radar
        </button>
        <button type="button" onclick="bulkDelete()"
          class="inline-flex items-center gap-1 rounded-lg bg-red-600 hover:bg-red-500 px-2.5 py-1.5 text-xs font-medium text-white transition-colors ml-auto">
          <%- icon('trash-2', { size: 14, class: 'shrink-0' }) %>
          Delete
        </button>
      </div>
    </div>

    <!-- Server cards -->
    <div class="space-y-2">
      <% let srvIdx = 0; servers.forEach(function(server) { %>
      <div class="grid-item-animate server-card rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3 cursor-pointer"
        style="--i:<%= srvIdx++ %>"
        data-id="<%= server.id %>" data-uuid="<%= server.UUID %>">

        <div class="flex items-center gap-3 mb-3">
          <input type="checkbox" class="server-checkbox rounded border-neutral-300 dark:border-neutral-600 cursor-pointer shrink-0"
            value="<%= server.id %>" data-uuid="<%= server.UUID %>" data-name="<%= server.name %>">
          <div class="w-7 h-7 rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 flex items-center justify-center shrink-0">
            <% if (server.Suspended) { %>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-neutral-400"></span>
            <% } else { %>
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
              </span>
            <% } %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-neutral-800 dark:text-white truncate server-name"><%= server.name %></p>
            <p class="text-xs text-neutral-500 font-mono truncate"><%= server.UUID %></p>
          </div>
          <span class="text-[10px] font-medium px-2 py-0.5 rounded-md shrink-0
            <%= server.Suspended ? 'bg-amber-50 dark:bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-200 dark:border-amber-500/20' : 'bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20' %>">
            <%= server.Suspended ? 'Suspended' : 'Enabled' %>
          </span>
        </div>

        <div class="flex gap-2 mb-3">
          <div class="flex-1 bg-neutral-100 dark:bg-neutral-800/50 rounded-lg px-2.5 py-2">
            <p class="text-[10px] text-neutral-500 mb-0.5">Owner</p>
            <a href="/admin/users/view/<%= server.owner.id %>" class="flex items-center gap-1.5" onclick="event.stopPropagation()">
              <img class="h-4 w-4 rounded object-cover shrink-0"
                src="<%= server.owner.avatar ? server.owner.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(server.owner.username) %>" alt="">
              <span class="text-xs font-medium text-blue-600 dark:text-blue-400 truncate"><%= server.owner.username %></span>
            </a>
          </div>
          <div class="flex-1 bg-neutral-100 dark:bg-neutral-800/50 rounded-lg px-2.5 py-2">
            <p class="text-[10px] text-neutral-500 mb-0.5">Node</p>
            <a href="/admin/node/<%= server.node.id %>/stats" class="text-xs font-medium text-blue-600 dark:text-blue-400 truncate block" onclick="event.stopPropagation()"><%= server.node.name %></a>
          </div>
          <div class="flex-1 bg-neutral-100 dark:bg-neutral-800/50 rounded-lg px-2.5 py-2">
            <p class="text-[10px] text-neutral-500 mb-0.5">Port</p>
            <p class="text-xs font-medium text-neutral-700 dark:text-neutral-300 font-mono truncate"><%= server.node.address %>:<%= JSON.parse(server.Ports).filter(p => p.primary).map(p => p.externalPort || String(p.Port || '').split(':')[0]).pop() %></p>
          </div>
        </div>

        <div class="flex gap-2 justify-end">
          <a href="/server/<%= server.UUID %>" onclick="event.stopPropagation()">
            <button type="button" class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 p-2 text-neutral-600 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition" title="Open console">
              <%- icon('external-link', { size: 16, class: 'shrink-0' }) %>
            </button>
          </a>
          <a href="/admin/servers/edit/<%= server.id %>" onclick="event.stopPropagation()">
            <button type="button" class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 p-2 text-neutral-600 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition" title="Edit">
              <%- icon('pencil', { size: 16, class: 'shrink-0' }) %>
            </button>
          </a>
          <button type="button" onclick="event.stopPropagation(); openRadarScanModal('<%= server.id %>', '<%= server.name %>')"
            class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 p-2 text-neutral-600 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition" title="Radar scan">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
            </svg>
          </button>
          <button type="button" onclick="event.stopPropagation(); confirmDelete('<%= server.id %>', '<%= server.name %>')"
            class="rounded-lg bg-red-600 p-2 text-white hover:bg-red-500 transition" title="Delete">
            <%- icon('trash-2', { size: 16, class: 'shrink-0' }) %>
          </button>
        </div>

      </div>
      <% }); %>
    </div>

  </div>
</main>

<!-- Radar scan modal -->
<div id="radarScanModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4 bg-black/60 backdrop-blur-sm">
  <div class="bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-white/10 rounded-2xl w-full shadow-xl overflow-hidden max-h-[90vh] flex flex-col">

    <div class="flex items-start justify-between px-5 pt-5 pb-4 border-b border-neutral-200 dark:border-white/10 shrink-0">
      <div>
        <p class="text-sm font-semibold text-neutral-800 dark:text-white" id="radarScanModalTitle">Radar Scan</p>
        <p class="text-xs text-neutral-500 mt-0.5" id="radarScanModalSubtitle">Pick a script and scan the server volume</p>
      </div>
      <button onclick="closeRadarScanModal()" class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200 transition ml-3 shrink-0 mt-0.5">
        <%- icon('x', { size: 18, class: 'shrink-0' }) %>
      </button>
    </div>

    <!-- Picker phase -->
    <div id="radarPickerPhase" class="px-5 py-4 shrink-0">

      <div id="scanModeToggle" class="hidden mb-4">
        <div class="flex gap-2">
          <button type="button" id="modeBuiltin" onclick="setScanMode('builtin')"
            class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl border-2 border-neutral-800 dark:border-white bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 text-xs font-medium transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
            </svg>
            Built-in
          </button>
          <button type="button" id="modeVT" onclick="setScanMode('vt')"
            class="flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl border-2 border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 text-xs font-medium transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.25-8.25-3.286Z"/>
            </svg>
            VirusTotal
          </button>
        </div>
      </div>

      <div id="builtinPickerSection">
        <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Script</label>
        <select id="scriptSelect" class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2 text-sm text-neutral-800 dark:text-white mb-2 focus:outline-none"></select>
        <p id="scriptDescription" class="text-xs text-neutral-500 italic mb-4 min-h-4"></p>
        <button id="runScanButton" onclick="runRadarScan()"
          class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-neutral-900 dark:bg-neutral-700 border border-neutral-700/40 px-4 py-2.5 text-sm font-medium text-white hover:bg-neutral-800 transition">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
          </svg>
          Run Scan
        </button>
      </div>

      <div id="vtScanSection" class="hidden">
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/60 border border-neutral-200 dark:border-neutral-700/40 p-4 mb-4 space-y-1.5 text-xs text-neutral-500">
          <p>Zips <span class="font-mono text-neutral-700 dark:text-neutral-300">plugins/</span>, <span class="font-mono text-neutral-700 dark:text-neutral-300">mods/</span>, <span class="font-mono text-neutral-700 dark:text-neutral-300">config/</span>, <span class="font-mono text-neutral-700 dark:text-neutral-300">addons/</span> and uploads to VirusTotal.</p>
          <p>Excludes world folders, logs, cache. Max 32 MB. Takes 30–120 seconds.</p>
          <p class="text-amber-600 dark:text-amber-400">Free tier: 4 requests/min · 500/day.</p>
        </div>
        <button type="button" id="runVtScanButton" onclick="runVtFileScan()"
          class="w-full inline-flex items-center justify-center gap-2 rounded-xl bg-neutral-900 dark:bg-neutral-700 border border-neutral-700/40 px-4 py-2.5 text-sm font-medium text-white hover:bg-neutral-800 transition">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.25-8.25-3.286Z"/>
          </svg>
          Upload to VirusTotal
        </button>
      </div>

    </div>

    <!-- Results phase -->
    <div id="radarResultsPhase" class="hidden flex-col min-h-0 flex-1">
      <div id="radarSummaryBar" class="px-5 py-3 border-t border-neutral-200 dark:border-white/10 bg-neutral-50 dark:bg-neutral-800/60 shrink-0"></div>
      <div id="radarResultsBody" class="px-5 py-4 overflow-y-auto flex-1"></div>
      <div class="px-5 py-3 border-t border-neutral-200 dark:border-white/10 flex justify-between items-center shrink-0">
        <button type="button" onclick="resetRadarToPickerPhase()" class="text-xs text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition">← Run another scan</button>
        <button onclick="closeRadarScanModal()" class="rounded-lg bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-1.5 text-xs font-medium text-neutral-700 dark:text-neutral-200 transition">Close</button>
      </div>
    </div>

  </div>
</div>

<script nonce="<%- nonce %>">
(function () {

  var vtEnabled = false;
  var scanMode = 'builtin';
  var currentServerIds = [];
  var availableScripts = [];

  // ── Toolbar ────────────────────────────────────────────────────────────────

  function getChecked() {
    return Array.from(document.querySelectorAll('.server-checkbox:checked'));
  }

  var sentinelVisible = true;
  var anyChecked = false;

  function setFloatingVisible(show) {
    var el = document.getElementById('floatingToolbar');
    if (show) {
      el.style.opacity = '1';
      el.style.transform = 'translateX(-50%) translateY(0)';
      el.style.pointerEvents = 'auto';
    } else {
      el.style.opacity = '0';
      el.style.transform = 'translateX(-50%) translateY(-10px)';
      el.style.pointerEvents = 'none';
    }
  }

  function showInlineToolbar() {
    var row = document.getElementById('bulkToolbarRow');
    row.style.display = 'block';
    requestAnimationFrame(function () {
      row.style.maxHeight = '52px';
      row.style.opacity = '1';
    });
  }

  function hideInlineToolbar() {
    var row = document.getElementById('bulkToolbarRow');
    row.style.maxHeight = '0';
    row.style.opacity = '0';
    setTimeout(function () {
      if (!anyChecked) row.style.display = 'none';
    }, 400);
  }

  function updateToolbar() {
    var checked = getChecked();
    anyChecked = checked.length > 0;

    document.querySelectorAll('.selection-count').forEach(function (el) {
      el.textContent = checked.length + ' selected';
    });

    if (anyChecked) {
      showInlineToolbar();
      setFloatingVisible(!sentinelVisible);
    } else {
      hideInlineToolbar();
      setFloatingVisible(false);
    }
  }

  var observer = new IntersectionObserver(function (entries) {
    sentinelVisible = entries[0].isIntersecting;
    if (anyChecked) setFloatingVisible(!sentinelVisible);
  }, { threshold: 0 });
  observer.observe(document.getElementById('toolbarSentinel'));

  function animateCheckbox(cb) {
    if (window.animateCheckbox) window.animateCheckbox(cb);
  }

  document.querySelectorAll('.server-checkbox').forEach(function (cb) {
    cb.addEventListener('change', function () {
      animateCheckbox(this);
      updateToolbar();
    });
  });

  document.querySelectorAll('.server-card').forEach(function (card) {
    card.addEventListener('click', function (e) {
      if (['A', 'BUTTON', 'INPUT'].includes(e.target.tagName) || e.target.closest('a, button')) return;
      var cb = card.querySelector('.server-checkbox');
      cb.checked = !cb.checked;
      animateCheckbox(cb);
      updateToolbar();
    });
  });

  // ── Bulk actions ───────────────────────────────────────────────────────────

  function bulkRadarScan() {
    var checked = getChecked();
    if (!checked.length) return;
    var first = checked[0];
    openRadarScanModal(first.value, first.dataset.name || first.value);
  }

  function bulkDelete() {
    var checked = getChecked();
    if (!checked.length) return;
    var msg = checked.length === 1
      ? 'Delete this server? All data will be permanently removed.'
      : 'Delete ' + checked.length + ' servers? All data will be permanently removed.';
    window.modal.confirm({
      title: checked.length === 1 ? 'Delete Server' : 'Delete ' + checked.length + ' Servers',
      body: msg,
      danger: true,
      confirmLabel: 'Delete',
      onConfirm: function () {
        checked.forEach(function (cb) { window.location.href = '/admin/server/delete/' + cb.value; });
      }
    });
  }

  function confirmDelete(serverId, serverName) {
    window.modal.confirm({
      title: 'Delete Server',
      body: 'Delete "' + serverName + '"? All server data will be permanently removed.',
      danger: true,
      confirmLabel: 'Delete',
      onConfirm: function () { window.location.href = '/admin/server/delete/' + serverId; }
    });
  }

  // ── VT check ───────────────────────────────────────────────────────────────

  fetch('/admin/radar/virustotal-enabled')
    .then(function (r) { return r.json(); })
    .then(function (d) {
      vtEnabled = d.enabled;
      if (vtEnabled) document.getElementById('scanModeToggle').classList.remove('hidden');
    })
    .catch(function () {});

  // ── Scan mode ──────────────────────────────────────────────────────────────

  function setScanMode(mode) {
    scanMode = mode;
    var builtinBtn = document.getElementById('modeBuiltin');
    var vtBtn = document.getElementById('modeVT');
    var active   = 'flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl border-2 border-neutral-800 dark:border-white bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 text-xs font-medium transition-all';
    var inactive = 'flex-1 flex items-center justify-center gap-1.5 px-3 py-2 rounded-xl border-2 border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 text-xs font-medium transition-all';
    if (mode === 'builtin') {
      builtinBtn.className = active;
      vtBtn.className = inactive;
      document.getElementById('builtinPickerSection').classList.remove('hidden');
      document.getElementById('vtScanSection').classList.add('hidden');
    } else {
      vtBtn.className = active;
      builtinBtn.className = inactive;
      document.getElementById('vtScanSection').classList.remove('hidden');
      document.getElementById('builtinPickerSection').classList.add('hidden');
    }
  }

  // ── Modal open/close ───────────────────────────────────────────────────────

  function openRadarScanModal(serverId, serverName) {
    currentServerIds = [serverId];
    document.getElementById('radarScanModalTitle').textContent = 'Radar Scan: ' + serverName;
    document.getElementById('radarScanModalSubtitle').textContent = 'Pick a script and scan the server volume';
    document.getElementById('radarResultsPhase').classList.remove('flex');
    document.getElementById('radarResultsPhase').classList.add('hidden');
    document.getElementById('radarPickerPhase').classList.remove('hidden');
    var modal = document.getElementById('radarScanModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    setScanMode('builtin');
    fetchRadarScripts();
  }

  function closeRadarScanModal() {
    var modal = document.getElementById('radarScanModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    currentServerIds = [];
  }

  function resetRadarToPickerPhase() {
    document.getElementById('radarResultsPhase').classList.remove('flex');
    document.getElementById('radarResultsPhase').classList.add('hidden');
    document.getElementById('radarPickerPhase').classList.remove('hidden');
    setScanMode(scanMode);
  }

  // ── Scripts ────────────────────────────────────────────────────────────────

  function fetchRadarScripts() {
    var select = document.getElementById('scriptSelect');
    var runBtn = document.getElementById('runScanButton');
    select.innerHTML = '<option value="">Loading...</option>';
    runBtn.disabled = true;

    fetch('/admin/radar/scripts')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        availableScripts = (data.success && data.scripts) ? data.scripts : [];
        select.innerHTML = '';
        if (!availableScripts.length) {
          select.innerHTML = '<option value="">No scripts available</option>';
          document.getElementById('scriptDescription').textContent = 'No radar scripts found in storage/radar/';
          return;
        }
        availableScripts.forEach(function (s) {
          var opt = document.createElement('option');
          opt.value = s.id;
          opt.textContent = s.name;
          select.appendChild(opt);
        });
        updateScriptDescription();
        runBtn.disabled = false;
      })
      .catch(function () { showToast('Failed to fetch scripts', 'error'); });
  }

  function updateScriptDescription() {
    var id = document.getElementById('scriptSelect').value;
    var script = availableScripts.find(function (s) { return s.id === id; });
    document.getElementById('scriptDescription').textContent = script ? script.description : '';
  }

  document.getElementById('scriptSelect').addEventListener('change', updateScriptDescription);

  // ── Built-in scan ──────────────────────────────────────────────────────────

  function runRadarScan() {
    if (!currentServerIds.length) return;
    var scriptId = document.getElementById('scriptSelect').value;
    if (!scriptId) { showToast('Select a script first', 'error'); return; }

    var btn = document.getElementById('runScanButton');
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Scanning...';

    fetch('/admin/radar/scan/' + currentServerIds[0], {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ scriptId: scriptId }),
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.success) {
          showToast('Scan failed: ' + (data.error || 'Unknown error'), 'error');
        } else {
          document.getElementById('radarPickerPhase').classList.add('hidden');
          var resultsPhase = document.getElementById('radarResultsPhase');
          resultsPhase.classList.remove('hidden');
          resultsPhase.classList.add('flex');
          renderResults(data.results);
        }
      })
      .catch(function (err) {
        console.error('Scan error:', err);
        showToast('Failed to run scan', 'error');
      })
      .finally(function () {
        btn.disabled = false;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 3.75H6A2.25 2.25 0 0 0 3.75 6v1.5M16.5 3.75H18A2.25 2.25 0 0 1 20.25 6v1.5m0 9V18A2.25 2.25 0 0 1 18 20.25h-1.5m-9 0H6A2.25 2.25 0 0 1 3.75 18v-1.5M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg> Run Scan';
      });
  }

  // ── VT file scan ───────────────────────────────────────────────────────────

  function runVtFileScan() {
    if (!currentServerIds.length) return;
    var serverId = currentServerIds[0];
    var btn = document.getElementById('runVtScanButton');

    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Starting...';

    closeRadarScanModal();

    var p = window.loadingPopupSystem;
    p.open('VirusTotal Scan', 'default');
    p.setProgress(5, 'Requesting file archive from node...');
    p.addStep('Connecting to node');

    var steps = [
      { at: 3000,  pct: 12, msg: 'Node zipping files...',                step: 'Archiving server files' },
      { at: 9000,  pct: 24, msg: 'Uploading to VirusTotal...',           step: 'Uploading archive' },
      { at: 16000, pct: 36, msg: 'VirusTotal queuing analysis...',        step: 'Upload complete' },
      { at: 26000, pct: 48, msg: 'Checking signatures...',                step: 'VT analysis started' },
      { at: 40000, pct: 60, msg: 'Running 70+ antivirus engines...',      step: 'Multi-engine scan' },
      { at: 56000, pct: 72, msg: 'Collecting results...',                 step: 'Engines finishing' },
      { at: 75000, pct: 82, msg: 'Waiting for final verdicts...',         step: 'Final results' },
    ];
    var timers = steps.map(function (s) {
      return setTimeout(function () { p.setProgress(s.pct, s.msg); p.addStep(s.step); }, s.at);
    });

    fetch('/admin/radar/vtscan/' + serverId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        timers.forEach(function (t) { clearTimeout(t); });

        if (!data.success) {
          p.setProgress(100, 'Scan failed');
          p.addStep(data.error || 'VT scan failed', 'error');
          p.setIcon('error');
          showToast(data.error || 'VT scan failed', 'error');
          setTimeout(function () { p.close(); }, 3000);
          return;
        }

        p.setProgress(100, 'Scan complete');
        p.addStep('Analysis complete', 'done');
        p.setIcon('done');

        setTimeout(function () {
          p.close();
          document.getElementById('radarScanModalTitle').textContent = 'VirusTotal: ' + (data.serverName || 'Server');
          document.getElementById('radarScanModalSubtitle').textContent = 'Results from VirusTotal analysis';
          document.getElementById('radarPickerPhase').classList.add('hidden');
          var resultsPhase = document.getElementById('radarResultsPhase');
          resultsPhase.classList.remove('hidden');
          resultsPhase.classList.add('flex');
          var modal = document.getElementById('radarScanModal');
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          renderVtFileScanResults(data);
        }, 800);
      })
      .catch(function (err) {
        timers.forEach(function (t) { clearTimeout(t); });
        console.error('VT scan error:', err);
        p.setProgress(100, 'Request failed');
        p.addStep('Network error', 'error');
        p.setIcon('error');
        showToast('VT file scan failed', 'error');
        setTimeout(function () { p.close(); }, 3000);
      })
      .finally(function () {
        btn.disabled = false;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.25-8.25-3.286Z"/></svg> Upload to VirusTotal';
      });
  }

  // ── VT hash check ──────────────────────────────────────────────────────────

  function checkVirusTotal(hash, matchId) {
    var btn = document.querySelector('#' + matchId + ' .vt-btn');
    var resultEl = document.querySelector('.vt-result-' + matchId);
    if (!btn || !resultEl) return;

    btn.disabled = true;
    btn.textContent = '...';

    fetch('/admin/radar/virustotal', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ hash: hash }),
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.success) {
          resultEl.innerHTML = '<span class="text-xs text-red-500">VT error: ' + escapeHtml(data.error) + '</span>';
        } else if (!data.found) {
          resultEl.innerHTML = '<span class="text-xs text-neutral-400">Not in VirusTotal database</span>';
        } else {
          var colour = data.malicious > 0 ? 'text-red-600 dark:text-red-400' : 'text-emerald-600 dark:text-emerald-400';
          resultEl.innerHTML =
            '<div class="flex flex-wrap gap-x-2 gap-y-0.5">' +
            '<span class="text-xs font-medium ' + colour + '">' + data.malicious + '/' + data.total + ' engines</span>' +
            (data.name ? '<span class="text-xs text-neutral-400">' + escapeHtml(data.name) + '</span>' : '') +
            '<a href="' + data.vtLink + '" target="_blank" rel="noopener" class="text-xs text-blue-500">View →</a>' +
            '</div>';
          btn.remove();
        }
        resultEl.classList.remove('hidden');
      })
      .catch(function () {
        resultEl.innerHTML = '<span class="text-xs text-red-500">Request failed</span>';
        resultEl.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'VT';
      });
  }

  // ── Result rendering ───────────────────────────────────────────────────────

  function renderVtFileScanResults(data) {
    var summaryEl = document.getElementById('radarSummaryBar');
    var bodyEl = document.getElementById('radarResultsBody');

    if (data.pending) {
      summaryEl.innerHTML = '<span class="text-sm text-amber-600 dark:text-amber-400 font-medium">Analysis still processing</span>';
      bodyEl.innerHTML = '<div class="py-6 text-center"><p class="text-sm text-neutral-500 mb-3">VT is still analysing. Check directly:</p><a href="' + data.vtLink + '" target="_blank" rel="noopener" class="text-sm text-blue-500 break-all">' + escapeHtml(data.vtLink) + '</a></div>';
      return;
    }

    var malCount = (data.maliciousEngines && data.maliciousEngines.length) || 0;
    var total = data.totalEngines || 0;

    summaryEl.innerHTML = malCount === 0
      ? '<div class="flex items-center justify-between"><span class="inline-flex items-center gap-1.5 text-sm text-emerald-600 dark:text-emerald-400 font-medium"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>Clean — 0/' + total + ' flagged</span><a href="' + data.vtLink + '" target="_blank" rel="noopener" class="text-xs text-blue-500">Report →</a></div>'
      : '<div class="flex items-center justify-between"><span class="inline-flex items-center gap-1.5 text-sm text-red-600 dark:text-red-400 font-medium"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/></svg>' + malCount + '/' + total + ' engines flagged</span><a href="' + data.vtLink + '" target="_blank" rel="noopener" class="text-xs text-blue-500">Report →</a></div>';

    if (malCount === 0) {
      bodyEl.innerHTML = '<div class="py-8 text-center"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="w-8 h-8 mx-auto mb-3 text-emerald-400"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg><p class="text-sm font-medium text-neutral-600 dark:text-neutral-300">No engines flagged anything</p><p class="text-xs text-neutral-400 mt-1">' + total + ' engines scanned</p></div>';
      return;
    }

    var html = '<div class="space-y-1">';
    data.maliciousEngines.forEach(function (e) {
      html += '<div class="flex items-center justify-between px-3 py-2 rounded-lg bg-red-50 dark:bg-red-900/10 border border-red-100 dark:border-red-900/20">';
      html += '<span class="text-xs font-medium text-neutral-700 dark:text-neutral-300">' + escapeHtml(e.engine) + '</span>';
      html += '<span class="text-xs text-red-600 dark:text-red-400 font-mono">' + escapeHtml(e.result || 'flagged') + '</span>';
      html += '</div>';
    });
    html += '</div>';
    bodyEl.innerHTML = html;
  }

  function renderResults(scanResults) {
    var summaryEl = document.getElementById('radarSummaryBar');
    var bodyEl = document.getElementById('radarResultsBody');
    var total = (!scanResults || !scanResults.results) ? 0 : scanResults.results.reduce(function (s, r) { return s + (r.matches ? r.matches.length : 0); }, 0);
    var sevStyles = {
      critical: 'bg-red-100 dark:bg-red-900/20 text-red-600 dark:text-red-400',
      high:     'bg-orange-100 dark:bg-orange-900/20 text-orange-600 dark:text-orange-400',
      medium:   'bg-amber-100 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400',
      low:      'bg-yellow-100 dark:bg-yellow-900/20 text-yellow-600 dark:text-yellow-400',
    };

    if (total === 0) {
      summaryEl.innerHTML = '<span class="inline-flex items-center gap-1.5 text-sm text-emerald-600 dark:text-emerald-400 font-medium"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/></svg>No suspicious files found</span>';
      bodyEl.innerHTML = '<div class="py-8 text-center"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="w-8 h-8 mx-auto mb-3 text-emerald-400"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg><p class="text-sm font-medium text-neutral-600 dark:text-neutral-300">All clear</p><p class="text-xs text-neutral-400 mt-1">No matches found</p></div>';
      return;
    }

    var pc = scanResults.results.length;
    summaryEl.innerHTML = '<span class="inline-flex items-center gap-1.5 text-sm text-red-600 dark:text-red-400 font-medium"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495ZM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5Zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z" clip-rule="evenodd"/></svg>' + total + ' finding' + (total !== 1 ? 's' : '') + ' across ' + pc + ' pattern' + (pc !== 1 ? 's' : '') + '</span>';

    var html = '<div class="space-y-3">';
    scanResults.results.forEach(function (result) {
      var sev = result.severity || 'low';
      var count = result.matches ? result.matches.length : 0;
      html += '<div class="rounded-lg border border-neutral-200 dark:border-neutral-700/40 overflow-hidden">';
      html += '<div class="flex items-center justify-between px-3 py-2 bg-neutral-100 dark:bg-neutral-800/60">';
      html += '<p class="text-xs font-medium text-neutral-700 dark:text-neutral-200 flex-1 min-w-0 pr-2">' + escapeHtml(result.pattern.description) + '</p>';
      html += '<div class="flex items-center gap-1.5 shrink-0"><span class="text-xs font-medium px-2 py-0.5 rounded-full ' + (sevStyles[sev] || sevStyles.low) + '">' + sev + '</span><span class="text-xs text-neutral-500">' + count + '</span></div>';
      html += '</div><ul class="divide-y divide-neutral-100 dark:divide-neutral-700/30">';
      result.matches.forEach(function (match) {
        var matchId = 'mm-' + Math.random().toString(36).slice(2, 8);
        html += '<li class="px-3 py-2" id="' + matchId + '">';
        html += '<div class="flex items-center justify-between gap-2">';
        html += '<span class="text-xs font-mono text-neutral-600 dark:text-neutral-300 truncate">' + escapeHtml(match.path) + '</span>';
        html += '<div class="flex items-center gap-1.5 shrink-0">';
        if (match.size) html += '<span class="text-xs text-neutral-400">' + formatBytes(match.size) + '</span>';
        if (match.hash && vtEnabled) {
          html += '<button type="button" onclick="checkVirusTotal(\'' + escapeHtml(match.hash) + '\',\'' + matchId + '\')" class="vt-btn text-xs px-1.5 py-0.5 rounded border border-neutral-300 dark:border-neutral-600 text-neutral-500 active:bg-neutral-100 dark:active:bg-neutral-700">VT</button>';
        }
        html += '</div></div>';
        html += '<div class="vt-result-' + matchId + ' mt-1 hidden"></div>';
        html += '</li>';
      });
      html += '</ul></div>';
    });
    html += '</div>';
    bodyEl.innerHTML = html;
  }

  // ── Utilities ──────────────────────────────────────────────────────────────

  function formatBytes(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
    if (bytes < 1073741824) return (bytes / 1048576).toFixed(1) + ' MB';
    return (bytes / 1073741824).toFixed(1) + ' GB';
  }

  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // Expose for inline onclick
  window.openRadarScanModal = openRadarScanModal;
  window.closeRadarScanModal = closeRadarScanModal;
  window.resetRadarToPickerPhase = resetRadarToPickerPhase;
  window.setScanMode = setScanMode;
  window.runRadarScan = runRadarScan;
  window.runVtFileScan = runVtFileScan;
  window.checkVirusTotal = checkVirusTotal;
  window.bulkRadarScan = bulkRadarScan;
  window.bulkDelete = bulkDelete;
  window.confirmDelete = confirmDelete;

})();
</script>

<%- include('../../components/footer') %>
