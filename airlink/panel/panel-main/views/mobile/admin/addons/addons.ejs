<%- include('../../components/header', { title: 'Addons' }) %>
<%- include('../../components/toast') %>
<%- include('../../components/loadingPopup') %>

<style>
  .a-card {
    background: white;
    border: 1px solid #e5e5e5;
    border-radius: 14px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 16px;
    min-width: 0;
    transition: border-color 0.15s;
  }
  .dark .a-card { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.06); }
  .a-card:hover { border-color: #d4d4d4; }
  .dark .a-card:hover { border-color: rgba(255,255,255,0.1); }

  .a-icon {
    width: 34px; height: 34px; min-width: 34px;
    border-radius: 9px;
    background: #f5f5f5;
    border: 1px solid #e5e5e5;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; flex-shrink: 0;
  }
  .dark .a-icon { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.08); }
  .a-icon svg { width: 16px; height: 16px; }

  .a-badge {
    font-size: 10px; font-weight: 500; line-height: 1;
    padding: 3px 7px; border-radius: 99px; white-space: nowrap; flex-shrink: 0;
  }
  .a-badge-enabled  { background: rgba(34,197,94,0.1);  color: #15803d; }
  .dark .a-badge-enabled  { background: rgba(34,197,94,0.12); color: #4ade80; }
  .a-badge-disabled { background: #f5f5f5; color: #737373; }
  .dark .a-badge-disabled { background: rgba(255,255,255,0.06); color: #525252; }
  .a-badge-notenabled { background: rgba(245,158,11,0.1); color: #b45309; }
  .dark .a-badge-notenabled { background: rgba(245,158,11,0.12); color: #fbbf24; }

  .a-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  @media (max-width: 1023px) { .a-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 639px)  { .a-grid { grid-template-columns: 1fr; } }

  .toggle-btn {
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 8px; padding: 5px 12px;
    font-size: 11px; font-weight: 500; cursor: pointer;
    transition: background 0.12s, color 0.12s; border: 1px solid transparent;
    white-space: nowrap;
  }
  .toggle-btn-enable {
    background: #f5f5f5; border-color: #e5e5e5; color: #525252;
  }
  .dark .toggle-btn-enable { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.08); color: #737373; }
  .toggle-btn-enable:hover { background: #ebebeb; color: #171717; }
  .dark .toggle-btn-enable:hover { background: rgba(255,255,255,0.09); color: #d4d4d4; }
  .toggle-btn-disable {
    background: rgba(239,68,68,0.06); border-color: rgba(239,68,68,0.15); color: #ef4444;
  }
  .toggle-btn-disable:hover { background: rgba(239,68,68,0.12); }

  .uninstall-btn {
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 8px; padding: 5px 10px;
    font-size: 11px; font-weight: 500; cursor: pointer;
    transition: background 0.12s, color 0.12s; border: 1px solid transparent;
    white-space: nowrap;
    background: rgba(239,68,68,0.06); border-color: rgba(239,68,68,0.12); color: #ef4444;
  }
  .uninstall-btn:hover { background: rgba(239,68,68,0.14); }
</style>

<main id="page-content" class="">
  <%- include('../../components/template') %>

  <div class="px-4 py-5">
<div class="px-4 pt-6 pb-0 flex items-center justify-between">
        <div>
          <h1 class="text-base font-medium text-neutral-800 dark:text-white">Addons</h1>
          <p class="mt-0.5 text-sm text-neutral-500">Manage installed addons and browse the store</p>
        </div>
        <button id="reloadBtn" class="inline-flex items-center gap-2 rounded-xl bg-neutral-100 dark:bg-neutral-800/80 hover:bg-neutral-200 dark:hover:bg-neutral-700/80 border border-neutral-200 dark:border-neutral-700/50 text-neutral-600 dark:text-neutral-300 px-3 py-2 text-sm font-medium transition">
          <%- icon('refresh-cw', { size: 14, class: 'shrink-0' }) %>
          Reload
        </button>
      </div>

      <div class="px-4 mt-5">
        <!-- Tabs -->
        <div class="flex border-b border-neutral-200 dark:border-neutral-800 mb-5">
          <a href="/admin/addons" class="px-4 py-2.5 text-sm font-medium text-neutral-800 dark:text-white border-b-2 border-neutral-800 dark:border-white -mb-px">
            Installed <span class="ml-1.5 text-xs text-neutral-400"><%= addons ? addons.length : 0 %></span>
          </a>
          <a href="/admin/addons/store" class="px-4 py-2.5 text-sm font-medium text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 border-b-2 border-transparent -mb-px transition">Store</a>
        </div>

        <% if (addons && addons.length > 0) { %>
        <div class="mb-4">
          <input id="addonSearchInput" type="text" placeholder="Filter addons…"
            class="w-full rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 px-3 py-2 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-500 focus:outline-none focus:border-neutral-400 dark:focus:border-neutral-600 transition">
        </div>
        <% } %>

        <!-- Migration warning -->
        <% if (!addonTableExists) { %>
          <div class="flex gap-3 rounded-xl p-4 mb-6 bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/20">
            <%- icon('triangle-alert', { size: 16, class: 'text-amber-400 shrink-0' }) %>
            <div>
              <p class="text-sm font-medium text-amber-400">Database migration required</p>
              <p class="mt-1 text-xs text-amber-400/70">Run <code class="px-1 py-0.5 rounded font-mono" style="background:rgba(245,158,11,0.1);">npm run migrate:dev</code> then restart the panel.</p>
            </div>
          </div>
        <% } %>

        <!-- Addon grid -->
        <% if (addons && addons.length > 0) { %>
          <div class="a-grid" id="addonGrid">
            <% let aIdx = 0; addons.forEach(function(addon) { %>
              <div class="a-card grid-item-animate"
                style="--i:<%= aIdx++ %>"
                data-slug="<%= addon.slug %>"
                data-search="<%= (addon.name + ' ' + (addon.description||'') + ' ' + (addon.author||'')).toLowerCase() %>">

                <!-- Top row: icon + badge -->
                <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;">
                  <div class="a-icon">
                    <%- icon('box', { size: 16, class: 'text-neutral-600 shrink-0' }) %>
                  </div>
                  <span class="status-badge a-badge <%= addon.hasDisabledPh ? 'a-badge-notenabled' : (addon.enabled ? 'a-badge-enabled' : 'a-badge-disabled') %>">
                    <%= addon.hasDisabledPh ? 'Not enabled' : (addon.enabled ? 'Enabled' : 'Disabled') %>
                  </span>
                </div>

                <!-- Name + meta -->
                <div style="display:flex;flex-direction:column;gap:4px;min-width:0;">
                  <p class="text-sm font-semibold text-neutral-800 dark:text-neutral-100 truncate"><%= addon.name %></p>
                  <p class="text-xs text-neutral-400 dark:text-neutral-500">
                    v<%= addon.version %><% if (addon.author) { %> · <%= addon.author %><% } %>
                  </p>
                  <% if (addon.description) { %>
                    <p class="text-xs text-neutral-500 dark:text-neutral-500 leading-relaxed line-clamp-2 mt-0.5"><%= addon.description %></p>
                  <% } %>
                </div>

                <!-- Action -->
                <div style="margin-top:auto;display:flex;flex-direction:column;gap:6px;">
                  <button
                    onclick="toggleAddon('<%= addon.slug %>', <%= !addon.enabled %>)"
                    class="toggle-btn w-full <%= addon.enabled ? 'toggle-btn-disable' : 'toggle-btn-enable' %>">
                    <%= addon.enabled ? 'Disable' : 'Enable' %>
                  </button>
                  <button
                    onclick="confirmUninstall('<%= addon.slug %>', '<%= addon.name %>')"
                    class="uninstall-btn w-full">
                    Uninstall
                  </button>
                </div>

              </div>
            <% }); %>
          </div>
          <div id="addonNoResults" class="hidden py-12 text-center">
            <p class="text-sm text-neutral-500">No addons match your search.</p>
          </div>

        <% } else { %>
          <!-- Empty state -->
          <div class="py-20 text-center">
            <%- icon('box', { size: 16, class: 'text-neutral-700 shrink-0' }) %>
            <p class="text-sm font-medium text-neutral-500">
              <% if (addonTableExists) { %>No addons installed<% } else { %>Migration required<% } %>
            </p>
            <p class="mt-2 text-xs text-neutral-400 dark:text-neutral-600 max-w-xs mx-auto">
              <% if (addonTableExists) { %>
                Browse the store or drop addon folders into <code class="px-1 py-0.5 rounded font-mono bg-neutral-100 dark:bg-neutral-800 text-neutral-500">storage/addons</code>
              <% } else { %>
                Run database migrations to enable the addon system
              <% } %>
            </p>
            <% if (addonTableExists) { %>
              <a href="/admin/addons/store" class="mt-5 inline-flex items-center gap-2 rounded-xl bg-neutral-100 dark:bg-neutral-800/80 hover:bg-neutral-200 dark:hover:bg-neutral-700/80 border border-neutral-200 dark:border-neutral-700/50 text-neutral-600 dark:text-neutral-300 px-4 py-2 text-sm font-medium transition">
                Browse Store
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</main>

<script nonce="<%- nonce %>">
(function () {
  function toggleAddon(slug, enable) {
    showLoadingPopup('Updating addon...', 'Applying changes...');
    fetch(`/admin/addons/toggle/${slug}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ enabled: enable.toString() }),
    })
    .then(r => r.json())
    .then(data => {
      hideLoadingPopup();
      if (data.success) {
        showToast('Addon updated', 'success');
        updateCard(slug, enable);
      } else {
        showToast(data.message || 'Failed to update addon', 'error');
      }
    })
    .catch(() => { hideLoadingPopup(); showToast('Something went wrong.', 'error'); });
  }

  function updateCard(slug, enabled) {
    const card = document.querySelector(`[data-slug="${slug}"]`);
    if (!card) return;

    const badge = card.querySelector('.status-badge');
    if (badge) {
      badge.className = `status-badge a-badge ${enabled ? 'a-badge-enabled' : 'a-badge-disabled'}`;
      badge.textContent = enabled ? 'Enabled' : 'Disabled';
    }

    const btn = card.querySelector('.toggle-btn');
    if (btn) {
      btn.className = `toggle-btn w-full ${enabled ? 'toggle-btn-disable' : 'toggle-btn-enable'}`;
      btn.textContent = enabled ? 'Disable' : 'Enable';
      btn.onclick = () => toggleAddon(slug, !enabled);
    }
  }

  window.toggleAddon = toggleAddon;

  function confirmUninstall(slug, name) {
    window.modal.confirm({
      title: 'Uninstall Addon',
      body: `Uninstall "${name}"? This will delete the addon files and cannot be undone.`,
      danger: true,
      confirmLabel: 'Uninstall',
      onConfirm: () => uninstallAddon(slug)
    });
  }

  function uninstallAddon(slug) {
    showLoadingPopup('Uninstalling addon...', 'Removing files...');
    fetch('/admin/addons/store/uninstall', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug }),
    })
    .then(r => r.json())
    .then(data => {
      hideLoadingPopup();
      if (data.success) {
        showToast('Addon uninstalled', 'success');
        const card = document.querySelector(`[data-slug="${slug}"]`);
        if (card) card.remove();
      } else {
        showToast(data.message || 'Failed to uninstall addon', 'error');
      }
    })
    .catch(() => { hideLoadingPopup(); showToast('Something went wrong.', 'error'); });
  }

  window.confirmUninstall = confirmUninstall;

  document.getElementById('reloadBtn').addEventListener('click', () => {
    showLoadingPopup('Reloading addons...', 'Please wait...');
    fetch('/admin/addons/reload', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
      .then(r => r.json())
      .then(data => {
        hideLoadingPopup();
        showToast(data.message || (data.success ? 'Reloaded' : 'Failed'), data.success ? 'success' : 'error');
      })
    .catch(() => { hideLoadingPopup(); showToast('Something went wrong.', 'error'); });
  });

  const addonSearch = document.getElementById('addonSearchInput');
  if (addonSearch) {
    addonSearch.addEventListener('input', function() {
      const q = this.value.toLowerCase().trim();
      let visible = 0;
      document.querySelectorAll('.a-card[data-search]').forEach(card => {
        const match = !q || card.dataset.search.includes(q);
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });
      const noResults = document.getElementById('addonNoResults');
      if (noResults) noResults.classList.toggle('hidden', visible > 0 || !q);
    });
  }
})();
</script>

<%- include('../../components/footer') %>
