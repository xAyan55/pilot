<%- include('../../components/header', { title: 'Analytics' }) %>

<main id="page-content" class="">
  <%- include('../../components/template') %>
  <%- include('../../components/toast') %>

  <div class="px-4 pt-5 pb-24">

    <div class="flex items-center justify-between mb-5">
      <div>
        <h1 class="text-base font-medium text-neutral-800 dark:text-white">Analytics</h1>
        <p class="text-xs text-neutral-500 mt-0.5">Live data from the panel and daemons.</p>
      </div>
      <button id="refreshBtn" type="button"
        class="flex items-center gap-1.5 rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-2 text-xs font-medium text-neutral-700 dark:text-neutral-300 transition shrink-0">
        <%- icon('refresh-cw', { size: 14, class: 'shrink-0' }) %>
        Refresh
      </button>
    </div>

    <!-- Scrollable tabs -->
    <div class="flex gap-0.5 border-b border-neutral-200 dark:border-neutral-700/40 mb-5 -mx-4 px-4 overflow-x-auto">
      <button type="button" data-tab="servers"  class="tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 whitespace-nowrap">Servers</button>
      <button type="button" data-tab="nodes"    class="tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 whitespace-nowrap">Nodes</button>
      <button type="button" data-tab="activity" class="tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2 whitespace-nowrap">Activity</button>
    </div>

    <!-- Loading -->
    <div id="loading-state" class="flex items-center gap-3 py-8 text-neutral-400">
      <svg class="animate-spin w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <span class="text-sm">Loading analytics…</span>
    </div>

    <!-- SERVERS -->
    <div data-tab-panel="servers" class="tab-panel hidden space-y-4">
      <div class="grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3.5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Total</p>
          <p class="text-xl font-semibold text-neutral-800 dark:text-white" id="sv-total">—</p>
          <p class="text-xs mt-1" id="sv-suspended-label"></p>
        </div>
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3.5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">RAM alloc</p>
          <p class="text-xl font-semibold text-neutral-800 dark:text-white" id="sv-ram">—</p>
        </div>
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3.5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">CPU alloc</p>
          <p class="text-xl font-semibold text-neutral-800 dark:text-white" id="sv-cpu">—</p>
        </div>
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3.5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Disk alloc</p>
          <p class="text-xl font-semibold text-neutral-800 dark:text-white" id="sv-storage">—</p>
        </div>
      </div>
      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
        <p class="text-sm font-medium text-neutral-800 dark:text-white mb-3">Images in use</p>
        <div id="sv-images" class="space-y-2.5"></div>
      </div>
      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 overflow-hidden">
        <div class="px-4 py-3 border-b border-neutral-200 dark:border-white/5">
          <p class="text-sm font-medium text-neutral-800 dark:text-white">Highest allocated</p>
        </div>
        <div id="sv-heavy" class="divide-y divide-neutral-100 dark:divide-white/5"></div>
      </div>
    </div>

    <!-- NODES -->
    <div data-tab-panel="nodes" class="tab-panel hidden space-y-4">
      <div class="grid grid-cols-3 gap-3">
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3.5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Nodes</p>
          <p class="text-xl font-semibold text-neutral-800 dark:text-white" id="nd-total">—</p>
        </div>
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3.5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Online</p>
          <p class="text-xl font-semibold text-emerald-600 dark:text-emerald-400" id="nd-online">—</p>
        </div>
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-3 py-3.5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Offline</p>
          <p class="text-xl font-semibold text-red-500 dark:text-red-400" id="nd-offline">—</p>
        </div>
      </div>
      <div id="nd-list" class="space-y-3"></div>
    </div>

    <!-- ACTIVITY -->
    <div data-tab-panel="activity" class="tab-panel hidden space-y-4">
      <div class="grid grid-cols-2 gap-3">
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3.5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Users</p>
          <p class="text-xl font-semibold text-neutral-800 dark:text-white" id="ac-users">—</p>
          <p class="text-xs text-neutral-500 mt-1" id="ac-admins-label"></p>
        </div>
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3.5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Images</p>
          <p class="text-xl font-semibold text-neutral-800 dark:text-white" id="ac-images">—</p>
        </div>
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3.5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Logins (30d)</p>
          <p class="text-xl font-semibold text-neutral-800 dark:text-white" id="ac-logins">—</p>
        </div>
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3.5">
          <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1">Avg/day</p>
          <p class="text-xl font-semibold text-neutral-800 dark:text-white" id="ac-avg">—</p>
        </div>
      </div>
      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
        <p class="text-sm font-medium text-neutral-800 dark:text-white mb-3">Login activity — 30 days</p>
        <div class="relative h-40">
          <canvas id="loginChart"></canvas>
        </div>
      </div>
      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 overflow-hidden">
        <div class="px-4 py-3 border-b border-neutral-200 dark:border-white/5">
          <p class="text-sm font-medium text-neutral-800 dark:text-white">Recent logins</p>
        </div>
        <div id="ac-logins-list" class="divide-y divide-neutral-100 dark:divide-white/5"></div>
      </div>
    </div>

  </div>
</main>

<script nonce="<%- nonce %>" src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>
<script nonce="<%- nonce %>">
(function () {
  const tabBtns   = document.querySelectorAll('.tab-btn');
  const tabPanels = document.querySelectorAll('.tab-panel');
  let loginChart  = null;

  function activateTab(id) {
    tabBtns.forEach(btn => {
      const on = btn.dataset.tab === id;
      btn.classList.toggle('border-neutral-800', on);
      btn.classList.toggle('dark:border-white', on);
      btn.classList.toggle('text-neutral-800', on);
      btn.classList.toggle('dark:text-white', on);
      btn.classList.toggle('border-transparent', !on);
      btn.classList.toggle('text-neutral-500', !on);
      btn.classList.toggle('dark:text-neutral-400', !on);
    });
    tabPanels.forEach(p => p.classList.toggle('hidden', p.dataset.tabPanel !== id));
  }

  tabBtns.forEach(btn => btn.addEventListener('click', () => activateTab(btn.dataset.tab)));
  activateTab('servers');

  const isDark    = () => document.documentElement.classList.contains('dark');
  const textColor = () => isDark() ? 'rgba(255,255,255,0.4)' : 'rgba(0,0,0,0.35)';
  const gridColor = () => isDark() ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';
  const fmt       = n  => n.toLocaleString();

  function bar(label, value, max) {
    const pct   = max > 0 ? Math.min(100, Math.round((value / max) * 100)) : 0;
    const color = pct >= 90 ? '#ef4444' : pct >= 70 ? '#f97316' : '#3b82f6';
    return `<div><div class="flex justify-between text-xs text-neutral-600 dark:text-neutral-400 mb-1.5"><span class="truncate max-w-[55%] font-medium">${label}</span><span class="shrink-0 tabular-nums">${fmt(value)} (${max > 0 ? pct+'%' : '—'})</span></div><div class="h-1.5 rounded-full bg-neutral-200 dark:bg-white/5"><div class="h-1.5 rounded-full" style="width:${max>0?pct:0}%;background:${color}"></div></div></div>`;
  }

  function render(data) {
    const s = data.servers;
    document.getElementById('sv-total').textContent   = fmt(s.total);
    document.getElementById('sv-ram').textContent     = s.totalRamMb >= 1024 ? (s.totalRamMb/1024).toFixed(1)+' GB' : s.totalRamMb+' MB';
    document.getElementById('sv-cpu').textContent     = s.totalCpuPct + '%';
    document.getElementById('sv-storage').textContent = s.totalStorageGb + ' GB';
    const sl = document.getElementById('sv-suspended-label');
    sl.textContent = s.suspended > 0 ? s.suspended + ' suspended' : 'none suspended';
    sl.className   = 'text-xs mt-1 ' + (s.suspended > 0 ? 'text-amber-600 dark:text-amber-400' : 'text-neutral-500');

    const imgEl = document.getElementById('sv-images');
    imgEl.innerHTML = s.topImages.length
      ? s.topImages.map(i => bar(i.name||'Unknown', i.count, s.topImages[0].count)).join('')
      : '<p class="text-xs text-neutral-400">No servers yet.</p>';

    document.getElementById('sv-heavy').innerHTML = s.topServers.map(sv =>
      `<div class="flex items-center gap-3 px-4 py-3"><div class="min-w-0 flex-1"><p class="text-sm text-neutral-700 dark:text-neutral-300 truncate font-medium">${sv.name}</p><p class="text-xs text-neutral-400">${sv.owner}</p></div><div class="text-xs text-neutral-500 tabular-nums shrink-0">${fmt(sv.memory)} MB · ${sv.cpu}%</div></div>`
    ).join('') || '<p class="px-4 py-4 text-sm text-neutral-400">No servers.</p>';

    const nodes = data.nodes;
    document.getElementById('nd-total').textContent  = fmt(nodes.length);
    document.getElementById('nd-online').textContent  = fmt(nodes.filter(n=>n.online).length);
    document.getElementById('nd-offline').textContent = fmt(nodes.filter(n=>!n.online).length);
    document.getElementById('nd-list').innerHTML = nodes.map(n =>
      `<div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2.5 min-w-0">
            <span class="w-2 h-2 rounded-full shrink-0 ${n.online?'bg-emerald-500':'bg-red-500'}"></span>
            <div class="min-w-0"><p class="text-sm font-medium text-neutral-800 dark:text-white truncate">${n.name}</p><p class="text-xs font-mono text-neutral-400">${n.address}:${n.port}</p></div>
          </div>
          <span class="text-xs px-2 py-0.5 rounded-md font-medium shrink-0 ml-2 ${n.online?'bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20':'bg-red-50 dark:bg-red-500/10 text-red-700 dark:text-red-400 border border-red-200 dark:border-red-500/20'}">${n.online?'Online':'Offline'}</span>
        </div>
        <div class="flex gap-4 mt-3 pt-3 border-t border-neutral-200 dark:border-white/5 text-xs text-neutral-500">
          <span>${n.serverCount} server${n.serverCount!==1?'s':''}</span>
          ${n.ram>0?`<span>${n.ram>=1024?(n.ram/1024).toFixed(1)+' GB':n.ram+' MB'} RAM</span>`:''}
          ${n.online&&n.versionRelease?`<span class="font-mono">${n.versionRelease}</span>`:''}
        </div>
      </div>`
    ).join('') || '<p class="text-sm text-neutral-400">No nodes.</p>';

    const a = data.activity;
    const totalLogins = Object.values(a.loginsByDay).reduce((s,v)=>s+v,0);
    document.getElementById('ac-users').textContent  = fmt(a.totalUsers);
    document.getElementById('ac-images').textContent = fmt(a.totalImages);
    document.getElementById('ac-logins').textContent = fmt(totalLogins);
    document.getElementById('ac-avg').textContent    = fmt(Math.round(totalLogins/30));
    document.getElementById('ac-admins-label').textContent = a.adminCount + ' admin' + (a.adminCount!==1?'s':'');

    if (loginChart) loginChart.destroy();
    loginChart = new Chart(document.getElementById('loginChart'), {
      type: 'bar',
      data: { labels: Object.keys(a.loginsByDay).map(d=>d.slice(5)), datasets: [{ data: Object.values(a.loginsByDay), backgroundColor: 'rgba(59,130,246,0.5)', borderColor: '#3b82f6', borderWidth: 1, borderRadius: 3 }] },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { grid: { color: gridColor() }, ticks: { color: textColor(), maxTicksLimit: 7 } }, y: { grid: { color: gridColor() }, ticks: { color: textColor(), stepSize: 1 }, min: 0 } } }
    });

    document.getElementById('ac-logins-list').innerHTML = (a.recentLogins||[]).map(l =>
      `<div class="flex items-center gap-3 px-4 py-3"><span class="text-xs font-mono text-neutral-500 shrink-0">#${l.userId}</span><span class="text-xs font-mono text-neutral-600 dark:text-neutral-400 flex-1">${l.ipAddress||'Unknown'}</span><span class="text-xs text-neutral-400">${new Date(l.timestamp).toLocaleString()}</span></div>`
    ).join('') || '<p class="px-4 py-4 text-sm text-neutral-400">No login history.</p>';
  }

  async function load() {
    const icon    = document.getElementById('refreshIcon');
    const loading = document.getElementById('loading-state');
    icon.classList.add('animate-spin');
    loading.classList.remove('hidden');
    tabPanels.forEach(p => p.classList.add('hidden'));

    try {
      const res = await fetch('/api/admin/analytics/summary');
      if (!res.ok) throw new Error();
      const data = await res.json();
      loading.classList.add('hidden');
      activateTab('servers');
      render(data);
      showToast('Analytics refreshed. Fresh data.', 'success');
    } catch {
      loading.classList.add('hidden');
      showToast('Failed to load analytics', 'error');
    } finally {
      icon.classList.remove('animate-spin');
    }
  }

  document.getElementById('refreshBtn').addEventListener('click', load);
  load();
})();
</script>

<%- include('../../components/footer') %>
