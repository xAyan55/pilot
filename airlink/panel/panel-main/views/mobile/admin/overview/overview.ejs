<%- include('../../components/header', { title: req.translations.adminOverviewTitle || 'Overview' }) %>

<main id="page-content" class="">
  <%- include('../../components/template') %>
  <%- include('../../components/toast') %>

  <div class="px-4 py-5">

    <div class="mb-5">
      <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.adminOverviewTitle %></h1>
      <p class="text-xs text-neutral-500 mt-0.5"><%= req.translations.adminOverviewText %></p>
    </div>

    <!-- Stats grid -->
    <div class="grid grid-cols-2 gap-3 mb-5">
      <div class="grid-item-animate rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3" style="--i:0">
        <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1"><%= req.translations.users || 'Users' %></p>
        <p class="text-2xl font-semibold text-neutral-800 dark:text-white"><%= userCount %></p>
        <p class="text-xs text-neutral-500 mt-1"><%= req.translations.totalRegisteredUsers || 'Registered' %></p>
      </div>
      <div class="grid-item-animate rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3" style="--i:1">
        <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1"><%= req.translations.instances || 'Servers' %></p>
        <p class="text-2xl font-semibold text-neutral-800 dark:text-white"><%= instanceCount %></p>
        <p class="text-xs text-neutral-500 mt-1">Active instances</p>
      </div>
      <div class="grid-item-animate rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3" style="--i:2">
        <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1"><%= req.translations.nodes || 'Nodes' %></p>
        <p class="text-2xl font-semibold text-neutral-800 dark:text-white"><%= nodeCount %></p>
        <p class="text-xs text-neutral-500 mt-1">Connected nodes</p>
      </div>
      <div class="grid-item-animate rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-3" style="--i:3">
        <p class="text-[10px] text-neutral-500 uppercase tracking-wider mb-1"><%= req.translations.images || 'Images' %></p>
        <p class="text-2xl font-semibold text-neutral-800 dark:text-white"><%= imageCount %></p>
        <p class="text-xs text-neutral-500 mt-1">Available images</p>
      </div>
    </div>

    <!-- Panel info card -->
    <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4 mb-4">
      <div class="flex items-center gap-3 mb-4">
        <img src="/assets/airlink_logo.png" class="h-10 w-10 rounded-xl shrink-0" alt="Airlink">
        <div>
          <p class="text-sm font-medium text-neutral-800 dark:text-white">Airlink Panel</p>
          <div class="flex items-center gap-2 mt-1">
            <span class="text-[10px] font-mono px-2 py-0.5 rounded-md bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 text-neutral-600 dark:text-neutral-400">v<span class="current-version"></span></span>
            <span class="text-[10px] text-neutral-500"><%= process.env.NODE_ENV %></span>
          </div>
        </div>
      </div>

      <!-- Update status -->
      <div id="updateStatus" class="rounded-lg bg-neutral-100 dark:bg-neutral-800/50 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2.5 mb-3 hidden">
        <p id="updateStatusText" class="text-xs text-neutral-600 dark:text-neutral-300"></p>
      </div>

      <div id="updateInfo" class="hidden mb-3">
        <p id="updateInfoText" class="text-xs text-neutral-500"></p>
      </div>

      <!-- API latency -->
      <div class="mb-3">
        <div class="flex justify-between items-center mb-1.5">
          <p class="text-xs text-neutral-500">API response time</p>
          <span id="apiLatency" class="text-xs font-mono text-neutral-600 dark:text-neutral-400">-- ms</span>
        </div>
        <div class="h-1.5 w-full bg-neutral-200 dark:bg-neutral-700 rounded-full overflow-hidden">
          <div id="latencyBar" class="h-full bg-neutral-400 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
      </div>

      <!-- Action buttons -->
      <div class="flex gap-2">
        <button id="checkUpdateBtn" type="button" class="flex-1 rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-200 dark:hover:bg-neutral-700 transition">
          Check Updates
        </button>
        <button id="performUpdateBtn" type="button" class="hidden flex-1 rounded-xl bg-emerald-600 px-3 py-2 text-xs font-medium text-white hover:bg-emerald-500 transition">
          Install Update
        </button>
      </div>
    </div>

    <!-- Community links -->
    <div class="grid grid-cols-2 gap-3">
      <a href="https://discord.gg/BybfXms7JZ" target="_blank" rel="noopener noreferrer" class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-3 flex items-center gap-2.5 hover:bg-neutral-100 dark:hover:bg-neutral-700/50 transition">
        <div class="w-8 h-8 rounded-lg bg-[#5865F2]/10 flex items-center justify-center shrink-0">
          <svg class="w-4 h-4 text-[#5865F2]" viewBox="0 0 127.14 96.36" fill="currentColor"><path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/></svg>
        </div>
        <div>
          <p class="text-xs font-medium text-neutral-800 dark:text-white">Discord</p>
          <p class="text-[10px] text-neutral-500">Community</p>
        </div>
      </a>

      <a href="https://airlinklabs.xyz/" target="_blank" rel="noopener noreferrer" class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-3 flex items-center gap-2.5 hover:bg-neutral-100 dark:hover:bg-neutral-700/50 transition">
        <div class="w-8 h-8 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-neutral-500">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-neutral-800 dark:text-white">Docs</p>
          <p class="text-[10px] text-neutral-500">Documentation</p>
        </div>
      </a>

      <a href="https://github.com/airlinklabs" target="_blank" rel="noopener noreferrer" class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-3 flex items-center gap-2.5 hover:bg-neutral-100 dark:hover:bg-neutral-700/50 transition">
        <div class="w-8 h-8 rounded-lg bg-neutral-100 dark:bg-neutral-800 flex items-center justify-center shrink-0">
          <svg class="w-4 h-4 text-neutral-600 dark:text-neutral-400" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </div>
        <div>
          <p class="text-xs font-medium text-neutral-800 dark:text-white">GitHub</p>
          <p class="text-[10px] text-neutral-500">Source code</p>
        </div>
      </a>

      <a href="https://ko-fi.com/airlinklabs" target="_blank" rel="noopener noreferrer" class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-3 flex items-center gap-2.5 hover:bg-neutral-100 dark:hover:bg-neutral-700/50 transition">
        <div class="w-8 h-8 rounded-lg bg-red-50 dark:bg-red-900/20 flex items-center justify-center shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-red-500">
            <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-neutral-800 dark:text-white">Support</p>
          <p class="text-[10px] text-neutral-500">Donate</p>
        </div>
      </a>
    </div>

  </div>
</main>

<script nonce="<%- nonce %>">
  const currentVersion = '<%= airlinkVersion %>';
  document.querySelectorAll('.current-version').forEach(el => { el.textContent = currentVersion; });

  document.getElementById('checkUpdateBtn').addEventListener('click', async () => {
    const btn = document.getElementById('checkUpdateBtn');
    const statusDiv = document.getElementById('updateStatus');
    const statusText = document.getElementById('updateStatusText');
    btn.textContent = 'Checking...';
    btn.disabled = true;

    try {
      const response = await fetch('/admin/check-update');
      const data = await response.json();
      const updateBtn = document.getElementById('performUpdateBtn');

      if (data.hasUpdate) {
        statusText.textContent = `Update available: v${data.latestVersion}`;
        statusText.className = 'text-xs text-amber-600 dark:text-amber-400';
        updateBtn.classList.remove('hidden');
        updateBtn.classList.add('flex');
      } else {
        statusText.textContent = '<%= req.translations.runningLatestVersion || "You are running the latest version." %>';
        statusText.className = 'text-xs text-emerald-600 dark:text-emerald-400';
        updateBtn.classList.add('hidden');
        updateBtn.classList.remove('flex');
      }
      fadeInEl(statusDiv);
    } catch (err) {
      statusText.textContent = 'Failed to check for updates.';
      statusText.className = 'text-xs text-red-500';
      fadeInEl(statusDiv);
    } finally {
      btn.textContent = 'Check Updates';
      btn.disabled = false;
    }
  });

  document.getElementById('performUpdateBtn').addEventListener('click', async () => {
    window.modal.confirm({
      title: 'Install Update',
      body: 'The panel will perform the update and restart the server.',
      confirmLabel: 'Install',
      danger: false,
      onConfirm: async () => {
        const statusText = document.getElementById('updateStatusText');
        statusText.textContent = 'Installing...';
        statusText.className = 'text-xs text-blue-500';
        try {
          const response = await fetch('/admin/perform-update', { method: 'POST' });
          const data = await response.json();
          showToast(data.message || 'Update started. Restarting...', 'success');
          statusText.textContent = 'Restarting...';
          statusText.className = 'text-xs text-emerald-600 dark:text-emerald-400';
          setTimeout(() => window.location.reload(), 5000);
        } catch (err) {
          statusText.textContent = 'Update failed.';
          statusText.className = 'text-xs text-red-500';
          showToast('Update failed. Check the logs.', 'error');
        }
      }
    });
  });

  function fadeInEl(el) {
    el.classList.remove('hidden');
    el.style.opacity = '0';
    el.style.transform = 'translateY(4px)';
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        el.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
        setTimeout(function() { el.style.transition = ''; el.style.opacity = ''; el.style.transform = ''; }, 220);
      });
    });
  }

  async function measureApiLatency() {
    try {
      const start = performance.now();
      const response = await fetch('/api/v1/ping');
      const latency = Math.round(performance.now() - start);
      if (response.ok) {
        document.getElementById('apiLatency').textContent = `${latency} ms`;
        const pct = Math.min((latency / 500) * 100, 100);
        const bar = document.getElementById('latencyBar');
        bar.style.width = `${pct}%`;
        bar.className = 'h-full rounded-full transition-all duration-300 ' + (latency < 100 ? 'bg-emerald-500' : latency < 300 ? 'bg-amber-500' : 'bg-red-500');
      }
    } catch {}
  }

  measureApiLatency();
  setInterval(measureApiLatency, 30000);
</script>

<%- include('../../components/footer') %>
