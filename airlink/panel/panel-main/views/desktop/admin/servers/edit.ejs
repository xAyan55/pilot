.cs-option.disabled { opacity: 0.35; cursor: default; pointer-events: none; }

@keyframes al-modal-in  { from { opacity:0; transform:scale(0.96) translateY(6px); } to { opacity:1; transform:scale(1) translateY(0); } }
@keyframes al-modal-out { from { opacity:1; transform:scale(1) translateY(0); } to { opacity:0; transform:scale(0.96) translateY(6px); } }
