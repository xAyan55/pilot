.cs-trigger:hover { background: var(--theme-bg-hover, rgba(180,180,180,0.18)); }
.dark .cs-trigger:hover { background: var(--theme-bg-hover, rgba(255,255,255,0.05)); }
.cs-trigger.open { border-color: var(--theme-border, rgba(0,0,0,0.15)); }
