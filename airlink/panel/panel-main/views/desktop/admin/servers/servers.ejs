<%- include('../../components/header', { title: 'Servers' }) %>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <div class="w-60 h-full">
      <%- include('../../components/template') %>
    </div>

    <div id="page-content" class="flex-1 p-6 overflow-y-auto pt-16">

      <!-- Page header -->
      <div class="sm:flex sm:items-center px-8 pt-4">
        <div class="sm:flex-auto">
          <h1 class="text-base font-medium leading-6 text-neutral-800 dark:text-white"><%= req.translations.adminServersTitle %></h1>
          <p class="mt-1 tracking-tight text-sm text-neutral-500"><%= req.translations.adminServersText %></p>
        </div>
        <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
          <button onclick="location.href='/admin/servers/create'" type="button"
            class="border border-neutral-800/20 dark:border-white/10 block rounded-xl bg-white dark:bg-white/5 hover:bg-neutral-100 dark:hover:bg-white/10 text-neutral-800 dark:text-white px-3 py-2 text-center text-sm font-medium shadow-sm transition">
            <%= req.translations.createNewServer %>
          </button>
        </div>
      </div>

      <% if (req.query.err == "none") { %>
      <div class="mt-6 mx-8">
        <div class="rounded-xl bg-emerald-600/10 dark:bg-emerald-800/10 px-4 py-3 border border-emerald-200 dark:border-emerald-500/20 flex items-center gap-3">
          <%- icon('check', { size: 16, class: 'text-emerald-500 shrink-0' }) %>
          <p class="text-sm text-emerald-700 dark:text-emerald-400"><%= req.translations.actionCompleted %></p>
        </div>
      </div>
      <% } %>

      <!-- Sentinel — watched to know when toolbar scrolls off screen -->
      <div id="toolbarSentinel" class="h-px w-full mx-8" aria-hidden="true"></div>

      <!-- Bulk toolbar — grid-template-rows 0fr→1fr for smooth height animation -->
      <div id="bulkToolbarRow" class="no-anim" style="display:grid;grid-template-rows:0fr;transition:grid-template-rows 0.36s cubic-bezier(0.16,1,0.3,1)">
        <div style="min-height:0;overflow:hidden">
          <div id="bulkToolbarContent" class="mx-8 mt-4 pb-0.5" style="opacity:0;transition:opacity 0.28s ease">
            <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-neutral-50 dark:bg-neutral-800/60 border border-neutral-200 dark:border-neutral-700/40">
              <span class="selection-count text-sm font-medium text-neutral-600 dark:text-neutral-300 mr-1">0 selected</span>
              <div class="h-4 w-px bg-neutral-200 dark:bg-neutral-700 mx-1"></div>
              <button type="button" onclick="bulkRadarScan()"
                class="inline-flex items-center gap-1.5 rounded-lg bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-1.5 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors">
                <%- icon('radar', { size: 14, class: 'shrink-0' }) %>
                Radar Scan
              </button>
              <button type="button" onclick="bulkDelete()"
                class="inline-flex items-center gap-1.5 rounded-lg bg-red-600 hover:bg-red-500 border border-red-700/30 px-3 py-1.5 text-xs font-medium text-white transition-colors ml-auto">
                <%- icon('trash-2', { size: 14, class: 'shrink-0' }) %>
                Delete
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Floating pill — fixed below topbar when toolbar scrolls off screen -->
      <div id="floatingToolbar"
        style="position:fixed;top:72px;left:50%;transform:translateX(-50%) translateY(-10px);z-index:40;opacity:0;pointer-events:none;transition:opacity 0.22s ease,transform 0.22s cubic-bezier(0.16,1,0.3,1)">
        <div class="flex items-center gap-2 px-4 py-2.5 rounded-xl bg-white dark:bg-neutral-900 shadow-xl border border-neutral-200 dark:border-neutral-700/60">
          <span class="selection-count text-sm font-medium text-neutral-600 dark:text-neutral-300 mr-1">0 selected</span>
          <div class="h-4 w-px bg-neutral-200 dark:bg-neutral-700 mx-1"></div>
          <button type="button" onclick="bulkRadarScan()"
            class="inline-flex items-center gap-1.5 rounded-lg bg-neutral-50 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-1.5 text-xs font-medium text-neutral-700 dark:text-neutral-300 hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors">
            <%- icon('radar', { size: 14, class: 'shrink-0' }) %>
            Radar Scan
          </button>
          <button type="button" onclick="bulkDelete()"
            class="inline-flex items-center gap-1.5 rounded-lg bg-red-600 hover:bg-red-500 border border-red-700/30 px-3 py-1.5 text-xs font-medium text-white transition-colors ml-auto">
            <%- icon('trash-2', { size: 14, class: 'shrink-0' }) %>
            Delete
          </button>
        </div>
      </div>

      <!-- Server table -->
      <div class="overflow-x-auto shadow-sm rounded-xl m-8 border border-neutral-200 dark:border-neutral-800/40" id="serverTable">
        <table class="min-w-full divide-y divide-neutral-200 dark:divide-white/10">
          <thead class="bg-neutral-50 dark:bg-neutral-800/50">
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 sm:pl-6 w-10"></th>
              <th scope="col" class="py-3.5 pr-3 text-left text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.name %></th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.Owner %></th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.Node %></th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.connection %></th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white"><%= req.translations.Status %></th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100 dark:divide-white/5 bg-white dark:bg-neutral-800/20">
            <% let srvIdx = 0; servers.forEach(function(server) { %>
            <tr style="--i:<%= srvIdx++ %>" class="hover:bg-neutral-50 dark:hover:bg-white/[0.03] transition-colors cursor-pointer server-row" data-id="<%= server.id %>" data-uuid="<%= server.UUID %>">
              <td class="py-4 pl-4 pr-3 sm:pl-6 w-10">
                <input type="checkbox" class="server-checkbox rounded border-neutral-300 dark:border-neutral-600 text-neutral-800 dark:bg-neutral-700 cursor-pointer"
                  value="<%= server.id %>" data-uuid="<%= server.UUID %>" data-edit-id="<%= server.id %>" data-name="<%= server.name %>">
              </td>
              <td class="whitespace-nowrap py-4 pr-3 text-sm">
                <div class="flex items-center gap-3">
                  <span class="shrink-0 relative flex h-2 w-2">
                    <% if (server.Suspended) { %>
                      <span class="relative inline-flex rounded-full h-2 w-2 bg-neutral-400"></span>
                    <% } else { %>
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                    <% } %>
                  </span>
                  <div>
                    <div class="font-medium text-neutral-800 dark:text-white truncate max-w-[200px]"><%= server.name %></div>
                    <div class="text-xs text-neutral-400 dark:text-neutral-500 font-mono mt-0.5"><%= server.UUID %></div>
                  </div>
                </div>
              </td>
              <td class="whitespace-nowrap px-3 py-4 text-sm">
                <a href="/admin/users/view/<%= server.owner.id %>" class="flex items-center gap-2 group" onclick="event.stopPropagation()">
                  <img class="h-6 w-6 rounded-md object-cover shrink-0"
                    src="<%= server.owner.avatar ? server.owner.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(server.owner.username) %>" alt="<%= server.owner.username %>'s avatar">
                  <span class="font-medium text-neutral-800 dark:text-blue-400 group-hover:underline truncate max-w-[120px]"><%= server.owner.username %></span>
                </a>
              </td>
              <td class="whitespace-nowrap px-3 py-4 text-sm">
                <a href="/admin/node/<%= server.node.id %>/stats" class="font-medium text-neutral-800 dark:text-blue-400 hover:underline truncate max-w-[120px]" onclick="event.stopPropagation()"><%= server.node.name %></a>
              </td>
              <td class="whitespace-nowrap px-3 py-4 text-sm text-neutral-600 dark:text-neutral-400">
                <%= server.node.address %>:<%= JSON.parse(server.Ports).filter(p => p.primary).map(p => p.externalPort || String(p.Port || '').split(':')[0]).pop() %>
              </td>
              <td class="whitespace-nowrap px-3 py-4 text-sm">
                <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset
                  <%= server.Suspended ? 'bg-amber-600/10 text-amber-600 dark:text-amber-400 ring-amber-600/20' : 'bg-emerald-600/10 text-emerald-600 dark:text-emerald-400 ring-emerald-600/20' %>">
                  <%= server.Suspended ? 'Suspended' : 'Enabled' %>
                </span>
              </td>
              <td class="whitespace-nowrap px-3 py-4 text-sm">
                <div class="flex items-center gap-1.5">
                  <a href="/server/<%= server.UUID %>" onclick="event.stopPropagation()" title="Open console"
                    class="rounded-lg bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/30 p-1.5 text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors">
                    <%- icon('external-link', { size: 16, class: 'shrink-0' }) %>
                  </a>
                  <a href="/admin/servers/edit/<%= server.id %>" onclick="event.stopPropagation()" title="Edit"
                    class="rounded-lg bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/30 p-1.5 text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors">
                    <%- icon('pencil', { size: 16, class: 'shrink-0' }) %>
                  </a>
                  <button type="button" onclick="event.stopPropagation(); deleteServer('<%= server.id %>', '<%= server.name %>')" title="Delete"
                    class="rounded-lg bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/30 p-1.5 text-red-700 dark:text-red-300 hover:bg-red-100 dark:hover:bg-red-500/20 hover:text-red-800 dark:hover:text-red-200 transition-colors">
                    <%- icon('trash-2', { size: 16, class: 'shrink-0' }) %>
                  </button>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</main>

<%- include('../../components/toast') %>
<%- include('../../components/loadingPopup') %>

<!-- Radar scan modal -->
<div id="radarScanModal" class="fixed inset-0 z-50 hidden">
  <div class="flex items-center justify-center min-h-screen p-4">
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm" id="radarScanModalBackdrop"></div>
    <div class="relative bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700/60 rounded-2xl shadow-2xl max-w-2xl w-full overflow-hidden">

      <div class="flex justify-between items-start px-6 py-4 border-b border-neutral-200 dark:border-neutral-700/50">
        <div>
          <h3 class="text-sm font-semibold text-neutral-800 dark:text-white" id="radarScanModalTitle">Radar Scan</h3>
          <p class="text-xs text-neutral-500 mt-0.5" id="radarScanModalSubtitle">Pick a script and scan the server volume</p>
        </div>
        <button type="button" onclick="closeRadarScanModal()" class="text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-200 transition ml-4 mt-0.5">
          <%- icon('x', { size: 20, class: 'shrink-0' }) %>
        </button>
      </div>

      <!-- Picker phase -->
      <div id="radarPickerPhase" class="px-6 py-5">

        <!-- Scan mode toggle — only shown when VT key configured -->
        <div id="scanModeToggle" class="hidden mb-5">
          <p class="text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-2">Scan method</p>
          <div class="flex gap-2">
            <button type="button" id="modeBuiltin" onclick="setScanMode('builtin')"
              class="flex-1 flex items-center gap-2 px-3 py-2.5 rounded-lg border-2 border-neutral-800 dark:border-white bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 text-xs font-medium transition-all">
              <%- icon('radar', { size: 14, class: 'shrink-0' }) %>
              Built-in patterns
            </button>
            <button type="button" id="modeVT" onclick="setScanMode('vt')"
              class="flex-1 flex items-center gap-2 px-3 py-2.5 rounded-lg border-2 border-neutral-200 dark:border-neutral-700 bg-white dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 text-xs font-medium transition-all hover:border-neutral-400 dark:hover:border-neutral-500">
              <%- icon('shield', { size: 14, class: 'shrink-0' }) %>
              VirusTotal file scan
            </button>
          </div>
        </div>

        <!-- Built-in script picker -->
        <div id="builtinPickerSection">
          <div class="flex gap-4 items-start">
            <div class="flex-1">
              <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Script</label>
              <select id="scriptSelect"
                class="w-full rounded-lg text-neutral-800 dark:text-white text-sm px-3 py-2 bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/50 focus:outline-none focus:ring-2 focus:ring-neutral-400 dark:focus:ring-neutral-500">
                <option value="">Loading scripts...</option>
              </select>
            </div>
            <div class="pt-5">
              <button type="button" id="runScanButton" onclick="runRadarScan()"
                class="inline-flex items-center gap-2 rounded-lg bg-neutral-900 dark:bg-neutral-700 border border-neutral-700/30 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-800 dark:hover:bg-neutral-600 transition-colors">
                <%- icon('radar', { size: 16, class: 'shrink-0' }) %>
                Run Scan
              </button>
            </div>
          </div>
          <p id="scriptDescription" class="mt-2 text-xs text-neutral-500 italic min-h-4"></p>
        </div>

        <!-- VT file scan -->
        <div id="vtScanSection" class="hidden">
          <div class="rounded-lg bg-neutral-50 dark:bg-neutral-800/60 border border-neutral-200 dark:border-neutral-700/50 p-4 mb-4 text-xs text-neutral-500 space-y-1">
            <p>Zips <span class="font-mono text-neutral-700 dark:text-neutral-300">plugins/</span>, <span class="font-mono text-neutral-700 dark:text-neutral-300">mods/</span>, <span class="font-mono text-neutral-700 dark:text-neutral-300">config/</span>, <span class="font-mono text-neutral-700 dark:text-neutral-300">addons/</span>, <span class="font-mono text-neutral-700 dark:text-neutral-300">datapacks/</span> and uploads to VirusTotal.</p>
            <p>Excludes world folders, logs, cache. Max 32 MB zip. Takes 30–120 seconds.</p>
            <p class="text-amber-600 dark:text-amber-400">Free tier: 4 requests/min · 500/day. Do not use for automated scanning.</p>
          </div>
          <button type="button" id="runVtScanButton" onclick="runVtFileScan()"
            class="inline-flex items-center gap-2 rounded-lg bg-neutral-900 dark:bg-neutral-700 border border-neutral-700/30 px-4 py-2 text-sm font-medium text-white hover:bg-neutral-800 dark:hover:bg-neutral-600 transition-colors">
            <%- icon('shield', { size: 16, class: 'shrink-0' }) %>
            Upload to VirusTotal
          </button>
        </div>

      </div>

      <!-- Results phase -->
      <div id="radarResultsPhase" class="hidden">
        <div id="radarSummaryBar" class="px-6 py-3 border-t border-neutral-200 dark:border-neutral-700/50 flex items-center gap-4 bg-neutral-50 dark:bg-neutral-800/60"></div>
        <div id="radarServerTabs" class="hidden border-b border-neutral-200 dark:border-neutral-700/50 px-6 pt-3 flex gap-1 overflow-x-auto"></div>
        <div id="radarResultsBody" class="px-6 py-4 max-h-80 overflow-y-auto"></div>
      </div>

      <!-- Footer -->
      <div class="px-6 py-4 border-t border-neutral-200 dark:border-neutral-700/50 flex justify-between items-center">
        <button type="button" id="radarRescanBtn" class="hidden text-xs text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition-colors" onclick="resetRadarToPickerPhase()">
          ← Run another scan
        </button>
        <div class="ml-auto">
          <button type="button" onclick="closeRadarScanModal()"
            class="rounded-lg bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 hover:bg-neutral-100 dark:hover:bg-neutral-700 text-neutral-700 dark:text-neutral-200 px-3 py-1.5 text-sm font-medium transition-colors">
            Close
          </button>
        </div>
      </div>

    </div>
  </div>
</div>

<script nonce="<%- nonce %>" src="/javascript/admin-servers.js"></script>

<%- include('../../components/footer') %>
