<%- include('../../components/header', { title: 'Player Statistics' }) %>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <div class="w-60 h-full">
      <%- include('../../components/template') %>
    </div>
    <!-- Content -->
    <div id="page-content" class="flex-1 p-6 overflow-y-auto pt-16">
      <div class="sm:flex sm:items-center px-8 pt-4">
        <%- include('../../components/pageTitle', {
          title: 'Player Statistics',
          description: 'View player statistics across all Minecraft servers'
        }) %>
         <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
          <button id="refreshBtn" class="border border-neutral-200 dark:border-neutral-800/20 block rounded-xl bg-white dark:bg-white/5 hover:bg-neutral-50 dark:hover:bg-white/10 text-neutral-800 dark:text-white px-3 py-2 text-center text-sm font-medium shadow-lg transition duration-300 focus:outline focus:outline-2 focus:outline-offset-2">
            Refresh Data
          </button>
        </div>
       </div>

       <!-- Error Message -->
      <% if (errorMessage && errorMessage.message) { %>
      <div class="rounded-xl bg-red-800/10 px-6 py-4 mt-8 mx-8">
        <div class="flex items-center">
          <%- icon('triangle-alert', { size: 20, class: 'text-red-400 mr-4 shrink-0' }) %>
          <div>
            <h3 class="text-sm font-medium text-red-400">Error</h3>
            <p class="text-sm text-red-400/50">
              <%= errorMessage.message %>
            </p>
          </div>
        </div>
      </div>
      <% } %>

       <div class="px-8 mt-6">
        <!-- Stats Cards -->
        <dl class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
            <!-- Total Players Card -->
            <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-4">
               <div class="flex items-center justify-between">
                 <dt class="truncate text-sm font-medium text-neutral-500 dark:text-neutral-300">Total Players</dt>
                  <div class="rounded-lg bg-neutral-100 dark:bg-neutral-700/30 p-2">
                    <%- icon('users', { size: 20, class: 'text-neutral-400 shrink-0' }) %>
                  </div>
               </div>
               <dd id="totalPlayers" class="mt-3 text-3xl font-semibold tracking-tight text-neutral-800 dark:text-white">
                0
               </dd>
               <p class="mt-1 text-sm text-neutral-400">Players across all servers</p>
            </div>

            <!-- Max Capacity Card -->
            <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-4">
               <div class="flex items-center justify-between">
                 <dt class="truncate text-sm font-medium text-neutral-500 dark:text-neutral-300">Max Capacity</dt>
                  <div class="rounded-lg bg-neutral-100 dark:bg-neutral-700/30 p-2">
                    <%- icon('database', { size: 20, class: 'text-neutral-400 shrink-0' }) %>
                  </div>
               </div>
               <dd id="maxCapacity" class="mt-3 text-3xl font-semibold tracking-tight text-neutral-800 dark:text-white">
                0
               </dd>
               <p class="mt-1 text-sm text-neutral-400">Total player capacity</p>
            </div>

            <!-- Online Servers Card -->
            <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-4">
               <div class="flex items-center justify-between">
                 <dt class="truncate text-sm font-medium text-neutral-500 dark:text-neutral-300">Online Servers</dt>
                  <div class="rounded-lg bg-neutral-100 dark:bg-neutral-700/30 p-2">
                    <%- icon('server', { size: 20, class: 'text-neutral-400 shrink-0' }) %>
                  </div>
               </div>
               <dd id="onlineServers" class="mt-3 text-3xl font-semibold tracking-tight text-neutral-800 dark:text-white">
                0
               </dd>
               <p class="mt-1 text-sm text-neutral-400">Servers currently online</p>
            </div>

            <!-- Utilization Card -->
            <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-4">
               <div class="flex items-center justify-between">
                 <dt class="truncate text-sm font-medium text-neutral-500 dark:text-neutral-300">Utilization</dt>
                  <div class="rounded-lg bg-neutral-100 dark:bg-neutral-700/30 p-2">
                    <%- icon('activity', { size: 20, class: 'text-neutral-400 shrink-0' }) %>
                  </div>
               </div>
               <dd id="utilization" class="mt-3 text-3xl font-semibold tracking-tight text-neutral-800 dark:text-white">
                0%
               </dd>
               <p class="mt-1 text-sm text-neutral-400">Player capacity utilization</p>
            </div>
         </dl>

         <!-- Player Graph -->
         <div class="bg-gradient-to-br from-neutral-800/20 to-neutral-900/10 border border-neutral-700/20 rounded-xl mt-8 shadow-md p-6">
            <div class="flex justify-between items-center mb-4">
              <h2 class="text-lg font-semibold text-neutral-800 dark:text-white">Player Count History</h2>
              <div class="text-xs text-neutral-400">Data collected every 5 minutes (last 48 hours)</div>
            </div>
            <div class="h-60">
              <canvas id="playerChart" class="w-full h-full"></canvas>
            </div>
            <div class="mt-2 text-xs text-neutral-400 text-center">
              <p><%= req.translations.refreshDataCollection || 'Double-click the Refresh button to manually trigger data collection' %></p>
            </div>
         </div>

         <!-- Server Table -->
         <div class="bg-white dark:bg-neutral-800/20 border border-neutral-200 dark:border-neutral-700/20 rounded-xl mt-8 shadow-sm p-6">
            <h2 class="text-lg font-semibold text-neutral-800 dark:text-white mb-4">Server Player Counts</h2>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-neutral-200 dark:divide-neutral-700/20">
                <thead>
                  <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">Server</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">Players</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400 uppercase tracking-wider">Version</th>
                  </tr>
                </thead>
                <tbody id="serverTableBody" class="divide-y divide-neutral-100 dark:divide-neutral-700/20 bg-white dark:bg-transparent">
                  <tr>
                    <td colspan="4" class="px-6 py-4 text-center text-neutral-400">Loading server data...</td>
                  </tr>
                </tbody>
              </table>
            </div>
         </div>
       </div>
    </div>
  </div>
</main>

<script nonce="<%- nonce %>" src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script nonce="<%- nonce %>" src="/javascript/admin-playerstats.js"></script>

<%- include('../../components/footer') %>