<%- include('../../components/header', { title: 'Settings' }) %>

<main class="min-h-screen">
  <div class="flex min-h-screen">
    <div class="w-60 shrink-0"><%- include('../../components/template') %></div>

    <div id="page-content" class="flex-1 overflow-y-auto pt-16 pb-12">
      <div class="px-8 pt-5">
        <h1 class="text-base font-medium text-neutral-800 dark:text-white">Settings</h1>
        <p class="mt-0.5 text-sm text-neutral-500">Manage your panel configuration.</p>
      </div>

      <div class="px-8 mt-5">

        <!-- Tab bar -->
        <div class="flex gap-0.5 mb-6 border-b border-neutral-200 dark:border-neutral-700/40">
          <button type="button" data-tab="appearance" class="tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2">Appearance</button>
          <button type="button" data-tab="servers"    class="tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2">Servers</button>
          <button type="button" data-tab="security"   class="tab-btn px-4 py-2.5 text-sm font-medium transition -mb-px border-b-2">Security</button>
        </div>

        <!-- ── APPEARANCE ──────────────────────────────────────────────────── -->
        <form id="form-appearance" data-tab-panel="appearance" class="tab-panel space-y-5 hidden" enctype="multipart/form-data">

          <!-- Branding -->
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Branding</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 px-5 py-5">
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Site title</label>
                <input type="text" name="title" value="<%= settings.title %>"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Logo</label>
                <input type="file" name="logo" accept="image/*"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white file:mr-3 file:py-1 file:px-2 file:rounded-lg file:border-0 file:text-xs file:bg-neutral-200 dark:file:bg-neutral-600 file:text-neutral-700 dark:file:text-neutral-300">
                <% if (settings.logo) { %>
                <img src="<%= settings.logo.startsWith('/') ? settings.logo : '/' + settings.logo %>" alt="Logo" class="h-8 mt-2 object-contain">
                <% } %>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Favicon</label>
                <input type="file" name="favicon" accept=".ico,.png,.jpg,.jpeg"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white file:mr-3 file:py-1 file:px-2 file:rounded-lg file:border-0 file:text-xs file:bg-neutral-200 dark:file:bg-neutral-600 file:text-neutral-700 dark:file:text-neutral-300">
                <p class="text-xs text-neutral-400 mt-1">PNG or JPG auto-converted to .ico</p>
              </div>
            </div>
          </div>

          <!-- Registration -->
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Registration</h2>
            <div class="px-5 py-5 flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-neutral-700 dark:text-white">Allow public registration</p>
                <p class="text-xs text-neutral-500 mt-0.5">When off, only admins can create new accounts.</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" name="allowRegistration" class="sr-only peer" <%= settings.allowRegistration ? 'checked' : '' %>>
                <div class="w-11 h-6 bg-neutral-300 dark:bg-neutral-600 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
              </label>
            </div>
          </div>

          <!-- Themes -->
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Themes</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 px-5 py-5">
              <div>
                <p class="text-sm font-medium text-neutral-700 dark:text-white mb-1">Light mode</p>
                <p class="text-xs text-neutral-500 mb-3">Applied when the panel is in light mode.</p>
                <div class="space-y-2">
                  <% const lightVal = settings.lightTheme || 'default'; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= lightVal === 'default' ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="lightTheme" value="default" class="sr-only" <%= lightVal === 'default' ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= lightVal === 'default' ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (lightVal === 'default') { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <span class="text-sm text-neutral-700 dark:text-neutral-300 flex-1">Default</span>
                    <span class="text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full">built-in</span>
                  </label>
                  <% allThemes.filter(t => t.name !== 'default').forEach(function(theme) { %>
                  <% const ltv = theme.lightPath || theme.path; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= lightVal === ltv ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="lightTheme" value="<%= ltv %>" class="sr-only" <%= lightVal === ltv ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= lightVal === ltv ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (lightVal === ltv) { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <div class="flex-1 min-w-0">
                      <span class="text-sm text-neutral-700 dark:text-neutral-300 capitalize block"><%= theme.name.replace(/-/g,' ') %></span>
                      <% if (theme.author) { %><span class="text-xs text-neutral-400">by <%= theme.author %></span><% } %>
                    </div>
                    <span class="text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full shrink-0"><%= theme.builtin ? 'built-in' : 'custom' %></span>
                  </label>
                  <% }); %>
                </div>
              </div>
              <div>
                <p class="text-sm font-medium text-neutral-700 dark:text-white mb-1">Dark mode</p>
                <p class="text-xs text-neutral-500 mb-3">Applied when the panel is in dark mode.</p>
                <div class="space-y-2">
                  <% const darkVal = settings.darkTheme || 'default'; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= darkVal === 'default' ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="darkTheme" value="default" class="sr-only" <%= darkVal === 'default' ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= darkVal === 'default' ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (darkVal === 'default') { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <span class="text-sm text-neutral-700 dark:text-neutral-300 flex-1">Default</span>
                    <span class="text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full">built-in</span>
                  </label>
                  <% allThemes.filter(t => t.name !== 'default').forEach(function(theme) { %>
                  <% const dtv = theme.darkPath || theme.path; %>
                  <label class="flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition <%= darkVal === dtv ? 'border-blue-400 bg-blue-50 dark:bg-blue-500/10' : 'border-neutral-200 dark:border-neutral-600/30 hover:border-neutral-300' %>">
                    <input type="radio" name="darkTheme" value="<%= dtv %>" class="sr-only" <%= darkVal === dtv ? 'checked' : '' %>>
                    <span class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 <%= darkVal === dtv ? 'border-blue-500' : 'border-neutral-300 dark:border-neutral-600' %>">
                      <% if (darkVal === dtv) { %><span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span><% } %>
                    </span>
                    <div class="flex-1 min-w-0">
                      <span class="text-sm text-neutral-700 dark:text-neutral-300 capitalize block"><%= theme.name.replace(/-/g,' ') %></span>
                      <% if (theme.author) { %><span class="text-xs text-neutral-400">by <%= theme.author %></span><% } %>
                    </div>
                    <span class="text-xs text-neutral-400 bg-neutral-100 dark:bg-neutral-700/40 px-2 py-0.5 rounded-full shrink-0"><%= theme.builtin ? 'built-in' : 'custom' %></span>
                  </label>
                  <% }); %>
                </div>
              </div>
            </div>
            <div class="px-5 pb-5 border-t border-neutral-200 dark:border-white/5 pt-4">
              <div class="flex items-center justify-between mb-2">
                <p class="text-sm font-medium text-neutral-700 dark:text-white">Upload custom theme</p>
                <a href="/admin/settings/example-theme" class="text-xs text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition">Download example</a>
              </div>
              <p class="text-xs text-neutral-500 mb-3">A .zip containing info.json, light.css, dark.css.</p>
              <input type="file" name="themeFile" accept=".zip"
                class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white file:mr-3 file:py-1 file:px-2 file:rounded-lg file:border-0 file:text-xs file:bg-neutral-200 dark:file:bg-neutral-600 file:text-neutral-700 dark:file:text-neutral-300">
            </div>
          </div>

          <!-- Auth page wallpapers -->
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Auth page wallpapers</h2>
            <p class="text-xs text-neutral-500 px-5 pt-3 pb-1">Background image on the login and register pages. Upload a file or paste a URL. Leave both blank to use the default.</p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 px-5 py-5">
              <div>
                <p class="text-sm font-medium text-neutral-700 dark:text-white mb-3">Login page</p>
                <% if (settings.loginWallpaper) { %>
                <img src="<%= settings.loginWallpaper %>" alt="" class="h-20 w-full object-cover rounded-xl border border-neutral-200 dark:border-white/5 mb-3">
                <% } %>
                <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Upload file</label>
                <input type="file" name="loginWallpaperFile" accept="image/*"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white file:mr-3 file:py-1 file:px-2 file:rounded-lg file:border-0 file:text-xs file:bg-neutral-200 dark:file:bg-neutral-600 file:text-neutral-700 dark:file:text-neutral-300 mb-2">
                <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Or paste a URL</label>
                <input type="text" name="loginWallpaperUrl" placeholder="https://…"
                  value="<%= (settings.loginWallpaper && settings.loginWallpaper.startsWith('http')) ? settings.loginWallpaper : '' %>"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors">
              </div>
              <div>
                <p class="text-sm font-medium text-neutral-700 dark:text-white mb-3">Register page</p>
                <% if (settings.registerWallpaper) { %>
                <img src="<%= settings.registerWallpaper %>" alt="" class="h-20 w-full object-cover rounded-xl border border-neutral-200 dark:border-white/5 mb-3">
                <% } %>
                <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Upload file</label>
                <input type="file" name="registerWallpaperFile" accept="image/*"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white file:mr-3 file:py-1 file:px-2 file:rounded-lg file:border-0 file:text-xs file:bg-neutral-200 dark:file:bg-neutral-600 file:text-neutral-700 dark:file:text-neutral-300 mb-2">
                <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Or paste a URL</label>
                <input type="text" name="registerWallpaperUrl" placeholder="https://…"
                  value="<%= (settings.registerWallpaper && settings.registerWallpaper.startsWith('http')) ? settings.registerWallpaper : '' %>"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors">
              </div>
            </div>
          </div>

          <div class="flex justify-end gap-3">
            <button type="button" id="resetButton" class="rounded-xl border border-neutral-200 dark:border-neutral-700/40 text-neutral-600 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white px-4 py-2 text-sm font-medium transition">Reset defaults</button>
            <button type="submit" class="rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-6 py-2 text-sm font-medium shadow-sm transition">Save appearance</button>
          </div>
        </form>

        <!-- ── SERVERS ─────────────────────────────────────────────────────── -->
        <div id="panel-servers" data-tab-panel="servers" class="tab-panel hidden space-y-5">

          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">User permissions</h2>
            <div class="px-5 py-5 space-y-5">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-neutral-700 dark:text-white">Allow users to create servers</p>
                  <p class="text-xs text-neutral-500 mt-0.5">Users can create their own servers up to their limit.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" id="allowUserCreateServer" class="sr-only peer" <%= settings.allowUserCreateServer ? 'checked' : '' %>>
                  <div class="w-10 h-5 bg-neutral-300 dark:bg-neutral-600 peer-focus-visible:ring-2 peer-focus-visible:ring-neutral-400 peer-focus-visible:ring-offset-1 outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                </label>
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-neutral-700 dark:text-white">Allow users to delete servers</p>
                  <p class="text-xs text-neutral-500 mt-0.5">Users can delete servers they own.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" id="allowUserDeleteServer" class="sr-only peer" <%= settings.allowUserDeleteServer ? 'checked' : '' %>>
                  <div class="w-10 h-5 bg-neutral-300 dark:bg-neutral-600 peer-focus-visible:ring-2 peer-focus-visible:ring-neutral-400 peer-focus-visible:ring-offset-1 outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                </label>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">File uploads</h2>
            <div class="px-5 py-5">
              <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Upload limit <span class="text-neutral-400 font-normal">(MB)</span></label>
              <div class="relative max-w-xs">
                <input type="number" id="uploadLimitInput" value="<%= settings.uploadLimit %>" min="1" max="10000"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 pr-12 text-neutral-800 dark:text-white transition-colors">
                <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-neutral-400 pointer-events-none">MB</span>
              </div>
              <p class="mt-1.5 text-xs text-neutral-500">Maximum file size users can upload via the file manager.</p>
            </div>
          </div>

          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Default limits</h2>
            <p class="text-xs text-neutral-500 px-5 pt-3">Applied to new users unless overridden per-user.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 px-5 py-5">
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Server limit</label>
                <input type="number" id="defaultServerLimit" value="<%= settings.defaultServerLimit %>" min="0" max="100"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                <p class="mt-1 text-xs text-neutral-500">0 = cannot create.</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Max memory</label>
                <input type="hidden" id="defaultMaxMemory" value="<%= settings.defaultMaxMemory %>">
                <div class="flex items-stretch gap-0">
                  <input type="number" id="defaultMaxMemoryDisplay" min="1"
                    value="<%= settings.defaultMaxMemory >= 1024 ? Math.round(settings.defaultMaxMemory / 1024) : settings.defaultMaxMemory %>"
                    class="rounded-l-xl flex-1 border border-r-0 border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                  <select id="defaultMaxMemoryUnit" class="rounded-r-xl text-sm px-2 py-2 bg-neutral-200 dark:bg-neutral-600 text-neutral-800 dark:text-white border border-neutral-200 dark:border-neutral-600/30 cursor-pointer">
                    <option value="1"    <%= settings.defaultMaxMemory < 1024  ? 'selected' : '' %>>MB</option>
                    <option value="1024" <%= settings.defaultMaxMemory >= 1024 ? 'selected' : '' %>>GB</option>
                  </select>
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Max CPU <span class="text-neutral-400 font-normal">(%)</span></label>
                <input type="number" id="defaultMaxCpu" value="<%= settings.defaultMaxCpu %>" min="50" max="10000"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Max storage</label>
                <input type="hidden" id="defaultMaxStorage" value="<%= settings.defaultMaxStorage %>">
                <div class="flex items-stretch gap-0">
                  <input type="number" id="defaultMaxStorageDisplay" min="1"
                    value="<%= settings.defaultMaxStorage >= 1024 ? Math.round(settings.defaultMaxStorage / 1024) : settings.defaultMaxStorage %>"
                    class="rounded-l-xl flex-1 border border-r-0 border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
                  <select id="defaultMaxStorageUnit" class="rounded-r-xl text-sm px-2 py-2 bg-neutral-200 dark:bg-neutral-600 text-neutral-800 dark:text-white border border-neutral-200 dark:border-neutral-600/30 cursor-pointer">
                    <option value="1"    <%= settings.defaultMaxStorage < 1024  ? 'selected' : '' %>>MB</option>
                    <option value="1024" <%= settings.defaultMaxStorage >= 1024 ? 'selected' : '' %>>GB</option>
                  </select>
                </div>
              </div>
            </div>
            <div class="px-5 pb-5 border-t border-neutral-200 dark:border-white/5 pt-4 flex justify-end">
              <button type="button" id="saveServerPolicy" class="rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-5 py-2 text-sm font-medium shadow-sm transition">Save</button>
            </div>
          </div>
        </div>

        <!-- ── SECURITY ────────────────────────────────────────────────────── -->
        <div id="panel-security" data-tab-panel="security" class="tab-panel hidden space-y-5">

          <!-- VirusTotal -->
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">VirusTotal</h2>
            <div class="px-5 py-5">
              <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">API key</label>
              <div class="relative max-w-sm">
                <input type="password" id="vtKeyInput" value="<%= settings.virusTotalApiKey || '' %>" placeholder="Paste your key" autocomplete="off"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 pr-16 text-neutral-800 dark:text-white placeholder-neutral-400 font-mono transition-colors">
                <button type="button" onclick="const i=this.previousElementSibling;i.type=i.type==='password'?'text':'password';this.textContent=i.type==='password'?'Show':'Hide';"
                  class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-neutral-500 hover:text-neutral-700 dark:hover:text-neutral-300 transition">Show</button>
              </div>
              <% if (settings.virusTotalApiKey) { %><p class="mt-1.5 text-xs text-emerald-600 dark:text-emerald-400">Key is set.</p><% } %>
              <p class="mt-1.5 text-xs text-neutral-500">Used to scan uploaded files. Get a free key at <a href="https://www.virustotal.com" target="_blank" class="underline hover:text-neutral-700 dark:hover:text-neutral-300 transition">virustotal.com</a>.</p>
            </div>
            <div class="px-5 pb-5 border-t border-neutral-200 dark:border-white/5 pt-4 flex justify-end">
              <button type="button" id="saveVtKey" class="rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-5 py-2 text-sm font-medium shadow-sm transition">Save</button>
            </div>
          </div>

          <!-- Rate limiting -->
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Rate limiting</h2>
            <div class="px-5 py-5 space-y-4">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-neutral-700 dark:text-white">Enable rate limiting</p>
                  <p class="text-xs text-neutral-500 mt-0.5">Limit requests per minute per IP address.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" id="rateLimitEnabled" class="sr-only peer" <%= settings.rateLimitEnabled ? 'checked' : '' %>>
                  <div class="w-11 h-6 bg-neutral-300 dark:bg-neutral-600 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                </label>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Requests per minute</label>
                <input type="number" id="rateLimitRpm" value="<%= settings.rateLimitRpm %>" min="1" max="10000"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-48 bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
              </div>
            </div>
          </div>

          <!-- Login protection -->
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Login protection</h2>
            <p class="text-xs text-neutral-500 px-5 pt-3">After N failed attempts from a single account, that account is locked for the configured duration. Errors always say "invalid credentials" — the username is never revealed.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 px-5 py-5">
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Max failed attempts before lockout</label>
                <input type="number" id="loginMaxAttempts" value="<%= settings.loginMaxAttempts ?? 5 %>" min="1" max="100"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-white mb-2">Lockout duration <span class="text-neutral-400 font-normal">(minutes)</span></label>
                <input type="number" id="loginLockoutMinutes" value="<%= settings.loginLockoutMinutes ?? 15 %>" min="1" max="1440"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus:ring-1 focus:outline-none text-sm w-full bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white transition-colors">
              </div>
            </div>
          </div>

          <!-- Network -->
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Network</h2>
            <div class="px-5 py-5 space-y-5">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-neutral-700 dark:text-white">Behind a reverse proxy</p>
                  <p class="text-xs text-neutral-500 mt-0.5">Enable if Nginx, Caddy, or another proxy sits in front. Makes <code class="text-xs bg-neutral-200 dark:bg-neutral-700 px-1 rounded">req.ip</code> use the forwarded header so rate limiting and IP bans target the real client.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer ml-4 shrink-0">
                  <input type="checkbox" id="behindReverseProxy" class="sr-only peer" <%= settings.behindReverseProxy ? 'checked' : '' %>>
                  <div class="w-11 h-6 bg-neutral-300 dark:bg-neutral-600 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                </label>
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-neutral-700 dark:text-white">Enforce HTTPS for daemon connections</p>
                  <p class="text-xs text-neutral-500 mt-0.5">Panel contacts daemons over <code class="text-xs bg-neutral-200 dark:bg-neutral-700 px-1 rounded">https://</code>. Only enable if your daemons have TLS configured.</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer ml-4 shrink-0">
                  <input type="checkbox" id="enforceDaemonHttps" class="sr-only peer" <%= settings.enforceDaemonHttps ? 'checked' : '' %>>
                  <div class="w-11 h-6 bg-neutral-300 dark:bg-neutral-600 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                </label>
              </div>
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-neutral-700 dark:text-white">Hash API keys at rest</p>
                  <p class="text-xs text-neutral-500 mt-0.5">Store API keys as SHA-256 hashes in the database. <strong class="text-amber-600 dark:text-amber-400">Enable before creating new keys — existing keys shown once.</strong></p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer ml-4 shrink-0">
                  <input type="checkbox" id="hashApiKeys" class="sr-only peer" <%= settings.hashApiKeys ? 'checked' : '' %>>
                  <div class="w-11 h-6 bg-neutral-300 dark:bg-neutral-600 rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                </label>
              </div>
            </div>
            <div class="px-5 pb-5 border-t border-neutral-200 dark:border-white/5 pt-4 flex justify-end">
              <button type="button" id="saveRateLimit" class="rounded-xl bg-neutral-900 dark:bg-white hover:bg-neutral-700 dark:hover:bg-neutral-200 text-white dark:text-neutral-900 px-5 py-2 text-sm font-medium shadow-sm transition">Save security settings</button>
            </div>
          </div>

          <!-- IP banning -->
          <div class="bg-white dark:bg-white/5 rounded-xl border border-neutral-200 dark:border-white/5 shadow-sm dark:shadow-none">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-50 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">IP banning</h2>
            <div class="px-5 py-5">
              <div class="flex gap-3 mb-4">
                <input type="text" id="banIpInput" placeholder="192.168.1.1"
                  class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/70 focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none text-sm bg-neutral-100 dark:bg-neutral-700/20 px-4 py-2 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors flex-1 max-w-xs">
                <button type="button" id="banIpBtn" class="rounded-xl bg-red-600 hover:bg-red-500 text-white px-4 py-2 text-sm font-medium transition">Ban IP</button>
              </div>
              <div id="bannedIpList" class="space-y-2">
                <% let banned = []; try { banned = JSON.parse(settings.bannedIps || '[]'); } catch {} %>
                <% if (banned.length === 0) { %>
                <p class="text-sm text-neutral-400">No banned IPs.</p>
                <% } else { %>
                <% banned.forEach(function(ip) { %>
                <div class="flex items-center justify-between rounded-xl bg-neutral-100 dark:bg-neutral-800/40 border border-neutral-200 dark:border-white/5 px-4 py-2.5">
                  <span class="text-sm font-mono text-neutral-700 dark:text-neutral-300"><%= ip %></span>
                  <button type="button" class="unban-btn text-xs text-red-500 hover:text-red-700 dark:hover:text-red-400 transition" data-ip="<%= ip %>">Unban</button>
                </div>
                <% }); } %>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include('../../components/toast') %>
<%- include('../../components/modal') %>

<script nonce="<%- nonce %>" src="/javascript/admin-settings.js"></script>

<%- include('../../components/footer') %>
