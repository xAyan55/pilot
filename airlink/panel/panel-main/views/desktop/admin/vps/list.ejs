<%- include('../../components/header', { title: 'Admin VPS Management' }) %>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <div class="w-60 h-full"><%- include('../../components/template') %></div>

    <div id="page-content" class="flex-1 overflow-y-auto pt-16">
      <div class="px-12 pt-6 pb-8">
        
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
          <div>
            <h1 class="text-base font-medium text-neutral-800 dark:text-white">Admin VPS Management</h1>
            <p class="text-sm text-neutral-500 mt-0.5">Control, manage, and monitor all virtual private servers active across the nodes.</p>
          </div>
          <div class="flex items-center gap-2">
            <a href="/admin/vps/create" class="flex min-h-10 items-center gap-1.5 px-3 py-2 rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 text-sm font-medium hover:bg-neutral-700 dark:hover:bg-neutral-200 transition shadow-sm">
              <%- icon('plus', { class: 'h-4 w-4' }) %>
              Provision VPS
            </a>
          </div>
        </div>

        <!-- Table Card -->
        <div class="bg-white dark:bg-white/[0.03] border border-neutral-200 dark:border-white/5 rounded-2xl overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs">
              <thead class="bg-neutral-50 dark:bg-white/[0.02] border-b border-neutral-200 dark:border-white/5 text-neutral-500 uppercase tracking-wider font-semibold">
                <tr>
                  <th class="py-3.5 px-5">Name</th>
                  <th class="py-3.5 px-4">Container ID</th>
                  <th class="py-3.5 px-4">Owner</th>
                  <th class="py-3.5 px-4">Node</th>
                  <th class="py-3.5 px-4">Specs (CPU/RAM/Disk)</th>
                  <th class="py-3.5 px-4">Relay Port</th>
                  <th class="py-3.5 px-4 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-100 dark:divide-white/5 text-neutral-700 dark:text-neutral-300 font-medium">
                <% vpsList.forEach(vps => { %>
                <tr class="hover:bg-neutral-50 dark:hover:bg-white/[0.02]">
                  <td class="py-4 px-5 font-bold"><%= vps.name %></td>
                  <td class="py-4 px-4 font-mono text-neutral-500"><%= vps.containerName %></td>
                  <td class="py-4 px-4">
                    <span class="px-2 py-1 bg-neutral-100 dark:bg-white/5 rounded text-neutral-600 dark:text-neutral-400">
                      <%= vps.owner.username %>
                    </span>
                  </td>
                  <td class="py-4 px-4 text-neutral-600 dark:text-neutral-400"><%= vps.node.name %></td>
                  <td class="py-4 px-4">
                    <%= vps.cpu %> Cores / <%= vps.ram >= 1024 ? (vps.ram/1024).toFixed(0) + 'GB' : vps.ram + 'MB' %> / <%= vps.disk %>GB
                  </td>
                  <td class="py-4 px-4 font-mono"><%= vps.tunnelPort %></td>
                  <td class="py-4 px-4 text-right flex items-center justify-end gap-2">
                    <a href="/vps/console/<%= vps.UUID %>" class="px-2 py-1 bg-neutral-100 hover:bg-neutral-200 dark:bg-white/5 dark:hover:bg-white/10 text-neutral-800 dark:text-neutral-200 rounded font-semibold transition" title="Inspect">
                      Inspect
                    </a>
                    <button onclick="destroyVps('<%= vps.UUID %>')" class="p-1 hover:bg-red-50 dark:hover:bg-red-500/10 text-red-500 rounded transition" title="Terminate Container">
                      <%- icon('trash', { class: 'h-4 w-4' }) %>
                    </button>
                  </td>
                </tr>
                <% }); %>

                <% if (vpsList.length === 0) { %>
                <tr>
                  <td colspan="7" class="py-8 text-center text-neutral-400">
                    No active VPS instances found.
                  </td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<script>
  async function destroyVps(uuid) {
    if (!confirm('Are you absolutely sure you want to terminate and delete this VPS instance? This will completely wipe all disk records.')) return;
    try {
      const response = await fetch(`/api/vps/${uuid}`, {
        method: 'DELETE'
      });
      const data = await response.json();
      if (data.success) {
        window.location.reload();
      } else {
        alert('Failed to terminate VPS: ' + data.error);
      }
    } catch {
      alert('Network error while terminating VPS');
    }
  }
</script>

<%- include('../../components/footer') %>
