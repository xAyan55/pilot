<%- include('../../components/header', { title: 'Edit Image' }) %>

<main class="min-h-screen">
  <div class="flex min-h-screen">
    <div class="w-60 shrink-0">
      <%- include('../../components/template') %>
    </div>
    <div id="page-content" class="flex-1 overflow-y-auto pt-16 pb-12">

      <div class="px-8 pt-5 flex items-start justify-between">
        <div>
          <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= image.name || 'Edit Image' %></h1>
          <p class="mt-0.5 text-sm text-neutral-500">Edit egg configuration, variables, Docker images, and install scripts.</p>
        </div>
        <div class="flex gap-2 shrink-0 ml-4">
          <a href="/admin/images/export/<%= image.id %>"
            class="px-3 py-2 text-sm font-medium rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 hover:bg-neutral-50 dark:hover:bg-neutral-700 text-neutral-700 dark:text-neutral-300 transition">
            Export
          </a>
          <a href="/admin/images"
            class="px-3 py-2 text-sm font-medium rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 hover:bg-neutral-50 dark:hover:bg-neutral-700 text-neutral-700 dark:text-neutral-300 transition">
            Back
          </a>
        </div>
      </div>

      <% if (req.query.success) { %>
        <div class="mx-8 mt-5 px-4 py-3 rounded-xl bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800/30 text-sm text-green-700 dark:text-green-400">
          Changes saved successfully.
        </div>
      <% } %>

      <div class="px-8 mt-6">
        <!-- Tab nav -->
        <div class="flex gap-0.5 mb-6 border-b border-neutral-200 dark:border-neutral-700/40">
          <button type="button" data-tab="general" class="tab-btn px-4 py-2.5 text-sm font-medium transition-colors -mb-px border-b-2">General</button>
          <button type="button" data-tab="docker" class="tab-btn px-4 py-2.5 text-sm font-medium transition-colors -mb-px border-b-2">Docker Images</button>
          <button type="button" data-tab="variables" class="tab-btn px-4 py-2.5 text-sm font-medium transition-colors -mb-px border-b-2">Variables</button>
          <button type="button" data-tab="install" class="tab-btn px-4 py-2.5 text-sm font-medium transition-colors -mb-px border-b-2">Install Script</button>
          <button type="button" data-tab="settings" class="tab-btn px-4 py-2.5 text-sm font-medium transition-colors -mb-px border-b-2">Settings</button>
          <button type="button" data-tab="raw" class="tab-btn px-4 py-2.5 text-sm font-medium transition-colors -mb-px border-b-2">Raw JSON</button>
        </div>

        <!-- General tab -->
        <div data-tab-form="general" class="tab-form space-y-5">
          <div class="flex flex-col bg-neutral-50 dark:bg-white/[0.03] rounded-xl border border-neutral-200 dark:border-white/5">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Basics</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 px-5 py-5">
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Name</label>
                <input type="text" id="field-name" value="<%= image.name || '' %>"
                  class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 px-3 py-2 text-sm text-neutral-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition">
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Author</label>
                <input type="text" id="field-author" value="<%= image.author || '' %>"
                  class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 px-3 py-2 text-sm text-neutral-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition">
              </div>
              <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Description</label>
                <textarea id="field-description" rows="2"
                  class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 px-3 py-2 text-sm text-neutral-800 dark:text-white focus:outline-none focus:ring-2 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition resize-none"><%= image.description || '' %></textarea>
              </div>
            </div>
          </div>

          <div class="flex flex-col bg-neutral-50 dark:bg-white/[0.03] rounded-xl border border-neutral-200 dark:border-white/5">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Process</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 px-5 py-5">
              <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Startup Command</label>
                <input type="text" id="field-startup" value="<%= image.startup || '' %>" placeholder="e.g. java -Xms128M -Xmx{{SERVER_MEMORY}}M -jar {{SERVER_JARFILE}}"
                  class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 px-3 py-2 text-sm text-neutral-800 dark:text-white font-mono focus:outline-none focus:ring-2 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition">
                <p class="mt-1.5 text-xs text-neutral-400">Use <code class="font-mono bg-neutral-100 dark:bg-neutral-800 px-1 rounded">{{VARIABLE_NAME}}</code> to reference egg variables.</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Stop Command</label>
                <input type="text" id="field-stop" value="<%= image.stop || 'stop' %>" placeholder="stop"
                  class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 px-3 py-2 text-sm text-neutral-800 dark:text-white font-mono focus:outline-none focus:ring-2 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition">
                <p class="mt-1.5 text-xs text-neutral-400">Command sent to the container to stop it gracefully.</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Startup Done Signal</label>
                <input type="text" id="field-startup-done" value="<%= image.startup_done || '' %>" placeholder="e.g. For help, type"
                  class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 px-3 py-2 text-sm text-neutral-800 dark:text-white font-mono focus:outline-none focus:ring-2 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition">
                <p class="mt-1.5 text-xs text-neutral-400">String in the server output that means the server finished starting.</p>
              </div>
            </div>
          </div>

          <div class="flex justify-end">
            <button type="button" id="save-general"
              class="px-5 py-2.5 text-sm font-medium rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 hover:bg-neutral-700 dark:hover:bg-neutral-100 transition">
              Save Changes
            </button>
          </div>
        </div>

        <!-- Docker Images tab -->
        <div data-tab-form="docker" class="tab-form space-y-5 hidden">
          <div class="flex flex-col bg-neutral-50 dark:bg-white/[0.03] rounded-xl border border-neutral-200 dark:border-white/5">
            <div class="flex items-center justify-between px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">
              <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white">Docker Images</h2>
              <button type="button" id="add-docker-image"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-white/10 bg-white dark:bg-neutral-800 hover:bg-neutral-50 dark:hover:bg-neutral-700 text-neutral-700 dark:text-neutral-300 transition">
                Add Image
              </button>
            </div>
            <div class="px-5 py-4">
              <p class="text-xs text-neutral-500 mb-4">Each entry maps a display label to a Docker image reference. The label is what users see in dropdowns.</p>
              <div id="docker-images-list" class="space-y-2">
                <!-- populated by JS -->
              </div>
            </div>
          </div>
          <div class="flex justify-end">
            <button type="button" id="save-docker"
              class="px-5 py-2.5 text-sm font-medium rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 hover:bg-neutral-700 dark:hover:bg-neutral-100 transition">
              Save Changes
            </button>
          </div>
        </div>

        <!-- Variables tab -->
        <div data-tab-form="variables" class="tab-form space-y-5 hidden">
          <div class="flex flex-col bg-neutral-50 dark:bg-white/[0.03] rounded-xl border border-neutral-200 dark:border-white/5">
            <div class="flex items-center justify-between px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">
              <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white">Egg Variables</h2>
              <button type="button" id="add-variable"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-white/10 bg-white dark:bg-neutral-800 hover:bg-neutral-50 dark:hover:bg-neutral-700 text-neutral-700 dark:text-neutral-300 transition">
                Add Variable
              </button>
            </div>
            <div class="px-5 py-4">
              <p class="text-xs text-neutral-500 mb-4">Variables are injected as environment variables into the container. <code class="font-mono bg-neutral-100 dark:bg-neutral-800 px-1 rounded">env_variable</code> is the name used in the startup command and Docker environment.</p>
              <div id="variables-list" class="space-y-3">
                <!-- populated by JS -->
              </div>
            </div>
          </div>
          <div class="flex justify-end">
            <button type="button" id="save-variables"
              class="px-5 py-2.5 text-sm font-medium rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 hover:bg-neutral-700 dark:hover:bg-neutral-100 transition">
              Save Changes
            </button>
          </div>
        </div>

        <!-- Install Script tab -->
        <div data-tab-form="install" class="tab-form space-y-5 hidden">
          <div class="flex flex-col bg-neutral-50 dark:bg-white/[0.03] rounded-xl border border-neutral-200 dark:border-white/5">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Installation Script</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 px-5 py-5">
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Container Image</label>
                <input type="text" id="field-install-container" placeholder="e.g. eclipse-temurin:21-jdk-jammy"
                  class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 px-3 py-2 text-sm text-neutral-800 dark:text-white font-mono focus:outline-none focus:ring-2 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition">
                <p class="mt-1.5 text-xs text-neutral-400">Docker image the install script runs inside.</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Entrypoint</label>
                <input type="text" id="field-install-entrypoint" placeholder="bash"
                  class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 px-3 py-2 text-sm text-neutral-800 dark:text-white font-mono focus:outline-none focus:ring-2 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition">
                <p class="mt-1.5 text-xs text-neutral-400">Shell that executes the script (usually <code class="font-mono">bash</code>).</p>
              </div>
              <div class="sm:col-span-2">
                <label class="block text-sm font-medium text-neutral-700 dark:text-neutral-300 mb-1.5">Script</label>
                <textarea id="field-install-script" rows="16" placeholder="#!/bin/bash&#10;# Install script runs inside the container&#10;apt update && apt install -y curl"
                  class="w-full rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-neutral-800 px-3 py-2 text-sm text-neutral-800 dark:text-white font-mono focus:outline-none focus:ring-2 focus:ring-neutral-300 dark:focus:ring-neutral-600 transition resize-y"></textarea>
                <p class="mt-1.5 text-xs text-neutral-400">Files are placed in <code class="font-mono bg-neutral-100 dark:bg-neutral-800 px-1 rounded">/mnt/server</code> inside the install container. The script runs as root.</p>
              </div>
            </div>
          </div>
          <div class="flex justify-end">
            <button type="button" id="save-install"
              class="px-5 py-2.5 text-sm font-medium rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 hover:bg-neutral-700 dark:hover:bg-neutral-100 transition">
              Save Changes
            </button>
          </div>
        </div>

        <!-- Settings tab -->
        <div data-tab-form="settings" class="tab-form space-y-5 hidden">
          <div class="flex flex-col bg-neutral-50 dark:bg-white/[0.03] rounded-xl border border-neutral-200 dark:border-white/5">
            <div class="flex items-center justify-between px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">
              <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white">Required Ports</h2>
              <button type="button" id="add-port-requirement"
                class="px-3 py-1.5 text-xs font-medium rounded-lg border border-neutral-200 dark:border-white/10 bg-white dark:bg-neutral-800 hover:bg-neutral-50 dark:hover:bg-neutral-700 text-neutral-700 dark:text-neutral-300 transition">
                Add Port
              </button>
            </div>
            <div class="px-5 py-4">
              <p class="text-xs text-neutral-500 mb-4">Each entry is shown when creating servers. Users get exactly these required ports; admins can add more.</p>
              <div id="port-requirements-list" class="space-y-2"></div>
            </div>
          </div>
          <div class="flex justify-end">
            <button type="button" id="save-settings"
              class="px-5 py-2.5 text-sm font-medium rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 hover:bg-neutral-700 dark:hover:bg-neutral-100 transition">
              Save Changes
            </button>
          </div>
        </div>

        <!-- Raw JSON tab -->
        <div data-tab-form="raw" class="tab-form space-y-5 hidden">
          <div class="flex flex-col bg-neutral-50 dark:bg-white/[0.03] rounded-xl border border-neutral-200 dark:border-white/5">
            <h2 class="text-[13px] font-medium text-neutral-800 dark:text-white px-5 py-3.5 bg-neutral-100 dark:bg-white/5 rounded-t-xl border-b border-neutral-200 dark:border-white/5">Raw JSON</h2>
            <div class="px-5 py-5">
              <p class="text-xs text-neutral-500 mb-4">Edit the complete egg JSON directly. Must be valid JSON — the editor will warn on errors. Saving here overwrites all tab values.</p>
              <div id="json-editor" class="w-full h-[480px] rounded-xl border border-neutral-200 dark:border-neutral-700 overflow-hidden"></div>
            </div>
          </div>
          <div class="flex justify-end">
            <button type="button" id="save-raw"
              class="px-5 py-2.5 text-sm font-medium rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 hover:bg-neutral-700 dark:hover:bg-neutral-100 transition">
              Save Raw JSON
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include('../../components/toast') %>

<script nonce="<%- nonce %>" src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.36.1/min/vs/loader.min.js"></script>

<div id="page-data" style="display:none"
  data-image="<%- JSON.stringify({
    id: image.id,
    name: image.name || '',
    description: image.description || '',
    author: image.author || '',
    startup: image.startup || '',
    stop: image.stop || 'stop',
    startup_done: image.startup_done || '',
    docker_images: image.dockerImages || {},
    variables: image.variables || [],
    scripts: image.scripts || {},
    info: image.info || {},
    meta: image.meta || {},
    portRequirements: image.portRequirements || []
  }) %>"
></div>

<script nonce="<%- nonce %>" src="/javascript/admin-image-edit.js"></script>

<%- include('../../components/footer') %>
