<%- include('../../components/header', { title: 'Image Store' }) %>
<%- include('../../components/toast') %>

<style>
  ::-webkit-scrollbar { display: none; }

  /* ── Fixed-size modals ────────────────────────────────────── */
  .modal-overlay {
    position: fixed; inset: 0; z-index: 50;
    background: var(--theme-overlay, rgba(0,0,0,0.5));
    display: flex; align-items: center; justify-content: center; padding: 16px;
    opacity: 0; pointer-events: none; transition: opacity 0.25s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: auto; }
  .modal-box {
    background: var(--theme-bg-card, #fff); border: 1px solid var(--theme-border, #e5e5e5); border-radius: 12px;
    width: 100%; max-width: 780px; height: 560px; max-height: calc(100vh - 40px);
    display: flex; flex-direction: column;
    transform: scale(0.96); opacity: 0;
    transition: transform 0.25s, opacity 0.25s;
    overflow: hidden;
  }
  html.dark .modal-box { background: var(--theme-bg-card, #1c1c1c); border-color: var(--theme-border-subtle, rgba(255,255,255,0.08)); }
  .modal-overlay.open .modal-box { transform: scale(1); opacity: 1; }

  /* Single-egg modal is narrower */
  .modal-box.narrow { max-width: 520px; height: 500px; }

  /* Group modal has a two-column body */
  .modal-two-col { display: flex; flex: 1; overflow: hidden; min-height: 0; }
  .modal-left {
    width: 260px; min-width: 200px; flex-shrink: 0;
    border-right: 1px solid var(--theme-border, #e5e5e5);
    overflow-y: auto; padding: 18px;
    display: flex; flex-direction: column; gap: 10px;
  }
  html.dark .modal-left { border-right-color: var(--theme-border-subtle, rgba(255,255,255,0.06)); }
  .modal-right { flex: 1; min-width: 0; overflow-y: auto; padding: 18px; }

  /* Single-egg body scrolls as one column */
  .modal-single-body { flex: 1; overflow-y: auto; padding: 18px; display: flex; flex-direction: column; gap: 14px; }

  /* ── Markdown rendering ───────────────────────────────────── */
  .md-body { font-size: 12.5px; line-height: 1.75; color: var(--theme-text-muted, #525252); }
  html.dark .md-body { color: var(--theme-text-muted, #737373); }
  .md-body h1, .md-body h2 { font-size: 13px; font-weight: 600; color: var(--theme-text-strong, #171717); margin: 0 0 6px; }
  html.dark .md-body h1, html.dark .md-body h2 { color: var(--theme-text, #e5e5e5); }
  .md-body h3 { font-size: 12px; font-weight: 600; color: var(--theme-text-muted, #525252); margin: 10px 0 3px; }
  html.dark .md-body h3 { color: var(--theme-text, #a3a3a3); }
  .md-body p { margin: 0 0 8px; }
  .md-body a { color: var(--theme-accent, #7c3aed); text-decoration: none; }
  .md-body a:hover { text-decoration: underline; }
  .md-body code { font-family: ui-monospace,monospace; font-size: 11px; background: var(--theme-bg-secondary, #f4f4f5); padding: 1px 5px; border-radius: 4px; color: var(--theme-text-muted, #3f3f46); }
  html.dark .md-body code { background: var(--theme-bg-hover, rgba(255,255,255,0.07)); color: var(--theme-text-strong, #d4d4d4); }
  .md-body pre { background: var(--theme-bg-secondary, #f4f4f5); border: 1px solid var(--theme-border, #e5e5e5); border-radius: 8px; padding: 10px 12px; overflow-x: auto; margin: 0 0 8px; }
  html.dark .md-body pre { background: var(--theme-bg-hover, rgba(255,255,255,0.04)); border-color: var(--theme-border-subtle, rgba(255,255,255,0.07)); }
  .md-body pre code { background: none; padding: 0; }
  .md-body ul, .md-body ol { padding-left: 16px; margin: 0 0 8px; }
  .md-body li { margin-bottom: 2px; }
  .md-body hr { border: none; border-top: 1px solid var(--theme-border, #e5e5e5); margin: 10px 0; }
  html.dark .md-body hr { border-top-color: var(--theme-border-subtle, rgba(255,255,255,0.06)); }
  .md-body strong { color: var(--theme-text-strong, #171717); }
  html.dark .md-body strong { color: var(--theme-text, #e5e5e5); }

  /* ── Sub-image list rows ──────────────────────────────────── */
  .sub-row {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    padding: 7px 10px; border-radius: 8px; cursor: pointer;
    border: 1px solid var(--theme-border, #e5e5e5);
    transition: background 0.12s, border-color 0.12s; margin-bottom: 4px;
  }
  html.dark .sub-row { border-color: var(--theme-border-subtle, rgba(255,255,255,0.07)); }
  .sub-row:hover { background: var(--theme-bg-secondary, #f5f5f5); border-color: var(--theme-border-strong, #d4d4d4); }
  html.dark .sub-row:hover { background: var(--theme-bg-hover, rgba(255,255,255,0.04)); border-color: var(--theme-border-subtle, rgba(255,255,255,0.13)); }

  /* ── Skeletons ────────────────────────────────────────────── */
  .sk { border-radius: 8px; animation: sk-pulse 1.4s ease-in-out infinite; }
  html:not(.dark) .sk { background: var(--theme-bg-secondary, #f0f0f0); }
  html.dark .sk { background: var(--theme-bg-hover, rgba(255,255,255,0.05)); }
  @keyframes sk-pulse { 0%,100%{opacity:1} 50%{opacity:0.35} }

  /* ── View toggle ──────────────────────────────────────────── */
  .vtog { display: flex; gap: 1px; background: var(--theme-bg-secondary, #f5f5f5); border: 1px solid var(--theme-border, #e5e5e5); border-radius: 10px; padding: 2px; }
  html.dark .vtog { background: var(--theme-bg-hover, rgba(255,255,255,0.04)); border-color: var(--theme-border-subtle, rgba(255,255,255,0.08)); }
  .vtog button { padding: 4px 14px; border-radius: 8px; font-size: 12px; font-weight: 500; cursor: pointer; border: none; background: transparent; color: var(--theme-text-muted, #737373); transition: background 0.12s, color 0.12s; }
  html.dark .vtog button { color: var(--theme-text-muted, #525252); }
  .vtog button.active { background: var(--theme-bg-card, #fff); color: var(--theme-text-strong, #171717); box-shadow: 0 1px 3px var(--theme-shadow-sm, rgba(0,0,0,0.07)); }
  html.dark .vtog button.active { background: var(--theme-bg-hover, rgba(255,255,255,0.1)); color: var(--theme-text, #e5e5e5); }

  /* ── Group header row ─────────────────────────────────────── */
  .grp-row {
    display: flex; align-items: center;
    padding: 11px 16px; cursor: pointer;
    transition: background 0.1s;
  }
  .grp-row:hover { background: var(--theme-bg-input, #f9fafb); }
  html.dark .grp-row:hover { background: var(--theme-bg-hover, rgba(255,255,255,0.025)); }

  /* ── Category badges ──────────────────────────────────────── */
  .cat-game        { background: var(--theme-info-bg, #ede9fe); color: var(--theme-info-text, #6d28d9); }
  .cat-application { background: var(--theme-info-bg, #e0f2fe); color: var(--theme-info-text, #0369a1); }
  .cat-generic     { background: var(--theme-success-bg, #dcfce7); color: var(--theme-success-text, #15803d); }
  html.dark .cat-game        { background: var(--theme-info-bg, rgba(139,92,246,0.15)); color: var(--theme-info, #a78bfa); }
  html.dark .cat-application { background: var(--theme-info-bg, rgba(14,165,233,0.15)); color: var(--theme-info, #38bdf8); }
  html.dark .cat-generic     { background: var(--theme-success-bg, rgba(34,197,94,0.15)); color: var(--theme-success, #4ade80); }

  /* ── Error banner ─────────────────────────────────────────── */
  .err-box { background: var(--theme-danger-bg, rgba(239,68,68,0.08)); border: 1px solid var(--theme-danger-border, rgba(239,68,68,0.2)); border-radius: 9px; padding: 10px 12px; }
  .err-txt { font-size: 11px; color: var(--theme-danger, #dc2626); }
  html.dark .err-txt { color: var(--theme-danger, #f87171); }

  @media (max-width: 640px) {
    .modal-box { height: auto; max-height: calc(100vh - 40px); }
    .modal-two-col { flex-direction: column; }
    .modal-left { width: 100%; border-right: none; border-bottom: 1px solid var(--theme-border, #e5e5e5); }
    html.dark .modal-left { border-bottom-color: var(--theme-border-subtle, rgba(255,255,255,0.06)); }
    .col-hide { display: none; }
  }
  @media (min-width: 641px) { .col-hide-desktop { display: none; } }
</style>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <div class="w-60 h-full"><%- include('../../components/template') %></div>
    <div id="page-content" class="flex-1 p-6 overflow-y-auto pt-16">

      <div class="sm:flex sm:items-center px-8 pt-4">
        <%- include('../../components/pageTitle', { title: 'Image Store', description: 'Browse and install images from the Pterodactyl community' }) %>
        <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
          <button id="refreshBtn" onclick="doRefresh()" type="button" class="border border-neutral-800/20 rounded-xl bg-white hover:bg-neutral-200 dark:hover:bg-neutral-300 text-neutral-800 px-3 py-2 text-sm font-medium shadow-lg transition">Refresh</button>
        </div>
      </div>

      <div class="mx-8 mt-6 flex border-b border-neutral-200 dark:border-neutral-800">
        <a href="/admin/images" class="px-1 py-2.5 mr-5 text-sm font-medium text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 border-b-2 border-transparent -mb-px transition">Installed</a>
        <span class="px-1 py-2.5 text-sm font-medium text-neutral-800 dark:text-white border-b-2 border-neutral-800 dark:border-white -mb-px">Store</span>
      </div>

      <!-- Controls -->
      <div class="mx-8 mt-5 flex items-center justify-between gap-3 flex-wrap mb-1">
        <div class="flex items-center gap-3">
          <input id="imageFilterInput" type="text" placeholder="Search…" class="w-52 rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 px-3 py-2 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-500 focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none focus:border-neutral-400 dark:focus:border-neutral-600 transition">
          <span id="statusText" class="text-xs text-neutral-400 dark:text-neutral-500 whitespace-nowrap"></span>
        </div>
        <div class="vtog">
          <button id="btnAll" onclick="setView('all')">All</button>
          <button id="btnApp" class="active" onclick="setView('app')">By App</button>
        </div>
      </div>

      <!-- Skeletons -->
      <div id="loadingEl" class="m-8 space-y-2">
        <% for(let i=0;i<8;i++){%><div class="sk h-11 w-full"></div><%}%>
      </div>
      <div id="errorEl" style="display:none" class="mx-8 mt-6 py-16 text-center">
        <p class="text-sm text-neutral-500">Failed to load catalogue.</p>
        <button onclick="loadCatalogue()" class="mt-3 text-xs text-neutral-400 underline cursor-pointer bg-transparent border-none">Retry</button>
      </div>
      <div id="emptyEl" style="display:none" class="mx-8 mt-6 py-16 text-center">
        <p class="text-sm text-neutral-500">No images match your search.</p>
      </div>

      <!-- All view: single alphabetical table -->
      <div id="allView" style="display:none" class="overflow-x-auto shadow-sm rounded-xl m-8 border border-neutral-200 dark:border-neutral-800/40">
        <table class="min-w-full divide-y divide-neutral-200 dark:divide-white/10">
          <thead class="bg-neutral-50 dark:bg-neutral-800/50">
            <tr>
              <th class="py-3.5 pl-6 pr-3 text-left text-sm font-medium text-neutral-800 dark:text-white">Name</th>
              <th class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white col-hide">Category</th>
              <th class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white col-hide">Author</th>
              <th class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white">Actions</th>
            </tr>
          </thead>
          <tbody id="allBody" class="divide-y divide-neutral-100 dark:divide-white/5 bg-white dark:bg-neutral-800/20"></tbody>
        </table>
      </div>

      <!-- App view: one collapsible block per group -->
      <div id="appView" style="display:none" class="m-8 space-y-3"></div>
    </div>
  </div>
</main>

<!-- ── Group popup (fixed 780×560) ─────────────────────────────── -->
<div class="modal-overlay" id="groupOverlay">
  <div class="modal-box">
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-200 dark:border-white/5 flex-shrink-0">
      <div class="flex items-center gap-2 min-w-0">
        <p id="grpTitle" class="text-sm font-semibold text-neutral-800 dark:text-white truncate"></p>
        <span id="grpCount" class="text-xs text-neutral-400 dark:text-neutral-500 whitespace-nowrap"></span>
      </div>
      <button onclick="closeGroup()" class="ml-3 shrink-0 w-7 h-7 flex items-center justify-center rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-400 transition">
        <%- icon('x', { size: 16, class: 'shrink-0' }) %>
      </button>
    </div>
    <div class="modal-two-col">
      <div class="modal-left">
        <p class="text-[10px] font-medium text-neutral-400 dark:text-neutral-500 uppercase tracking-wider">Images</p>
        <div id="grpSubList"></div>
      </div>
      <div class="modal-right">
        <p class="text-[10px] font-medium text-neutral-400 dark:text-neutral-500 uppercase tracking-wider mb-3">README</p>
        <div id="grpReadme" class="md-body"></div>
      </div>
    </div>
  </div>
</div>

<!-- ── Single-egg install popup (fixed 520×500) ────────────────── -->
<div class="modal-overlay" id="eggOverlay">
  <div class="modal-box narrow">
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-200 dark:border-white/5 flex-shrink-0">
      <div class="flex items-center gap-2 min-w-0">
        <p id="eggTitle" class="text-sm font-semibold text-neutral-800 dark:text-white truncate"></p>
        <span id="eggCat" class="text-[10px] font-medium px-2 py-0.5 rounded-full whitespace-nowrap"></span>
      </div>
      <button onclick="closeEgg()" class="ml-3 shrink-0 w-7 h-7 flex items-center justify-center rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-400 transition">
        <%- icon('x', { size: 16, class: 'shrink-0' }) %>
      </button>
    </div>
    <div class="modal-single-body">
      <p id="eggDesc" class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed"></p>
      <p id="eggAuthor" class="text-[11px] text-neutral-400 dark:text-neutral-500"></p>
      <div class="flex-1 overflow-y-auto">
        <p class="text-[10px] font-medium text-neutral-400 dark:text-neutral-500 uppercase tracking-wider mb-2">README</p>
        <div id="eggReadme" class="md-body"></div>
      </div>
      <div id="eggErr" style="display:none" class="err-box"><p id="eggErrTxt" class="err-txt"></p></div>
      <button id="eggInstallBtn" onclick="confirmInstall()" type="button"
        class="w-full border border-neutral-800/20 rounded-xl bg-white hover:bg-neutral-200 dark:hover:bg-neutral-300 text-neutral-800 py-2.5 text-sm font-medium shadow-lg transition mt-auto">
        Install
      </button>
    </div>
  </div>
</div>

<script nonce="<%- nonce %>" src="/javascript/admin-image-store.js"></script>

<%- include('../../components/footer') %>
