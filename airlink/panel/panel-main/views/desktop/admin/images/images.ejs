<%- include('../../components/header', { title: 'Images' }) %>
<%- include('../../components/toast') %>

<style>
  ::-webkit-scrollbar { display: none; }
  .modal-overlay {
    position: fixed; inset: 0; z-index: 50;
    background: var(--theme-overlay, rgba(0,0,0,0.5));
    display: flex; align-items: center; justify-content: center; padding: 16px;
    opacity: 0; pointer-events: none; transition: opacity 0.25s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: auto; }
  .modal-box {
    background: var(--theme-bg-card, #fff); border: 1px solid var(--theme-border, #e5e5e5); border-radius: 12px;
    width: 100%; max-width: 460px;
    transform: scale(0.96); opacity: 0;
    transition: transform 0.25s, opacity 0.25s;
  }
  html.dark .modal-box { background: var(--theme-bg-card, #1c1c1c); border-color: var(--theme-border-subtle, rgba(255,255,255,0.08)); }
  .modal-overlay.open .modal-box { transform: scale(1); opacity: 1; }
  .field-label { font-size: 11px; font-weight: 500; color: var(--theme-text-muted, #737373); display: block; margin-bottom: 5px; }
  html.dark .field-label { color: var(--theme-text, #a3a3a3); }
  .field-input {
    width: 100%; border-radius: 9px; border: 1px solid var(--theme-border, #e5e5e5);
    background: var(--theme-bg-input, #fafafa); padding: 8px 12px;
    font-size: 13px; color: var(--theme-text-strong, #171717); outline: none;
    transition: border-color 0.15s; box-sizing: border-box; font-family: inherit;
  }
  html.dark .field-input { background: var(--theme-bg-hover, rgba(255,255,255,0.04)); border-color: var(--theme-border-subtle, rgba(255,255,255,0.1)); color: var(--theme-text, #e5e5e5); }
  .field-input:focus { border-color: var(--theme-border, #a3a3a3); }
  html.dark .field-input:focus { border-color: var(--theme-border-subtle, rgba(255,255,255,0.25)); }
  .field-input::placeholder { color: var(--theme-text-placeholder, #a3a3a3); }
  html.dark .field-input::placeholder { color: var(--theme-text-muted, #525252); }
  @media (max-width: 640px) { .col-hide { display: none; } }
</style>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <div class="w-60 h-full"><%- include('../../components/template') %></div>
    <div id="page-content" class="flex-1 p-6 overflow-y-auto pt-16">

      <div class="sm:flex sm:items-center px-8 pt-4">
        <%- include('../../components/pageTitle', { title: 'Images', description: 'Manage server images installed on this panel' }) %>
        <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none flex gap-2 flex-wrap">
          <button id="uploadBtn" type="button" class="border border-neutral-800/20 rounded-xl bg-white hover:bg-neutral-200 dark:hover:bg-neutral-300 text-neutral-800 px-3 py-2 text-sm font-medium shadow-lg transition">Upload JSON</button>
          <button onclick="openCreate()" type="button" class="border border-neutral-800/20 rounded-xl bg-white hover:bg-neutral-200 dark:hover:bg-neutral-300 text-neutral-800 px-3 py-2 text-sm font-medium shadow-lg transition">New Image</button>
          <a href="/admin/images/store"><button type="button" class="border border-neutral-800/20 rounded-xl bg-white hover:bg-neutral-200 dark:hover:bg-neutral-300 text-neutral-800 px-3 py-2 text-sm font-medium shadow-lg transition">Browse Store</button></a>
        </div>
      </div>

      <div class="mx-8 mt-6 flex border-b border-neutral-200 dark:border-neutral-800">
        <span class="px-1 py-2.5 mr-5 text-sm font-medium text-neutral-800 dark:text-white border-b-2 border-neutral-800 dark:border-white -mb-px">Installed <span class="ml-1 text-xs text-neutral-400"><%= images.length %></span></span>
        <a href="/admin/images/store" class="px-1 py-2.5 text-sm font-medium text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 border-b-2 border-transparent -mb-px transition">Store</a>
      </div>

      <% if (images.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-24 text-center">
        <p class="text-sm text-neutral-500">No images installed yet.</p>
        <a href="/admin/images/store"><button type="button" class="mt-4 border border-neutral-800/20 rounded-xl bg-white hover:bg-neutral-200 dark:hover:bg-neutral-300 text-neutral-800 px-3 py-2 text-sm font-medium shadow-lg transition">Browse Store</button></a>
      </div>
      <% } else { %>

      <div class="mx-8 mt-5 mb-1">
        <input id="imageFilterInput" type="text" placeholder="Filter images…" class="w-56 rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 px-3 py-2 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-500 focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none focus:border-neutral-400 dark:focus:border-neutral-600 transition">
      </div>

      <div class="overflow-x-auto shadow-sm rounded-xl m-8 border border-neutral-200 dark:border-neutral-800/40">
        <table class="min-w-full divide-y divide-neutral-200 dark:divide-white/10">
          <thead class="bg-neutral-50 dark:bg-neutral-800/50">
            <tr>
              <th class="py-3.5 pl-6 pr-3 text-left text-sm font-medium text-neutral-800 dark:text-white">Name</th>
              <th class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white col-hide">Author</th>
              <th class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white col-hide">Created</th>
              <th class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100 dark:divide-white/5 bg-white dark:bg-neutral-800/20" id="tableBody">
            <% let imgIdx = 0; images.forEach(function(image) { %>
            <tr class="hover:bg-neutral-50 dark:hover:bg-white/[0.05] transition-colors cursor-pointer img-row"
                style="--i:<%= imgIdx++ %>"
                data-search="<%= (image.name + ' ' + (image.author||'')).toLowerCase() %>"
                onclick="handleRowClick(event, '/admin/images/edit/<%= image.id %>')">
              <td class="whitespace-nowrap py-4 pl-6 pr-3 text-sm font-medium text-neutral-800 dark:text-white"><%= image.name %></td>
              <td class="whitespace-nowrap px-3 py-4 text-sm text-neutral-600 dark:text-neutral-400 col-hide"><%= image.author || '—' %></td>
              <td class="whitespace-nowrap px-3 py-4 text-sm text-neutral-600 dark:text-neutral-400 col-hide"><%= new Date(image.createdAt).toLocaleDateString() %></td>
              <td class="whitespace-nowrap px-3 py-4 text-sm">
                <div class="flex gap-2">
                  <a href="/admin/images/edit/<%= image.id %>"><button onclick="event.stopPropagation()" type="button" class="rounded-xl border border-neutral-800/20 bg-white hover:bg-neutral-300 text-neutral-800 px-3 py-2 text-sm font-medium shadow-lg transition">Edit</button></a>
                  <a href="/admin/images/export/<%= image.id %>"><button onclick="event.stopPropagation()" type="button" class="rounded-xl border border-neutral-800/20 bg-white hover:bg-neutral-300 text-neutral-800 px-3 py-2 text-sm font-medium shadow-lg transition">Export</button></a>
                  <button onclick="event.stopPropagation(); openDelete('<%= image.id %>', '<%= image.name %>')" type="button" class="rounded-xl bg-red-600 hover:bg-red-500 px-3 py-2 text-sm font-medium shadow-sm transition">
                    <%- icon('trash-2', { size: 16, class: 'text-white shrink-0' }) %>
                  </button>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
        <div id="noResults" class="hidden py-10 text-center text-sm text-neutral-500 dark:text-neutral-400 bg-white dark:bg-neutral-800/20">No images match your search.</div>
      </div>
      <% } %>
    </div>
  </div>
</main>

<!-- Create modal -->
<div class="modal-overlay" id="createOverlay">
  <div class="modal-box">
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-200 dark:border-white/5">
      <div>
        <p class="text-sm font-semibold text-neutral-800 dark:text-white">New Image</p>
        <p class="text-xs text-neutral-500 mt-0.5">Configure Docker images and variables after creation.</p>
      </div>
      <button onclick="closeCreate()" class="w-7 h-7 flex items-center justify-center rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-400 transition">
        <%- icon('x', { size: 16, class: 'shrink-0' }) %>
      </button>
    </div>
    <form action="/admin/images/create" method="POST" class="p-5 flex flex-col gap-4">
      <div class="grid grid-cols-2 gap-3">
        <div class="col-span-2"><label class="field-label">Name <span class="text-red-500">*</span></label><input class="field-input" type="text" name="name" required placeholder="e.g. Minecraft Java"></div>
        <div><label class="field-label">Author</label><input class="field-input" type="text" name="author" placeholder="e.g. github.com/you"></div>
        <div><label class="field-label">Author Name</label><input class="field-input" type="text" name="authorName" placeholder="Your Name"></div>
        <div class="col-span-2"><label class="field-label">Startup Command <span class="text-red-500">*</span></label><input class="field-input" type="text" name="startup" required placeholder="java -Xms128M -jar server.jar" style="font-family:ui-monospace,monospace;font-size:12px;"></div>
        <div class="col-span-2"><label class="field-label">Description</label><textarea class="field-input" name="description" rows="2" placeholder="What does this image run?" style="resize:none;"></textarea></div>
      </div>
      <div class="flex gap-2 pt-1">
        <button type="button" onclick="closeCreate()" class="flex-1 py-2 rounded-xl border border-neutral-200 dark:border-neutral-700 text-sm font-medium text-neutral-600 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition">Cancel</button>
        <button type="submit" class="flex-1 py-2 rounded-xl border border-neutral-800/20 bg-white hover:bg-neutral-200 dark:hover:bg-neutral-300 text-neutral-800 text-sm font-medium shadow-lg transition">Create & Edit</button>
      </div>
    </form>
  </div>
</div>

<!-- Delete modal -->
<div class="modal-overlay" id="deleteOverlay">
  <div class="modal-box" style="max-width:380px;">
    <div class="p-5">
      <p class="text-sm font-semibold text-neutral-800 dark:text-white mb-1">Delete image?</p>
      <p id="deleteMsg" class="text-xs text-neutral-500 mb-5"></p>
      <div class="flex gap-2">
        <button onclick="closeDelete()" class="flex-1 py-2 rounded-xl border border-neutral-200 dark:border-neutral-700 text-sm font-medium text-neutral-600 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-800 transition">Cancel</button>
        <button id="deleteConfirm" class="flex-1 py-2 rounded-xl bg-red-600 hover:bg-red-500 text-white text-sm font-medium shadow-sm transition">Delete</button>
      </div>
    </div>
  </div>
</div>

<script nonce="<%- nonce %>" src="/javascript/admin-images.js"></script>

<%- include('../../components/footer') %>
