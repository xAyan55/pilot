<%- include('../../components/header', { title: 'Addons' }) %>
<%- include('../../components/toast') %>
<%- include('../../components/loadingPopup') %>

<style>
  ::-webkit-scrollbar { display: none; }
  @media (max-width: 640px) { .col-hide { display: none; } }
</style>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <div class="w-60 h-full"><%- include('../../components/template') %></div>
    <div id="page-content" class="flex-1 p-6 overflow-y-auto pt-16">

      <div class="sm:flex sm:items-center px-8 pt-4">
        <%- include('../../components/pageTitle', { title: 'Addons', description: 'Manage installed addons and browse the store' }) %>
        <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none flex gap-2">
          <button id="reloadBtn" type="button" class="border border-neutral-800/20 rounded-xl bg-white hover:bg-neutral-200 dark:hover:bg-neutral-300 text-neutral-800 px-3 py-2 text-sm font-medium shadow-lg transition">Reload</button>
        </div>
      </div>

      <div class="mx-8 mt-6 flex border-b border-neutral-200 dark:border-neutral-800">
        <span class="px-1 py-2.5 mr-5 text-sm font-medium text-neutral-800 dark:text-white border-b-2 border-neutral-800 dark:border-white -mb-px">Installed <span class="ml-1 text-xs text-neutral-400"><%= addons ? addons.length : 0 %></span></span>
        <a href="/admin/addons/store" class="px-1 py-2.5 text-sm font-medium text-neutral-400 hover:text-neutral-600 dark:hover:text-neutral-300 border-b-2 border-transparent -mb-px transition">Store</a>
      </div>

      <% if (!addonTableExists) { %>
      <div class="mx-8 mt-5 rounded-xl bg-amber-600/20 dark:bg-amber-800/10 px-4 py-4 border border-neutral-800/20 flex items-start gap-3">
        <%- icon('triangle-alert', { size: 20, class: 'mt-0.5 shrink-0 text-amber-400' }) %>
        <div>
          <p class="text-sm font-medium text-amber-400">Database migration required</p>
          <p class="mt-1 text-xs text-amber-400/70">Run <code class="px-1 py-0.5 rounded font-mono bg-amber-500/10">npm run migrate:dev</code> then restart.</p>
        </div>
      </div>
      <% } %>

      <% if (addons && addons.length > 0) { %>
      <div class="mx-8 mt-5 mb-1">
        <input id="addonSearchInput" type="text" placeholder="Filter addons…" class="w-56 rounded-xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-900 px-3 py-2 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 dark:placeholder-neutral-500 focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none focus:border-neutral-400 dark:focus:border-neutral-600 transition">
      </div>
      <div class="overflow-x-auto shadow-sm rounded-xl m-8 border border-neutral-200 dark:border-neutral-800/40">
        <table class="min-w-full divide-y divide-neutral-200 dark:divide-white/10">
          <thead class="bg-neutral-50 dark:bg-neutral-800/50">
            <tr>
              <th class="py-3.5 pl-6 pr-3 text-left text-sm font-medium text-neutral-800 dark:text-white">Name</th>
              <th class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white col-hide">Version</th>
              <th class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white col-hide">Status</th>
              <th class="px-3 py-3.5 text-left text-sm font-medium text-neutral-800 dark:text-white">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100 dark:divide-white/5 bg-white dark:bg-neutral-800/20">
            <% let addonIdx = 0; addons.forEach(function(addon) { %>
            <tr class="hover:bg-neutral-50 dark:hover:bg-white/[0.05] transition-colors addon-row"
                style="--i:<%= addonIdx++ %>"
                data-slug="<%= addon.slug %>"
                data-search="<%= (addon.name + ' ' + (addon.description||'') + ' ' + (addon.author||'')).toLowerCase() %>">
              <td class="whitespace-nowrap py-4 pl-6 pr-3 text-sm">
                <p class="font-medium text-neutral-800 dark:text-white"><%= addon.name %></p>
                <% if (addon.description) { %><p class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5 max-w-xs truncate"><%= addon.description %></p><% } %>
              </td>
              <td class="whitespace-nowrap px-3 py-4 text-sm text-neutral-600 dark:text-neutral-400 col-hide">v<%= addon.version %><% if (addon.author) { %> · <%= addon.author %><% } %></td>
              <td class="whitespace-nowrap px-3 py-4 text-sm col-hide">
                <% if (addon.hasDisabledPh) { %>
                <span class="status-badge inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset bg-amber-50 dark:bg-amber-500/10 text-amber-700 dark:text-amber-300 ring-amber-600/20 dark:ring-amber-400/20">Not enabled</span>
                <% } else if (addon.enabled) { %>
                <span class="status-badge inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset bg-emerald-50 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-300 ring-emerald-600/20 dark:ring-emerald-400/20">Enabled</span>
                <% } else { %>
                <span class="status-badge inline-flex items-center rounded-md px-2 py-1 text-xs font-medium ring-1 ring-inset bg-neutral-100 dark:bg-white/5 text-neutral-600 dark:text-neutral-300 ring-neutral-300 dark:ring-white/10">Disabled</span>
                <% } %>
              </td>
              <td class="whitespace-nowrap px-3 py-4 text-sm">
                <div class="flex gap-2">
                  <button onclick="toggleAddon('<%= addon.slug %>', <%= !addon.enabled %>)" type="button"
                    class="toggle-btn rounded-xl border border-neutral-800/20 bg-white hover:bg-neutral-300 text-neutral-800 px-3 py-2 text-sm font-medium shadow-lg transition">
                    <%= addon.enabled ? 'Disable' : 'Enable' %>
                  </button>
                  <button onclick="confirmUninstall('<%= addon.slug %>', '<%= addon.name %>')" type="button"
                    class="rounded-xl bg-red-600 hover:bg-red-500 px-3 py-2 text-sm font-medium shadow-sm transition">
                    <%- icon('trash-2', { size: 16, class: 'text-white shrink-0' }) %>
                  </button>
                </div>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
        <div id="addonNoResults" class="hidden py-10 text-center text-sm text-neutral-500 dark:text-neutral-400 bg-white dark:bg-neutral-800/20">No addons match your search.</div>
      </div>
      <% } else { %>
      <div class="flex flex-col items-center justify-center py-24 text-center">
        <p class="text-sm text-neutral-500"><% if (addonTableExists) { %>No addons installed<% } else { %>Migration required<% } %></p>
        <% if (addonTableExists) { %>
        <a href="/admin/addons/store"><button type="button" class="mt-4 border border-neutral-800/20 rounded-xl bg-white hover:bg-neutral-200 dark:hover:bg-neutral-300 text-neutral-800 px-3 py-2 text-sm font-medium shadow-lg transition">Browse Store</button></a>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>
</main>

<script nonce="<%- nonce %>" src="/javascript/admin-addons.js"></script>

<%- include('../../components/footer') %>
