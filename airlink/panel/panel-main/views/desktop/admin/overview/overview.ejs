<%- include('../../components/header', { title: req.translations.adminOverviewTitle || 'About' }) %>

<main class="min-h-screen m-auto">
  <div class="flex min-h-screen">
    <div class="w-60 h-full">
      <%- include('../../components/template') %>
    </div>
    <div id="page-content" class="flex-1 overflow-y-auto pt-16">
      <div class="px-12 pt-6 pb-8">

        <div class="mb-6">
          <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.adminOverviewTitle || 'About' %></h1>
          <p class="text-sm text-neutral-500 mt-0.5"><%= req.translations.adminOverviewText || 'Panel information and credits.' %></p>
        </div>

        <!-- Stats grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
          <a href="/admin/users" class="group rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-4 hover:border-neutral-300 dark:hover:border-white/10 transition-colors">
            <div class="flex items-center justify-between mb-2">
              <p class="text-[10px] text-neutral-500 uppercase tracking-wider"><%= req.translations.users || 'Users' %></p>
              <span class="text-neutral-400 dark:text-neutral-500 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors"><%- icon('arrow-right', { size: 14 }) %></span>
            </div>
            <p class="text-3xl font-bold text-neutral-800 dark:text-white tabular-nums"><%= userCount %></p>
            <p class="text-xs text-neutral-500 mt-1.5"><%= req.translations.totalRegisteredUsers || 'Registered' %></p>
          </a>
          <a href="/admin/servers" class="group rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-4 hover:border-neutral-300 dark:hover:border-white/10 transition-colors">
            <div class="flex items-center justify-between mb-2">
              <p class="text-[10px] text-neutral-500 uppercase tracking-wider"><%= req.translations.instances || 'Servers' %></p>
              <span class="text-neutral-400 dark:text-neutral-500 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors"><%- icon('arrow-right', { size: 14 }) %></span>
            </div>
            <p class="text-3xl font-bold text-neutral-800 dark:text-white tabular-nums"><%= instanceCount %></p>
            <p class="text-xs text-neutral-500 mt-1.5">Active instances</p>
          </a>
          <a href="/admin/nodes" class="group rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-4 hover:border-neutral-300 dark:hover:border-white/10 transition-colors">
            <div class="flex items-center justify-between mb-2">
              <p class="text-[10px] text-neutral-500 uppercase tracking-wider"><%= req.translations.nodes || 'Nodes' %></p>
              <span class="text-neutral-400 dark:text-neutral-500 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors"><%- icon('arrow-right', { size: 14 }) %></span>
            </div>
            <p class="text-3xl font-bold text-neutral-800 dark:text-white tabular-nums"><%= nodeCount %></p>
            <p class="text-xs text-neutral-500 mt-1.5">Connected nodes</p>
          </a>
          <a href="/admin/images" class="group rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 px-4 py-4 hover:border-neutral-300 dark:hover:border-white/10 transition-colors">
            <div class="flex items-center justify-between mb-2">
              <p class="text-[10px] text-neutral-500 uppercase tracking-wider"><%= req.translations.images || 'Images' %></p>
              <span class="text-neutral-400 dark:text-neutral-500 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors"><%- icon('arrow-right', { size: 14 }) %></span>
            </div>
            <p class="text-3xl font-bold text-neutral-800 dark:text-white tabular-nums"><%= imageCount %></p>
            <p class="text-xs text-neutral-500 mt-1.5">Available images</p>
          </a>
        </div>

        <!-- Panel info + update card -->
        <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-5 mb-6">
          <div class="flex items-center justify-between mb-5">
            <div class="flex items-center gap-3">
              <img src="/assets/airlink_logo.png" class="h-10 w-10 rounded-xl shrink-0" alt="Airlink">
              <div>
                <p class="text-sm font-medium text-neutral-800 dark:text-white">Airlink Panel</p>
                <div class="flex items-center gap-2 mt-1">
                  <span class="text-[10px] font-mono px-2 py-0.5 rounded-md bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 text-neutral-600 dark:text-neutral-400">v<span class="current-version"></span></span>
                  <span class="text-[10px] text-neutral-500"><%= process.env.NODE_ENV %></span>
                </div>
              </div>
            </div>
            <div class="flex gap-2">
              <button id="checkUpdateBtn" class="rounded-xl bg-neutral-200 dark:bg-neutral-700/60 hover:bg-neutral-300 dark:hover:bg-neutral-700 text-neutral-700 dark:text-neutral-200 border border-neutral-300 dark:border-white/5 px-3 py-2 text-sm font-medium transition-colors flex items-center gap-1.5">
                <%- icon('refresh-cw', { size: 16, class: 'shrink-0' }) %>
                Check Updates
              </button>
              <button id="performUpdateBtn" class="hidden rounded-xl bg-neutral-200 dark:bg-neutral-700/60 hover:bg-neutral-300 dark:hover:bg-neutral-700 text-neutral-700 dark:text-neutral-200 border border-neutral-300 dark:border-white/5 px-3 py-2 text-sm font-medium transition-colors items-center gap-1.5">
                <%- icon('download', { size: 16, class: 'shrink-0' }) %>
                <%= req.translations.update || 'Update' %>
              </button>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div class="rounded-xl bg-neutral-100 dark:bg-neutral-800/40 border border-neutral-200 dark:border-white/5 p-4">
              <p class="text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-3">API Response Time</p>
              <div class="flex items-center justify-between mb-2">
                <span id="apiLatency" class="text-sm font-mono text-neutral-700 dark:text-neutral-300">-- ms</span>
              </div>
              <div class="w-full bg-neutral-200 dark:bg-neutral-700/40 rounded-full h-1.5">
                <div id="latencyBar" class="bg-neutral-400 dark:bg-neutral-500 h-1.5 rounded-full transition-all duration-300" style="width: 0%"></div>
              </div>
            </div>

            <div class="rounded-xl bg-neutral-100 dark:bg-neutral-800/40 border border-neutral-200 dark:border-white/5 p-4">
              <p class="text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-2">Update Status</p>
              <p class="text-xs text-neutral-500 mb-3"><%= req.translations.sysInfoText %> <span class="text-neutral-700 dark:text-neutral-300 font-medium" id="current-version-inline"></span></p>
              <div id="updateStatus" class="text-sm hidden rounded-lg p-3 bg-neutral-200/60 dark:bg-neutral-800/60"></div>
              <div id="updateInfo" class="mt-3 hidden"></div>
            </div>
          </div>
        </div>

        <!-- Resources -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          <a href="https://discord.gg/BybfXms7JZ" class="group rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4 hover:border-neutral-300 dark:hover:border-white/10 transition-colors">
            <div class="flex items-center gap-2 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-neutral-500 dark:text-neutral-400 shrink-0" viewBox="0 0 127.14 96.36" fill="currentColor">
                <path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z" />
              </svg>
              <p class="text-sm font-medium text-neutral-700 dark:text-neutral-200">Discord</p>
            </div>
            <p class="text-xs text-neutral-500">Community support and discussions</p>
          </a>

          <a href="https://airlinklabs.xyz/" target="_blank" rel="noopener noreferrer" class="group rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4 hover:border-neutral-300 dark:hover:border-white/10 transition-colors">
            <div class="flex items-center gap-2 mb-2">
              <%- icon('book-open', { size: 16, class: 'text-neutral-500 dark:text-neutral-400 shrink-0' }) %>
              <p class="text-sm font-medium text-neutral-700 dark:text-neutral-200">Docs</p>
            </div>
            <p class="text-xs text-neutral-500">Usage and configuration guides</p>
          </a>

          <a href="https://github.com/airlinklabs" class="group rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4 hover:border-neutral-300 dark:hover:border-white/10 transition-colors">
            <div class="flex items-center gap-2 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-neutral-500 dark:text-neutral-400 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
              <p class="text-sm font-medium text-neutral-700 dark:text-neutral-200">GitHub</p>
            </div>
            <p class="text-xs text-neutral-500">Source code and contributions</p>
          </a>

          <a href="https://ko-fi.com/airlinklabs#checkoutModal" class="group rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4 hover:border-neutral-300 dark:hover:border-white/10 transition-colors">
            <div class="flex items-center gap-2 mb-2">
              <%- icon('credit-card', { size: 16, class: 'text-neutral-500 dark:text-neutral-400 shrink-0' }) %>
              <p class="text-sm font-medium text-neutral-700 dark:text-neutral-200">Support</p>
            </div>
            <p class="text-xs text-neutral-500">Fund Airlink development</p>
          </a>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include('../../components/toast') %>
<%- include('../../components/footer') %>

<div id="page-data" style="display:none"
  data-airlink-version="<%= airlinkVersion %>"
  data-running-latest-version="<%= req.translations.runningLatestVersion %>"
></div>

<script nonce="<%- nonce %>" src="/javascript/admin-overview.js"></script>
