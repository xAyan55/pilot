<%- include('../../components/header', { title: 'Console' }) %>
<%- include('../../components/serverFeatures') %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/css/xterm.css" />
<script nonce="<%- nonce %>" src="https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/lib/xterm.js"></script>
<script nonce="<%- nonce %>" src="https://cdn.jsdelivr.net/npm/@xterm/addon-fit@0.10.0/lib/addon-fit.js"></script>
<script nonce="<%- nonce %>" src="https://cdn.jsdelivr.net/npm/@xterm/addon-web-links@0.11.0/lib/addon-web-links.js"></script>
<script nonce="<%- nonce %>" src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.7.0/chart.min.js"></script>

<style>
    canvas {
        position: absolute;
        left: 0;
        top: 0;
        width: 100% !important;
        height: 100% !important;
    }

    #terminal {
        height: 420px;
        background: var(--theme-bg-card, #141414);
    }

    #terminal .xterm {
        padding: 8px;
        height: 100%;
    }

    #terminal .xterm-viewport {
        background: var(--theme-bg-card, #141414) !important;
        border-radius: 0;
    }

    #terminal .xterm-screen {
        background: var(--theme-bg-card, #141414);
    }

    .console-wrap {
        animation: console-appear 0.35s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @keyframes console-appear {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

<main class="h-screen m-auto text-neutral-800 dark:text-white">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <div class="w-60 h-full">
      <%- include('../../components/template') %>
    </div>

    <!-- Content -->
    <div id="page-content" class="flex-1 min-w-0 overflow-y-auto pt-16">
      <!-- Page Header: title + meta left, buttons right -->
      <div class="px-8 pt-4">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <%- include('../../components/serverHeader') %>
            <!-- Server meta: image · node · id -->
            <div class="flex items-center gap-3 mt-1.5 flex-wrap">
              <div class="flex items-center gap-1.5">
                <%- icon('box', { class: 'h-3 w-3 text-neutral-400 shrink-0' }) %>
                <span class="text-[11px] text-neutral-500 dark:text-neutral-400 truncate max-w-[140px]"><%= server.image.name %></span>
              </div>
              <span class="text-neutral-300 dark:text-neutral-600 text-[11px]">·</span>
              <div class="flex items-center gap-1.5">
                <%- icon('server', { class: 'h-3 w-3 text-neutral-400 shrink-0' }) %>
                <span class="text-[11px] text-neutral-500 dark:text-neutral-400 truncate max-w-[100px]"><%= server.node.name %></span>
              </div>
              <span class="text-neutral-300 dark:text-neutral-600 text-[11px]">·</span>
              <div class="flex items-center gap-1.5">
                <%- icon('hash', { class: 'h-3 w-3 text-neutral-400 shrink-0' }) %>
                <span class="text-[11px] font-mono text-neutral-500 dark:text-neutral-400"><%= server.UUID.split('-')[0] %></span>
              </div>
            </div>
          </div>

          <!-- Control buttons -->
          <div class="flex gap-2 shrink-0">
            <button id="startButton" type="button"
              class="rounded-xl bg-emerald-600 hover:bg-emerald-500 text-white px-3 py-2 text-sm font-medium shadow-sm transition <%= server.Suspended ? 'opacity-50 cursor-not-allowed' : '' %>" <%= server.Suspended ? 'disabled' : '' %>>
              <%- icon('play', { class: 'size-4 inline-flex mr-1 text-emerald-100 mb-0.5' }) %>
              <%= req.translations.start %>
            </button>
            <button id="restartButton" type="button"
              class="rounded-xl bg-neutral-800 dark:bg-neutral-600 hover:bg-neutral-700 dark:hover:bg-neutral-500 text-white px-3 py-2 text-sm font-medium shadow-sm transition <%= server.Suspended ? 'opacity-50 cursor-not-allowed' : '' %>" <%= server.Suspended ? 'disabled' : '' %>>
              <%- icon('refresh-cw', { class: 'size-4 inline-flex mr-1 text-white mb-0.5' }) %>
              <%= req.translations.restart %>
            </button>
            <button id="stopButton" type="button"
              class="rounded-xl bg-red-600 hover:bg-red-500 text-white px-3 py-2 text-sm font-medium shadow-sm transition <%= server.Suspended ? 'opacity-50 cursor-not-allowed' : '' %>" <%= server.Suspended ? 'disabled' : '' %>>
              <%- icon('square', { class: 'size-4 inline-flex mr-1 text-red-100 mb-0.5' }) %>
              <%= req.translations.stop %>
            </button>
          </div>
        </div>

        <!-- Server Suspended Warning -->
        <% if (server.Suspended) { %>
        <div class="mt-3 bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 flex items-center gap-3">
          <%- icon('triangle-alert', { class: 'h-5 w-5 shrink-0 text-red-500' }) %>
          <div>
            <p class="text-sm font-medium text-red-500"><%= req.translations.serverSuspended || "This server's been grounded. Reach out to your admin if you think that's a mistake." %></p>
            <p class="text-xs text-red-400"><%= req.translations.serverSuspendedDesc || 'This server has been suspended by an administrator.' %></p>
          </div>
        </div>
        <% } %>

        <!-- Daemon Offline Warning — hidden by default, shown by JS when daemon unreachable -->
        <div id="daemonOfflineWarningRow" class="<% if (typeof serverStatus === 'undefined' || !serverStatus.daemonOffline) { %>hidden<% } %> mt-3">
          <div id="daemonOfflineWarning" class="bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 flex items-center gap-3">
            <%- icon('triangle-alert', { class: 'h-5 w-5 shrink-0 text-red-500' }) %>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-red-500"><%= (typeof serverStatus !== 'undefined' && serverStatus.error) ? serverStatus.error : 'This node isn\'t talking to us right now. Check the daemon — it might just need a nudge.' %></p>
            </div>
            <button onclick="window.location.reload()" class="shrink-0 px-3 py-1.5 bg-red-600 hover:bg-red-500 text-white text-xs font-medium rounded-lg transition">
              Retry Connection
            </button>
          </div>
        </div>
      </div>



      <%- include('../../components/serverTemplate') %>

      <%- include('../../components/installHeader') %>

      <div id="server-page-body" class="flex flex-col lg:flex-row px-8 mt-4">

<!-- Left side: Console -->
<div class="w-full lg:w-2/3 lg:pr-5 flex flex-col min-w-0">
    <div class="flex flex-col rounded-xl overflow-hidden border border-neutral-800 shadow-lg flex-1 console-wrap">
        <!-- Console chrome bar -->
        <div class="flex items-center gap-2 px-3 py-2 bg-[#1c1c1c] border-b border-neutral-800 shrink-0">
            <span class="text-[11px] font-medium text-neutral-600 select-none tracking-wide">console</span>
        </div>
        <div class="bg-[#141414] flex-1 relative">
            <div id="terminal"></div>
        </div>
    </div>
    <div class="relative">
        <div class="relative">
            <input id="input" type="text" autocomplete="off" placeholder="<%= req.translations.typeACommand || 'Type a command...' %>"
                class="w-full px-4 py-3 bg-neutral-200 dark:bg-neutral-600/20 text-neutral-800 dark:text-white rounded-b-xl text-sm border-t border-neutral-600/20 focus:ring-1 focus:ring-neutral-500/50 dark:focus:ring-neutral-100/20 focus:border-transparent placeholder:font-medium placeholder:text-neutral-600 dark:placeholder:text-neutral-500"
                style="background: transparent; position: relative; z-index: 1;">
            <div id="ghost-text-bg" class="absolute inset-0 px-4 py-3 text-sm pointer-events-none rounded-b-xl overflow-hidden bg-neutral-200 dark:bg-neutral-600/20 border-t border-neutral-600/20" style="z-index: 0;">
                <span id="ghost-typed" class="invisible"></span><span id="ghost-suggestion" class="text-neutral-400 dark:text-neutral-500"></span>
            </div>
        </div>
    </div>
</div>

        <!-- Right side: Stats Cards -->
        <div class="w-full lg:w-1/3 mt-4 lg:mt-0 space-y-4 flex flex-col">

            <!-- IP Address Card -->
            <div class="stats-card overflow-hidden bg-white dark:bg-neutral-800/50 backdrop-blur-sm border border-neutral-200 dark:border-neutral-700/30 rounded-xl px-4 py-4 shadow-sm hover:shadow-md transition-shadow duration-200 hover:bg-neutral-50 dark:hover:bg-neutral-700/30 group flex-1" style="--i:0">
                <div class="relative z-10 flex items-start justify-between gap-2">
                    <div class="min-w-0">
                        <h2 class="text-sm font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.addressIP %>:</h2>
                        <p id="server-ip-text" class="mt-1 text-sm font-medium font-mono tracking-tight text-neutral-800 dark:text-white break-all"><%= server.node.address %>:<%= server.Ports ? JSON.parse(server.Ports).filter(Port => Port.primary).map(Port => Port.externalPort || String(Port.Port || '').split(':')[0]).pop() : '' %></p>
                    </div>
                    <button id="copy-ip-btn" onclick="copyServerIP()" title="Copy" class="shrink-0 mt-1 rounded-lg p-1.5 bg-neutral-100 dark:bg-neutral-700/50 hover:bg-neutral-200 dark:hover:bg-neutral-600/50 transition-colors">
                        <span id="copy-icon"><%- icon('copy', { class: 'h-3.5 w-3.5 text-neutral-500' }) %></span>
                        <span id="check-icon" class="hidden"><%- icon('check', { class: 'h-3.5 w-3.5 text-emerald-500', strokeWidth: 2.5 }) %></span>
                    </button>
                </div>
            </div>

            <!-- Status Card -->
            <div class="stats-card overflow-hidden bg-white dark:bg-neutral-800/50 backdrop-blur-sm border border-neutral-200 dark:border-neutral-700/30 rounded-xl px-4 py-4 shadow-sm hover:shadow-md transition-shadow duration-200 hover:bg-neutral-50 dark:hover:bg-neutral-700/30 group flex-1" style="--i:1">
                <canvas id="statusChart" class="absolute inset-0 w-full h-full"></canvas>
                <div class="relative z-10">
                  <h2 class="text-sm font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.Status %>:</h2>
                  <p id="status" class="mt-1 text-lg font-medium tracking-tight text-neutral-800 dark:text-white leading-snug">-</p>
                  <p id="status-msg" class="text-xs font-medium mt-0.5 leading-snug transition-all duration-300 opacity-0 translate-y-1 pointer-events-none"></p>
                </div>
              </div>

            <!-- RAM Usage Card -->
            <div class="stats-card overflow-hidden bg-white dark:bg-neutral-800/50 backdrop-blur-sm border border-neutral-200 dark:border-neutral-700/30 rounded-xl px-4 py-4 shadow-sm hover:shadow-md transition-shadow duration-200 hover:bg-neutral-50 dark:hover:bg-neutral-700/30 group flex-1" style="--i:2">
                <canvas id="ramChart" class="absolute inset-0 w-full h-full"></canvas>
                <div class="relative z-10">
                    <h2 class="text-sm font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.ramUsage %>:</h2>
                    <p id="ramUsage" class="mt-1 text-lg font-medium tracking-tight text-neutral-800 dark:text-white">0% (0 MB / 0 MB)</p>
                </div>
            </div>

            <!-- CPU Usage Card -->
            <div class="stats-card overflow-hidden bg-white dark:bg-neutral-800/50 backdrop-blur-sm border border-neutral-200 dark:border-neutral-700/30 rounded-xl px-4 py-4 shadow-sm hover:shadow-md transition-shadow duration-200 hover:bg-neutral-50 dark:hover:bg-neutral-700/30 group flex-1" style="--i:3">
                <canvas id="cpuChart" class="absolute inset-0 w-full h-full"></canvas>
                <div class="relative z-10">
                    <h2 class="text-sm font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.cpuUsage %>:</h2>
                    <p id="cpuUsage" class="mt-1 text-lg font-medium tracking-tight text-neutral-800 dark:text-white">0%</p>
                </div>
            </div>

            <!-- Disk Usage Card -->
            <div class="stats-card overflow-hidden bg-white dark:bg-neutral-800/50 backdrop-blur-sm border border-neutral-200 dark:border-neutral-700/30 rounded-xl px-4 py-4 shadow-sm hover:shadow-md transition-shadow duration-200 hover:bg-neutral-50 dark:hover:bg-neutral-700/30 group flex-1" style="--i:4">
                <canvas id="diskChart" class="absolute inset-0 w-full h-full hidden"></canvas>
                <div class="relative z-10">
                    <h2 class="text-sm font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.diskUsage %>:</h2>
                    <p id="diskUsage" class="mt-1 text-lg font-medium tracking-tight text-neutral-800 dark:text-white">-</p>
                </div>
            </div>
        </div>

      </div>

    </div>
  </div>
</main>

<%- include('../../components/toast') %>

