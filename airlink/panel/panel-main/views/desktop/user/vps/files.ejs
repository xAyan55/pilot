<%- include('../components/header', { title: 'File Manager' }) %>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <div class="w-60 h-full"><%- include('../components/template') %></div>

    <div id="page-content" class="flex-1 overflow-y-auto pt-16">
      <div class="px-12 pt-6 pb-8">
        
        <!-- Server Title Header -->
        <div class="flex items-center justify-between mb-6">
          <div>
            <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= vps.name %></h1>
            <p class="text-sm text-neutral-500 mt-0.5"><%= vps.os %> • Private IP: <%= vps.ip || 'N/A' %></p>
          </div>
          <div class="flex items-center gap-2">
            <button onclick="createFolder()" class="px-3.5 py-2 rounded-xl text-xs font-semibold bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 hover:bg-neutral-700 dark:hover:bg-neutral-200 transition flex items-center gap-1.5 shadow-sm">
              <%- icon('folder-plus', { class: 'h-4 w-4' }) %>
              New Folder
            </button>
          </div>
        </div>

        <!-- Inner Navigation Menu -->
        <div class="flex items-center gap-2 border-b border-neutral-200 dark:border-white/5 pb-3 mb-6">
          <a href="/vps/console/<%= vps.UUID %>" class="px-3.5 py-2 rounded-xl text-xs font-semibold text-neutral-500 hover:text-neutral-800 dark:hover:text-white transition">Console</a>
          <a href="/vps/files/<%= vps.UUID %>" class="px-3.5 py-2 rounded-xl text-xs font-semibold menu-btn-active text-neutral-800 dark:text-white transition">Files</a>
          <a href="/vps/backups/<%= vps.UUID %>" class="px-3.5 py-2 rounded-xl text-xs font-semibold text-neutral-500 hover:text-neutral-800 dark:hover:text-white transition">Backups</a>
          <a href="/vps/network/<%= vps.UUID %>" class="px-3.5 py-2 rounded-xl text-xs font-semibold text-neutral-500 hover:text-neutral-800 dark:hover:text-white transition">Firewall</a>
          <a href="/vps/settings/<%= vps.UUID %>" class="px-3.5 py-2 rounded-xl text-xs font-semibold text-neutral-500 hover:text-neutral-800 dark:hover:text-white transition">Settings</a>
        </div>

        <!-- Path Breadcrumb -->
        <div class="flex items-center gap-1 text-xs text-neutral-500 mb-4 bg-neutral-50 dark:bg-white/[0.02] border border-neutral-200 dark:border-white/5 p-3 rounded-xl">
          <%- icon('home', { class: 'h-3.5 w-3.5' }) %>
          <span class="ml-1 font-mono text-neutral-700 dark:text-neutral-300"><%= currentPath %></span>
        </div>

        <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
        <div class="rounded-xl bg-red-50 dark:bg-red-800/10 border border-red-200 dark:border-red-500/20 px-4 py-3 mb-5">
          <p class="text-sm font-medium text-red-700 dark:text-red-400">Error</p>
          <p class="text-xs text-red-600 dark:text-red-400/60 mt-0.5"><%= errorMessage.message %></p>
        </div>
        <% } %>

        <!-- File List Table -->
        <div class="bg-white dark:bg-white/[0.03] border border-neutral-200 dark:border-white/5 rounded-2xl overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-xs">
              <thead class="bg-neutral-50 dark:bg-white/[0.02] border-b border-neutral-200 dark:border-white/5 text-neutral-500 uppercase tracking-wider font-semibold">
                <tr>
                  <th class="py-3 px-5">Name</th>
                  <th class="py-3 px-4">Size</th>
                  <th class="py-3 px-4">Last Modified</th>
                  <th class="py-3 px-4 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-100 dark:divide-white/5 text-neutral-700 dark:text-neutral-300 font-medium">
                <!-- Parent directory folder if not root -->
                <% if (currentPath !== '/' && currentPath !== '') { 
                     const parentPath = currentPath.substring(0, currentPath.lastIndexOf('/')) || '/';
                %>
                <tr class="hover:bg-neutral-50 dark:hover:bg-white/[0.02]">
                  <td class="py-3 px-5 flex items-center gap-2">
                    <%- icon('folder', { class: 'h-4 w-4 text-blue-500' }) %>
                    <a href="/vps/files/<%= vps.UUID %>?path=<%= encodeURIComponent(parentPath) %>" class="text-blue-500 hover:underline font-mono">..</a>
                  </td>
                  <td class="py-3 px-4">—</td>
                  <td class="py-3 px-4">—</td>
                  <td class="py-3 px-4 text-right">—</td>
                </tr>
                <% } %>

                <% files.forEach(file => { 
                     const nextPath = currentPath === '/' ? `/${file.name}` : `${currentPath}/${file.name}`;
                %>
                <tr class="hover:bg-neutral-50 dark:hover:bg-white/[0.02]">
                  <td class="py-3 px-5 flex items-center gap-2">
                    <%- icon(file.type === 'directory' ? 'folder' : 'file', { class: file.type === 'directory' ? 'h-4 w-4 text-blue-500' : 'h-4 w-4 text-neutral-400' }) %>
                    <% if (file.type === 'directory') { %>
                      <a href="/vps/files/<%= vps.UUID %>?path=<%= encodeURIComponent(nextPath) %>" class="hover:text-blue-500 hover:underline font-mono"><%= file.name %></a>
                    <% } else { %>
                      <span class="font-mono"><%= file.name %></span>
                    <% } %>
                  </td>
                  <td class="py-3 px-4 font-mono">
                    <%= file.type === 'directory' ? '—' : (file.size >= 1048576 ? (file.size/1048576).toFixed(1) + ' MB' : (file.size/1024).toFixed(0) + ' KB') %>
                  </td>
                  <td class="py-3 px-4 text-neutral-400">
                    <%= new Date(file.modified * 1000).toLocaleString() %>
                  </td>
                  <td class="py-3 px-4 text-right">
                    <button onclick="deleteFile('<%= nextPath %>')" class="p-1 hover:bg-red-50 dark:hover:bg-red-500/10 text-red-500 rounded transition" title="Delete">
                      <%- icon('trash', { class: 'h-4 w-4' }) %>
                    </button>
                  </td>
                </tr>
                <% }); %>

                <% if (files.length === 0) { %>
                <tr>
                  <td colspan="4" class="py-8 text-center text-neutral-400">
                    This directory is empty.
                  </td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<script>
  async function createFolder() {
    const folderName = prompt('Enter new folder name:');
    if (!folderName) return;
    const path = '<%= currentPath %>' === '/' ? `/${folderName}` : `<%= currentPath %>/${folderName}`;
    try {
      const response = await fetch('/api/vps/<%= vps.UUID %>/files/mkdir', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ path })
      });
      const data = await response.json();
      if (data.success) {
        window.location.reload();
      } else {
        alert('Failed to create folder: ' + data.error);
      }
    } catch {
      alert('Network error while creating folder');
    }
  }

  async function deleteFile(path) {
    if (!confirm('Are you sure you want to delete this item?')) return;
    try {
      const response = await fetch('/api/vps/<%= vps.UUID %>/files/delete', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ path })
      });
      const data = await response.json();
      if (data.success) {
        window.location.reload();
      } else {
        alert('Failed to delete item: ' + data.error);
      }
    } catch {
      alert('Network error while deleting item');
    }
  }
</script>

<%- include('../components/footer') %>
