<%- include('../components/header', { title: 'VPS Console' }) %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/css/xterm.css" />
<script src="https://cdn.jsdelivr.net/npm/@xterm/xterm@5.5.0/lib/xterm.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@xterm/addon-fit@0.10.0/lib/addon-fit.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@xterm/addon-web-links@0.11.0/lib/addon-web-links.js"></script>

<style>
  ::-webkit-scrollbar { display: none; }
  #terminal {
    background: #09090b;
    padding: 12px;
    border-radius: 16px;
  }
  #terminal .xterm {
    padding: 10px;
  }
  #terminal .xterm-viewport {
    background-color: #09090b !important;
    border-radius: 16px;
  }
  #terminal .xterm-screen {
    background-color: #09090b !important;
  }
  .menu-btn-active {
    background: var(--theme-bg-active-nav, rgba(255,255,255,0.05));
    color: white;
  }
</style>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <div class="w-60 h-full"><%- include('../components/template') %></div>

    <div id="page-content" class="flex-1 overflow-y-auto pt-16">
      <div class="px-12 pt-6 pb-8">
        
        <!-- Server Title Header -->
        <div class="flex items-center justify-between mb-6">
          <div>
            <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= vps.name %></h1>
            <p class="text-sm text-neutral-500 mt-0.5"><%= vps.os %> • Private IP: <%= vps.ip || 'N/A' %></p>
          </div>
          <div class="flex items-center gap-2">
            <button onclick="powerAction('start')" class="px-3.5 py-2 rounded-xl text-xs font-semibold bg-emerald-600 hover:bg-emerald-500 text-white transition flex items-center gap-1.5 shadow-sm">
              <span class="h-2 w-2 rounded-full bg-white"></span>
              Start
            </button>
            <button onclick="powerAction('stop')" class="px-3.5 py-2 rounded-xl text-xs font-semibold bg-neutral-200 hover:bg-neutral-300 dark:bg-white/5 dark:hover:bg-white/10 text-neutral-800 dark:text-neutral-200 transition flex items-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-neutral-600 dark:bg-neutral-400"></span>
              Stop
            </button>
            <button onclick="powerAction('restart')" class="px-3.5 py-2 rounded-xl text-xs font-semibold bg-neutral-800 hover:bg-neutral-700 dark:bg-white dark:hover:bg-neutral-200 text-white dark:text-neutral-900 transition flex items-center gap-1.5 shadow-sm">
              Restart
            </button>
          </div>
        </div>

        <!-- Inner Navigation Menu -->
        <div class="flex items-center gap-2 border-b border-neutral-200 dark:border-white/5 pb-3 mb-6">
          <a href="/vps/console/<%= vps.UUID %>" class="px-3.5 py-2 rounded-xl text-xs font-semibold menu-btn-active text-neutral-800 dark:text-white transition">Console</a>
          <a href="/vps/files/<%= vps.UUID %>" class="px-3.5 py-2 rounded-xl text-xs font-semibold text-neutral-500 hover:text-neutral-800 dark:hover:text-white transition">Files</a>
          <a href="/vps/backups/<%= vps.UUID %>" class="px-3.5 py-2 rounded-xl text-xs font-semibold text-neutral-500 hover:text-neutral-800 dark:hover:text-white transition">Backups</a>
          <a href="/vps/network/<%= vps.UUID %>" class="px-3.5 py-2 rounded-xl text-xs font-semibold text-neutral-500 hover:text-neutral-800 dark:hover:text-white transition">Firewall</a>
          <a href="/vps/settings/<%= vps.UUID %>" class="px-3.5 py-2 rounded-xl text-xs font-semibold text-neutral-500 hover:text-neutral-800 dark:hover:text-white transition">Settings</a>
        </div>

        <!-- Terminal Container -->
        <div class="w-full bg-[#09090b] rounded-2xl border border-neutral-200 dark:border-white/5 overflow-hidden">
          <div id="terminal" class="w-full min-h-[450px]"></div>
        </div>

      </div>
    </div>
  </div>
</main>

<script>
  let term;
  let fitAddon;
  let socket;

  function initTerminal() {
    term = new Terminal({
      cursorBlink: true,
      fontFamily: 'JetBrains Mono, Fira Code, Courier New, monospace',
      fontSize: 13,
      theme: {
        background: '#09090b',
        foreground: '#f4f4f5',
        cursor: '#f4f4f5',
        selectionBackground: 'rgba(255, 255, 255, 0.15)',
        black: '#09090b',
        red: '#f43f5e',
        green: '#10b981',
        yellow: '#f59e0b',
        blue: '#3b82f6',
        magenta: '#d946ef',
        cyan: '#06b6d4',
        white: '#f4f4f5'
      }
    });

    fitAddon = new FitAddon.FitAddon();
    term.loadAddon(fitAddon);
    term.loadAddon(new WebLinksAddon.WebLinksAddon());

    term.open(document.getElementById('terminal'));
    fitAddon.fit();

    term.write('Connecting to container console...\r\n');

    connectWebSocket();

    window.addEventListener('resize', () => {
      fitAddon.fit();
    });
  }

  function connectWebSocket() {
    const protocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
    const wsUrl = `${protocol}//${location.host}/vps/ws/<%= vps.UUID %>`;
    
    socket = new WebSocket(wsUrl);
    socket.binaryType = 'arraybuffer';

    socket.onopen = () => {
      term.write('\x1b[32m[Connected]\x1b[0m\r\n');
    };

    socket.onmessage = (event) => {
      if (event.data instanceof ArrayBuffer) {
        term.write(new Uint8Array(event.data));
      } else {
        term.write(event.data);
      }
    };

    socket.onclose = () => {
      term.write('\r\n\x1b[31;1m[Console connection closed]\x1b[0m\r\n');
    };

    term.onData((data) => {
      if (socket && socket.readyState === WebSocket.OPEN) {
        socket.send(data);
      }
    });
  }

  async function powerAction(action) {
    try {
      const response = await fetch('/api/vps/<%= vps.UUID %>/power', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': '<%= req.session.csrfToken || "" %>'
        },
        body: JSON.stringify({ action })
      });
      const data = await response.json();
      if (data.success) {
        term.write(`\r\n\x1b[33;1m[Power action '${action}' initiated successfully]\x1b[0m\r\n`);
      } else {
        term.write(`\r\n\x1b[31;1m[Failed: ${data.error || 'Unknown error'}]\x1b[0m\r\n`);
      }
    } catch (err) {
      term.write(`\r\n\x1b[31;1m[Network error during power action]\x1b[0m\r\n`);
    }
  }

  document.addEventListener('DOMContentLoaded', initTerminal);
</script>

<%- include('../components/footer') %>
