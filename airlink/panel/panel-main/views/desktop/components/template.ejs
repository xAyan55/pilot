<!-- Sidebar -->
<div id="pc-sidebar" class="sidebar transition hidden lg:fixed lg:inset-y-0 lg:z-50 lg:flex lg:w-56 lg:flex-col left-0">
  <div id="pc-sidebar2" class="flex flex-col h-full bg-white/8 dark:bg-[#141414]/8 backdrop-blur-xl border-r border-neutral-200/30 dark:border-white/5">

    <!-- Static top: logo -->
    <div class="pl-6 pt-4 pb-4 flex min-w-0 shrink-0">
      <a href="/" class="flex items-center min-w-0">
        <img src="<%= settings.logo.startsWith('/') ? settings.logo : '/' + settings.logo %>" alt="Logo" class="logo-bg bg-neutral-950/90 p-1 dark:bg-transparent h-10 w-10 rounded-xl mr-3 shrink-0 inline-flex">
        <h1 class="text-neutral-700 dark:text-white font-medium tracking-tight text-lg truncate min-w-0"><%= settings.title || 'Airlink' %></h1>
      </a>
    </div>

    <!-- Static: user info — clicking goes to account page -->
    <a href="/account" id="sidebar-account-link" class="sidebar-special-link flex items-center space-x-4 py-4 px-4 border-y border-neutral-800/10 dark:border-white/5 shrink-0 hover:bg-neutral-100 dark:hover:bg-white/[0.05] transition-colors group">
      <img class="h-8 w-8 rounded-xl border border-neutral-700/10 shrink-0" src="<%= user.avatar ? user.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(user.username) %>" alt="User avatar">
      <div class="min-w-0">
        <p class="text-sm font-medium text-neutral-700 dark:text-white truncate group-hover:text-neutral-900 dark:group-hover:text-white transition-colors">
          <span id="sidebar-username"><%= user.username %></span>
          <span class="text-xs text-neutral-500">
            <sup class="mt-1">#<%= String(user.id).padStart(4, '0') %></sup>
          </span>
        </p>
        <p id="sidebar-description" class="text-xs text-neutral-600 dark:text-neutral-400 truncate"><%= user.description %></p>
      </div>
    </a>

    <!-- Scrollable nav -->
    <nav class="flex-1 overflow-y-auto">
      <ul role="list" class="py-2">
        <li>
          <ul role="list" class="-mx-2 space-y-1 relative">
            <div id="active-background" class="ml-1.5 absolute left-2 w-[calc(97%-1.5rem)] h-9 transition-none duration-0 z-[-1] bg-neutral-200 border border-neutral-300 dark:bg-white/5 dark:border-neutral-300/5 rounded-xl opacity-0"></div>
            <%
            const sidebarItems = regularMenuItems || (global.uiComponentStore ? global.uiComponentStore.getSidebarItems(undefined, false) : []);
            if (!sidebarItems || sidebarItems.length === 0) {
            %>
              <li class="nav-item">
                <a href="/" class="nav-link mt-1 text-neutral-600 hover:text-neutral-950 dark:text-neutral-400 dark:hover:text-white px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal transition-all duration-200" data-search="container instances servers" data-subterm="jegli:/server/servername" data-match-prefix="/server">
                  <%- icon('layout-dashboard', { class: 'w-5 h-5 mt-0.5' }) %>
                  <span><%= req.translations.navServers || 'Servers' %></span>
                </a>
              </li>
            <% } else {
              sidebarItems.forEach(item => {
            %>
              <li class="nav-item">
                <a href="<%= item.url %>" class="nav-link mt-1 text-neutral-600 hover:text-neutral-950 dark:text-neutral-400 dark:hover:text-white px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal transition-all duration-200"<% if (item.matchPrefix) { %> data-match-prefix="<%= item.matchPrefix %>"<% } %>>
                  <%- item.icon %>
                  <span><%= item.label %></span>
                </a>
              </li>
            <% }); } %>

            <% if (user.isAdmin === true) { %>
              <p class="pl-8 text-neutral-600 dark:text-neutral-400 text-xs font-medium pt-6 pb-2"><span><%= req.translations.navAdminPanel || 'Admin Panel' %></span></p>
              <li>
                <a href="/admin/overview" searchdata="admin overview control" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <%- icon('layout-grid', { class: 'w-5 mt-0.5 h-5', strokeWidth: 1.5 }) %>
                  <span><%= req.translations.navOverview || 'Overview' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/settings" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <%- icon('settings', { class: 'w-5 mt-0.5 h-5', strokeWidth: 1.5 }) %>
                  <span><%= req.translations.navSettings || 'Settings' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/servers" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <%- icon('server', { class: 'w-5 mt-0.5 h-5', strokeWidth: 1.5 }) %>
                  <span><%= req.translations.navServers || 'Servers' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/users" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <%- icon('users', { class: 'w-5 mt-0.5 h-5', strokeWidth: 1.5 }) %>
                  <span><%= req.translations.navUsers || 'Users' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/nodes" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <%- icon('network', { class: 'w-5 mt-0.5 h-5', strokeWidth: 1.5 }) %>
                  <span><%= req.translations.navNodes || 'Nodes' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/images" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <%- icon('box', { class: 'w-5 mt-0.5 h-5', strokeWidth: 1.5 }) %>
                  <span><%= req.translations.navImages || 'Images' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/addons" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <%- icon('puzzle', { class: 'w-5 mt-0.5 h-5', strokeWidth: 1.5 }) %>
                  <span><%= req.translations.navAddons || 'Addons' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/airlink-cloud" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <%- icon('cloud', { class: 'w-5 mt-0.5 h-5', strokeWidth: 1.5 }) %>
                  <span><%= req.translations.navAirlinkCloud || 'Airlink Cloud' %></span>
                </a>
              </li>
              <li>
                <a href="/admin/apikeys" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <%- icon('key', { class: 'w-5 mt-0.5 h-5', strokeWidth: 1.5 }) %>
                  <span><%= req.translations.navApiKeys || 'API Keys' %></span>
                </a>
              </li>
              <% if (adminMenuItems && adminMenuItems.length > 0) {
                adminMenuItems.forEach(item => {
              %>
              <li>
                <a href="<%= item.url %>" class="transition nav-link mt-1 text-neutral-600 dark:text-neutral-400 px-4 mx-4 group flex gap-x-3 py-1.5 rounded-xl text-sm leading-6 font-normal">
                  <%- item.icon %>
                  <span><%= item.label %></span>
                </a>
              </li>
              <% }); } %>
            <% } %>
          </ul>
        </li>
      </ul>
    </nav>

    <!-- Static bottom: logout -->
    <div class="shrink-0 border-t border-neutral-800/10 dark:border-white/5">
      <a href="/logout" id="sidebar-logout-link" class="sidebar-special-link group flex gap-x-3 pl-6 py-4 text-sm font-medium leading-6 text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-500/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-red-500 transition-colors duration-200">
        <%- icon('log-out', { class: 'w-5 h-5 mt-0.5 shrink-0', strokeWidth: 1.5 }) %>
        <span><%= req.translations.navLogout || 'Logout' %></span>
      </a>
    </div>

  </div>
</div>

<script nonce="<%- nonce %>">
(function () {
  var wsProtocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
  var ws = new WebSocket(wsProtocol + '//' + window.location.host + '/online-check');
  ws.addEventListener('error', function () {});

  // Highlight account/logout when on those pages
  function markSpecialLinks(path) {
    var account = document.getElementById('sidebar-account-link');
    var logout  = document.getElementById('sidebar-logout-link');
    var isDark  = document.documentElement.classList.contains('dark');
    if (account) {
      var onAccount = path === '/account' || path.startsWith('/account/');
      account.style.background = onAccount
        ? (isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)')
        : '';
    }
    if (logout) {
      logout.style.background = '';
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    markSpecialLinks(window.location.pathname);
  });
  document.addEventListener('al:navigated', function () {
    markSpecialLinks(window.location.pathname);
  });
})();
</script>

<div id="colcont" class="lg:pl-56">
  <div class="fixed top-0 left-0 lg:left-56 right-0 z-40 flex h-16 shrink-0 items-center gap-x-4 bg-white/8 dark:bg-[#141414]/8 backdrop-blur-xl border-b border-neutral-200/30 dark:border-white/5 px-4 sm:gap-x-6 sm:px-4 lg:px-4">
    <div class="flex flex-1 gap-x-4 self-stretch lg:gap-x-6">
      <div class="relative flex flex-1 flex-col">

        <div class="lg:-ml-2 flex items-center w-fit mt-3.5 px-4 py-2 h-10 rounded-xl border border-neutral-300 dark:border-white/5 active:scale-100 duration-200 hover:border-neutral-400 dark:hover:border-neutral-300/10 bg-transparent text-neutral-800 dark:text-white" role="search">
          <%- icon('search', { class: 'h-5 w-5 text-neutral-400' }) %>
          <input id="searchInput"
            class="bg-transparent border-transparent ml-2 focus-visible:ring-transparent border-none ring-transparent sm:text-sm placeholder:text-zinc-500 text-neutral-700 dark:text-neutral-300 focus-visible:outline-none"
            placeholder="<%= req.translations.navSearch || 'Search' %>"
            type="search"
            role="combobox"
            aria-autocomplete="list"
            aria-expanded="false"
            aria-controls="searchResults"
            aria-activedescendant=""
            aria-label="<%= req.translations.navSearch || 'Search' %>"
            name="search"
            autocomplete="off"
            onfocus="showSearchResults()">
          <div aria-hidden="true" class="ml-2 px-1 py-0.5 text-[10px] w-[55px] font-medium text-neutral-700 dark:text-neutral-400 bg-neutral-200 dark:bg-neutral-800 rounded-md border border-neutral-300 dark:border-neutral-700
            bg-[linear-gradient(45deg,transparent_25%,rgba(68,68,68,.2)_50%,transparent_75%,transparent_100%)]
            bg-[length:250%_250%,100%_100%] bg-[position:-100%_0,0_0] bg-no-repeat transition-ease-out
            hover:bg-[position:200%_0,0_0] hover:duration-[2s]">
            CTRL + K
          </div>
        </div>

        <div id="searchResults" role="listbox" aria-label="Search results" class="absolute bg-neutral-50 dark:bg-neutral-900 w-[19.5rem] rounded-xl shadow-2xl shadow-neutral-200/80 dark:shadow-black/40 hidden mt-20 px-2 pb-2 border border-neutral-200 dark:border-neutral-700/60">
        </div>
      </div>

      <script nonce="<%- nonce %>">
        document.addEventListener('keydown', function(event) {
          if (event.ctrlKey && event.key === 'k') {
            event.preventDefault();
            document.getElementById('searchInput').focus();
          }
        });

        function showSearchResults() {
          document.getElementById('searchResults').classList.remove('hidden');
          document.getElementById('searchInput').setAttribute('aria-expanded', 'true');
        }

        document.getElementById('searchInput').addEventListener('focus', showSearchResults);

        document.addEventListener('click', function(event) {
          var searchInput = document.getElementById('searchInput');
          var searchResults = document.getElementById('searchResults');
          if (!searchInput.contains(event.target) && !searchResults.contains(event.target)) {
            searchResults.classList.add('hidden');
            searchInput.setAttribute('aria-expanded', 'false');
            searchInput.setAttribute('aria-activedescendant', '');
          }
        });
      </script>
      <script nonce="<%- nonce %>" src="/javascript/search.js"></script>
    </div>
  </div>
</div>
<script nonce="<%- nonce %>">
(function () {
  var ov = document.getElementById('pl-overlay');
  if (!ov) return;
  ov.style.left   = '224px';
  ov.style.top    = '64px';
  ov.style.right  = '0';
  ov.style.bottom = '0';
  ov.style.display = 'flex';
})();
</script>
