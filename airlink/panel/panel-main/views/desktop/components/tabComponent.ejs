<!-- Reusable Tab Component -->
<!-- Usage: include('../components/tabComponent', { tabs: tabsArray, activeTab: 'tabId' }) -->

<% if (typeof tabs !== 'undefined' && tabs && tabs.length > 0) { %>
<div class="tab-bar bg-neutral-100 dark:bg-white/5 border border-neutral-200 dark:border-neutral-800/20 rounded-xl p-1 inline-flex">
  <% tabs.forEach(function(tab) { %>
    <button
      id="tab-<%= tab.id %>"
      class="tab-button flex items-center px-4 py-2 text-sm font-medium rounded-lg transition-all duration-200<% if (tab.id === activeTab) { %> tab-button--active<% } %>"
      onclick="<% if (tab.onclick) { %><%- tab.onclick %><% } else { %>switchTab('<%- tab.id %>')<% } %>"<% if (tab.disabled) { %> disabled<% } %>
    >
      <% if (tab.icon) { %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 mr-2">
          <path stroke-linecap="round" stroke-linejoin="round" d="<%- tab.icon %>" />
        </svg>
      <% } %>
      <%- tab.label %>
    </button>
  <% }); %>
</div>

<style>
.tab-button {
  color: var(--theme-text-muted, #737373);
}
.tab-button:hover {
  color: var(--theme-text-strong, #171717);
  background-color: var(--theme-bg-active-nav, rgba(0, 0, 0, 0.05));
}
.tab-button--active {
  background-color: var(--theme-bg-input, #ffffff);
  color: var(--theme-text-strong, #171717);
  box-shadow: 0 1px 3px var(--theme-border-subtle, rgba(0,0,0,0.1));
}
.tab-button--active:hover {
  background-color: var(--theme-bg-input, #ffffff);
  color: var(--theme-text-strong, #171717);
}
.dark .tab-button {
  color: var(--theme-text, #a3a3a3);
}
.dark .tab-button:hover {
  color: var(--theme-text-strong, #ffffff);
  background-color: var(--theme-bg-hover, rgba(255, 255, 255, 0.08));
}
.dark .tab-button--active {
  background-color: var(--theme-bg-active-nav, rgba(255, 255, 255, 0.18));
  color: var(--theme-text-strong, #ffffff);
  box-shadow: none;
}
.dark .tab-button--active:hover {
  background-color: var(--theme-bg-active-nav, rgba(255, 255, 255, 0.18));
}
</style>
<% } %>