
<button onclick="openSftpModal()" type="button" aria-label="Open SFTP access"
  class="border border-neutral-800/20 block rounded-xl bg-white hover:bg-neutral-200 dark:hover:bg-neutral-300 text-neutral-800 px-3 py-2 text-center text-sm font-medium shadow-lg transition duration-300 focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
  <%- icon('lock', { class: 'size-4 inline-flex mr-1 text-neutral-800 mb-0.5' }) %>
  SFTP
</button>


<div id="sftpModal" class="fixed inset-0 z-50 hidden items-center justify-center">

  
  <div onclick="closeSftpModal()" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  
  <div class="al-sftp-panel relative bg-white dark:bg-[#1c1c1c] border border-neutral-200 dark:border-white/5 rounded-2xl shadow-xl w-full max-w-md mx-4">

    
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-200 dark:border-white/5">
      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-neutral-100 dark:bg-white/5">
          <%- icon('lock', { class: 'size-4 text-neutral-500 dark:text-neutral-300' }) %>
        </div>
        <div>
          <h2 class="text-sm font-semibold text-neutral-800 dark:text-white leading-none">SFTP Access</h2>
          <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5">Connect using any SFTP client</p>
        </div>
      </div>
      <button onclick="closeSftpModal()" aria-label="Close SFTP modal" class="flex items-center justify-center w-7 h-7 rounded-lg text-neutral-400 hover:text-white hover:bg-white/10 transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
        <%- icon('x', { class: 'size-4' }) %>
      </button>
    </div>

    
    <div id="sftpLoading" class="flex items-center gap-3 px-5 py-8">
      <span class="animate-spin size-4 text-neutral-500 shrink-0"><%- icon('loader', { class: 'size-4' }) %></span>
      <span class="text-sm text-neutral-500 dark:text-neutral-400">Fetching your keys…</span>
    </div>

    
    <div id="sftpError" class="hidden px-5 py-4">
      <div class="flex items-start gap-3 p-3 rounded-lg bg-red-500/10 border border-red-500/20 mb-4">
        <%- icon('triangle-alert', { class: 'size-4 text-red-400 shrink-0 mt-0.5' }) %>
        <div>
          <p class="text-xs font-medium text-red-400">Couldn't load credentials — maybe generate a fresh set?</p>
          <p id="sftpErrorMsg" class="text-xs text-red-400/70 mt-0.5"></p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <button onclick="generateSftpCredentials()" class="px-3 py-1.5 rounded-lg bg-neutral-100 dark:bg-white/10 hover:bg-neutral-200 dark:hover:bg-white/15 text-neutral-800 dark:text-white text-xs font-medium transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none border border-neutral-200 dark:border-transparent">Generate credentials</button>
        <button onclick="closeSftpModal()" class="px-3 py-1.5 rounded-lg text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white text-xs font-medium transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">Close</button>
      </div>
    </div>

    
    <div id="sftpCredentials" class="hidden">
      <div class="px-5 py-3 space-y-1">

        
        <div class="flex items-center gap-3 py-2">
          <span class="text-xs font-medium text-neutral-500 w-16 shrink-0">Host</span>
          <span id="sftpValHost" class="text-xs text-neutral-700 dark:text-neutral-200 flex-1 truncate font-mono"></span>
          <button onclick="sftpCopy('sftpValHost')" aria-label="Copy host" class="shrink-0 flex items-center justify-center w-6 h-6 rounded-md bg-neutral-100 dark:bg-white/5 hover:bg-neutral-200 dark:hover:bg-white/10 text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
            <%- icon('copy', { class: 'size-3', strokeWidth: 2 }) %>
          </button>
        </div>
        <div class="h-px bg-neutral-200 dark:bg-white/5"></div>

        
        <div class="flex items-center gap-3 py-2">
          <span class="text-xs font-medium text-neutral-500 w-16 shrink-0">Port</span>
          <span id="sftpValPort" class="text-xs text-neutral-700 dark:text-neutral-200 flex-1 font-mono"></span>
          <button onclick="sftpCopy('sftpValPort')" aria-label="Copy port" class="shrink-0 flex items-center justify-center w-6 h-6 rounded-md bg-neutral-100 dark:bg-white/5 hover:bg-neutral-200 dark:hover:bg-white/10 text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
            <%- icon('copy', { class: 'size-3', strokeWidth: 2 }) %>
          </button>
        </div>
        <div class="h-px bg-neutral-200 dark:bg-white/5"></div>

        
        <div class="flex items-center gap-3 py-2">
          <span class="text-xs font-medium text-neutral-500 w-16 shrink-0">Username</span>
          <span id="sftpValUser" class="text-xs text-neutral-700 dark:text-neutral-200 flex-1 truncate font-mono"></span>
          <button onclick="sftpCopy('sftpValUser')" aria-label="Copy username" class="shrink-0 flex items-center justify-center w-6 h-6 rounded-md bg-neutral-100 dark:bg-white/5 hover:bg-neutral-200 dark:hover:bg-white/10 text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
            <%- icon('copy', { class: 'size-3', strokeWidth: 2 }) %>
          </button>
        </div>
        <div class="h-px bg-neutral-200 dark:bg-white/5"></div>

        
        <div class="flex items-center gap-3 py-2">
          <span class="text-xs font-medium text-neutral-500 w-16 shrink-0">Password</span>
          <span id="sftpValPass" class="text-xs text-neutral-200 flex-1 truncate font-mono blur-sm hover:blur-none transition-all duration-200 cursor-default select-all" title="Hover to reveal"></span>
          <button onclick="sftpCopy('sftpValPass')" aria-label="Copy password" class="shrink-0 flex items-center justify-center w-6 h-6 rounded-md bg-neutral-100 dark:bg-white/5 hover:bg-neutral-200 dark:hover:bg-white/10 text-neutral-500 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">
            <%- icon('copy', { class: 'size-3', strokeWidth: 2 }) %>
          </button>
        </div>

      </div>

      
      <div class="flex items-center gap-2 px-5 py-4 border-t border-neutral-200 dark:border-white/5">
        <button onclick="generateSftpCredentials()" id="sftpRegenBtn" class="px-3 py-1.5 rounded-lg bg-orange-500 hover:bg-orange-400 text-black text-xs font-semibold transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none disabled:opacity-40">Regenerate</button>
        <button onclick="revokeSftpCredentials()" class="px-3 py-1.5 rounded-lg bg-red-600 hover:bg-red-500 text-white text-xs font-semibold transition focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none">Revoke</button>
      </div>
    </div>

  </div>
</div>

<style>
@keyframes al-sftp-in  { from { opacity:0; transform:scale(0.96) translateY(8px); } to { opacity:1; transform:scale(1) translateY(0); } }
@keyframes al-sftp-out { from { opacity:1; transform:scale(1) translateY(0); } to { opacity:0; transform:scale(0.96) translateY(8px); } }
#sftpModal .al-sftp-panel { animation: al-sftp-in 0.2s cubic-bezier(0.16,1,0.3,1) both; }
#sftpModal .al-sftp-panel.al-closing { animation: al-sftp-out 0.15s cubic-bezier(0.4,0,1,1) both; }
</style>

<script nonce="<%- nonce %>">
(function () {
  var SERVER_ID = '<%= server.UUID %>';
  var sftpPlainPassword = null;

  window.openSftpModal = function () {
    var modal = document.getElementById('sftpModal');
    var panel = modal.querySelector('.al-sftp-panel');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    if (panel) { panel.classList.remove('al-closing'); void panel.offsetWidth; }
    loadSftpCredentials();
  };

  window.closeSftpModal = function () {
    var modal = document.getElementById('sftpModal');
    var panel = modal.querySelector('.al-sftp-panel');
    if (!panel || window.matchMedia('(prefers-reduced-motion:reduce)').matches) {
      modal.classList.add('hidden'); modal.classList.remove('flex'); return;
    }
    panel.classList.add('al-closing');
    panel.addEventListener('animationend', function () {
      modal.classList.add('hidden'); modal.classList.remove('flex');
      panel.classList.remove('al-closing');
    }, { once: true });
  };

  function showSftpState(state) {
    document.getElementById('sftpLoading').classList.toggle('hidden', state !== 'loading');
    document.getElementById('sftpError').classList.toggle('hidden', state !== 'error');
    document.getElementById('sftpCredentials').classList.toggle('hidden', state !== 'credentials');
  }

  function fillCredentials(data) {
    if (data.password) {
      sftpPlainPassword = data.password;
    }

    document.getElementById('sftpValHost').textContent = data.host;
    document.getElementById('sftpValPort').textContent = data.port;
    document.getElementById('sftpValUser').textContent = data.username;
    document.getElementById('sftpValPass').textContent = data.password || sftpPlainPassword || 'Regenerate to view';
    showSftpState('credentials');
  }

  function loadSftpCredentials() {
    showSftpState('loading');
    fetch('/server/' + SERVER_ID + '/sftp/credentials')
      .then(function (resp) {
        if (resp.status === 404) {
          return generateSftpCredentials();
        }
        if (!resp.ok) {
          return resp.json().catch(function () { return {}; }).then(function (d) {
            throw new Error(d.error || 'Request failed (' + resp.status + ')');
          });
        }
        return resp.json().then(fillCredentials);
      })
      .catch(function (err) {
        document.getElementById('sftpErrorMsg').textContent = err.message || 'Unknown error.';
        showSftpState('error');
      });
  }

  window.generateSftpCredentials = function () {
    var btn = document.getElementById('sftpRegenBtn');
    if (btn) btn.disabled = true;
    showSftpState('loading');

    return fetch('/server/' + SERVER_ID + '/sftp/credentials', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
    })
      .then(function (resp) {
        if (!resp.ok) {
          return resp.json().catch(function () { return {}; }).then(function (d) {
            throw new Error(d.error || 'Request failed (' + resp.status + ')');
          });
        }
        return resp.json();
      })
      .then(function (data) {
        if (btn) btn.disabled = false;
        fillCredentials(data);
        showToast('Fresh credentials ready.', 'success');
      })
      .catch(function (err) {
        if (btn) btn.disabled = false;
        document.getElementById('sftpErrorMsg').textContent = err.message || 'Unknown error.';
        showSftpState('error');
      });
  };

  window.revokeSftpCredentials = function () {
    fetch('/server/' + SERVER_ID + '/sftp/credentials', {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' },
    })
      .then(function () {
        closeSftpModal();
        showToast('SFTP access revoked.', 'success');
      })
      .catch(function () {
        showToast('SFTP access revoked.', 'success');
      });
  };

  window.sftpCopy = function (elementId) {
    var el = document.getElementById(elementId);
    if (!el) return;
    navigator.clipboard.writeText(el.textContent || '').then(function () {
      showToast('Copied!', 'success');
    }).catch(function () {
      showToast('Copy failed — try selecting and copying manually.', 'error');
    });
  };
})();
</script>
