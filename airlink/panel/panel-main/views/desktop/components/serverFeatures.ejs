
<!-- EULA Feature -->

<% if (typeof features !== 'undefined' && features && features.includes('eula')) { %>
<script nonce="<%- nonce %>">
  document.addEventListener('DOMContentLoaded', function() {
    window.modal.confirm({
      title: "Accept Minecraft's EULA",
      body: "By clicking Accept you agree to the Mojang End User License Agreement (EULA). The server will not start until you accept.",
      danger: false,
      confirmLabel: 'Accept EULA',
      onConfirm: () => {
        fetch('/server/<%= req.params.id %>/feature/eula', { method: 'POST' })
          .then(() => location.reload())
          .catch(error => console.error('There was an error!', error));
      }
    });
  });
</script>
<% } %>


<!-- AUTO-COMPLETE FEATURE -->

<% if (typeof features !== 'undefined' && features && features.includes('auto-complete')) { %>
    <script nonce="<%- nonce %>">
        document.addEventListener('DOMContentLoaded', () => {
            const inputField = document.getElementById('input');
            const suggestionsBox = document.getElementById('suggestions');
            const settingsIcon = document.getElementById('settings-icon');
            const settingsMenu = document.getElementById('settings-menu');
            const autoCompleteToggle = document.getElementById('auto-complete-toggle');

            if (!inputField || !suggestionsBox || !autoCompleteToggle) return;

            const suggestions = [
                'help', 'pardon', 'ban [PLAYER]', 'kick [PLAYER]', 'teleport [PLAYER]',
                'time', 'weather', 'give [ITEM] [PLAYER]', 'gamemode [MODE] [PLAYER]',
                'difficulty', 'summon [ENTITY] [PLAYER]', 'say', 'me', 'list', 'scoreboard',
                'tp', 'setworldspawn', 'clear', 'op', 'deop', 'banlist', 'spawnpoint',
                'stop', 'save-all', 'setblock', 'execute', 'fill', 'replaceitem', 'event',
                'advancement', 'item', 'effect', 'playsound', 'team', 'title',
                'gamerule', 'clone', 'debug', 'publish', 'ban-ip', 'whitelist', 'enchant',
                'msg', 'tellraw', 'seed', 'defaultgamemode', 'xp', 'worldborder', 'tps', 'tell'
            ];

            function getCookie(name) {
                const nameEQ = name + '=';
                for (let c of document.cookie.split(';')) {
                    c = c.trim();
                    if (c.startsWith(nameEQ)) return c.substring(nameEQ.length);
                }
                return null;
            }

            function setCookie(name, value, days) {
                const expires = new Date();
                expires.setTime(expires.getTime() + (days * 24 * 60 * 60 * 1000));
                document.cookie = `${name}=${value}; expires=${expires.toUTCString()}; path=/`;
            }

            autoCompleteToggle.checked = getCookie('auto-complete-enabled') === 'true';

            if (settingsIcon && settingsMenu) {
                settingsIcon.addEventListener('click', () => settingsMenu.classList.toggle('hidden'));
            }

            autoCompleteToggle.addEventListener('change', () => {
                setCookie('auto-complete-enabled', autoCompleteToggle.checked, 365);
                if (!autoCompleteToggle.checked) suggestionsBox.classList.add('hidden');
            });

            inputField.addEventListener('input', () => {
                if (!autoCompleteToggle.checked) return;
                const query = inputField.value.toLowerCase();
                suggestionsBox.innerHTML = '';
                if (!query) { suggestionsBox.classList.add('hidden'); return; }

                const matches = suggestions.filter(s => s.toLowerCase().startsWith(query));
                if (matches.length === 0) { suggestionsBox.classList.add('hidden'); return; }

                suggestionsBox.classList.remove('hidden');
                matches.forEach(suggestion => {
                    const div = document.createElement('div');
                    div.textContent = suggestion;
                    div.className = 'px-4 py-2 hover:bg-neutral-600 cursor-pointer text-sm';
                    div.addEventListener('click', () => {
                        inputField.value = suggestion;
                        const bracketStart = suggestion.indexOf('[');
                        const bracketEnd = suggestion.indexOf(']', bracketStart);
                        if (bracketStart !== -1 && bracketEnd !== -1) {
                            setTimeout(() => {
                                inputField.setSelectionRange(bracketStart, bracketEnd + 1);
                                inputField.focus();
                            }, 0);
                        }
                        suggestionsBox.classList.add('hidden');
                    });
                    suggestionsBox.appendChild(div);
                });
            });

            document.addEventListener('click', (e) => {
                if (!e.target.closest('#input') && !e.target.closest('#suggestions') && !e.target.closest('#settings-icon')) {
                    suggestionsBox.classList.add('hidden');
                    if (settingsMenu) settingsMenu.classList.add('hidden');
                }
            });
        });
    </script>
<% } %>