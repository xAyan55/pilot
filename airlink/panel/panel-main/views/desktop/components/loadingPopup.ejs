<style>
  /* Inline action feedback bar */
  #actionFeedback {
    display: none;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--af-color, var(--theme-text-muted, #6b7280));
    transition: opacity 0.3s ease;
  }
  #actionFeedback.visible { display: flex; }
  #actionFeedback.fading  { opacity: 0; }
  .af-spinner {
    width: 12px;
    height: 12px;
    border: 1.5px solid transparent;
    border-top-color: currentColor;
    border-radius: 50%;
    animation: af-spin 0.65s linear infinite;
    flex-shrink: 0;
  }
  @keyframes af-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) {
    .af-spinner { animation: none; }
  }
</style>

<div id="actionFeedback" aria-live="polite">
  <span class="af-spinner" id="afSpinner"></span>
  <svg id="afCheck" xmlns="http://www.w3.org/2000/svg" class="hidden" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <polyline points="20 6 9 17 4 12"/>
  </svg>
  <span id="afText"></span>
</div>

<script nonce="<%- nonce %>" src="/javascript/loading-popup.js"></script>
