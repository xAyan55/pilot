<!DOCTYPE html>
<html class="h-full js-loading" lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% if (typeof csrfToken !== 'undefined') { %>
    <meta name="csrf-token" content="<%= csrfToken %>">
    <% } %>
    <title><%= settings.title %> - <%= title %></title>
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/layout-animations.css">
    <link rel="stylesheet" href="/styles/motion.css">
    <link rel="icon" href="<%= settings.favicon && settings.favicon.startsWith('/') ? settings.favicon : '/favicon.ico' %>" type="image/x-icon">
    <link rel="shortcut icon" href="<%= settings.favicon && settings.favicon.startsWith('/') ? settings.favicon : '/favicon.ico' %>" type="image/x-icon">
    <% if (settings.lightTheme && settings.lightTheme !== 'default') { %>
    <link rel="stylesheet" href="<%= settings.lightTheme %>" id="light-theme-css" data-theme-mode="light">
    <% } %>
    <% if (settings.darkTheme && settings.darkTheme !== 'default') { %>
    <link rel="stylesheet" href="<%= settings.darkTheme %>" id="dark-theme-css" data-theme-mode="dark">
    <% } %>
    <link rel="preconnect" href="https://cdn.fontshare.com">
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@500,300,600,400,700&display=swap" rel="stylesheet">
    <script nonce="<%- nonce %>" src="/js/csrf.js"></script>
    <script nonce="<%- nonce %>" src="/javascript/viewport-mode.js"></script>
    <script nonce="<%- nonce %>" src="/javascript/page-loader.js"></script>
    <script nonce="<%- nonce %>" src="/javascript/checkbox-anim.js"></script>
    <script nonce="<%- nonce %>" src="/javascript/layout-animations.js"></script>
    <style>
      html, body, * { scrollbar-width: none; -ms-overflow-style: none; }
      ::-webkit-scrollbar { display: none; }
      html, body { transition: background-color 0.25s ease-in, color 0.25s ease-in; }
      /* Pre-hide animatable content before JS runs so there's no flash-then-hide jitter */
      .js-loading #page-content > *:not(.mobile-top-bar):not(.mobile-bottom-nav):not(.mobile-more-sheet):not([style*="position: fixed"]),
      .js-loading #server-page-body > * {
        opacity: 0;
        transform: translateY(14px);
      }
    </style>
</head>
<body style="font-family: 'General Sans'" class="bg-neutral-50 dark:bg-[#141414] h-full text-neutral-800 dark:text-white">

<a href="#page-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[99999] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-neutral-900 focus:text-white focus:text-sm focus:font-medium focus:shadow-lg">Skip to main content</a>

<!-- Page loader overlay — rendered in HTML so it exists before any JS or paint -->
<script nonce="<%- nonce %>">
(function(){
  var d=false;
  try{var s=localStorage.getItem('theme');if(s==='dark')d=true;else if(!s)d=window.matchMedia('(prefers-color-scheme: dark)').matches;}catch(e){}
  /* frosted glass overlay — background set via CSS class, not inline */
})();
</script>
<div id="pl-overlay" style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:99998;display:none;align-items:center;justify-content:center;pointer-events:all;background:rgba(249,250,251,0.08);backdrop-filter:blur(28px) saturate(180%);-webkit-backdrop-filter:blur(28px) saturate(180%);">
  <div id="pl-inner" style="display:flex;flex-direction:column;align-items:center;gap:18px;">
    <img src="/assets/logo.png" alt="" style="width:42px;height:42px;object-fit:contain;border-radius:10px;display:block;" onerror="this.style.display='none'">
    <p style="margin:0;margin-top:-4px;font-family:'General Sans',sans-serif;font-size:14px;font-weight:600;letter-spacing:-0.015em;" id="pl-title"><%= settings.title %></p>
    <div style="width:128px;height:1.5px;border-radius:2px;overflow:hidden;" id="pl-track">
      <div id="pl-bar" style="height:100%;width:0%;border-radius:2px;transition:width 260ms cubic-bezier(0.4,0,0.2,1);"></div>
    </div>
    <p id="pl-msg" style="margin:0;margin-top:-4px;font-family:'General Sans',sans-serif;font-size:11px;color:var(--theme-text-muted,#737373);letter-spacing:0.01em;transition:opacity 180ms ease;">Preparing your experience...</p>
  </div>
</div>
<script nonce="<%- nonce %>">
(function(){
  var d=false;
  try{var s=localStorage.getItem('theme');if(s==='dark')d=true;else if(!s)d=window.matchMedia('(prefers-color-scheme: dark)').matches;}catch(e){}
  var fg=d?'var(--theme-text-strong,#ffffff)':'var(--theme-text-strong,#171717)';
  var track=d?'var(--theme-border-subtle,rgba(255,255,255,0.08))':'var(--theme-border-subtle,rgba(0,0,0,0.12))';
  var ov=document.getElementById('pl-overlay');
  var t=document.getElementById('pl-title');
  var tr=document.getElementById('pl-track');
  var b=document.getElementById('pl-bar');
  if(ov){ov.style.background=d?'var(--theme-bg,rgba(14,14,14,0.08))':'var(--theme-bg,rgba(249,250,251,0.08))';ov.style.backdropFilter='blur(28px) saturate(180%)';ov.style.webkitBackdropFilter='blur(28px) saturate(180%)';}
  if(t)t.style.color=fg;
  if(tr)tr.style.background=track;
  if(b)b.style.background=fg;
})();
</script>

<button id="theme-toggle" class="fixed right-4 top-4 w-14 h-8 flex items-center bg-neutral-300 dark:bg-neutral-700/70 rounded-full p-1 transition-colors duration-500 z-50" aria-label="Switch to dark mode" aria-pressed="false">
    <span class="dot bg-white w-6 h-6 rounded-full shadow-md transform transition-transform duration-500 border border-neutral-950/20"></span>
</button>
<script nonce="<%- nonce %>">
function initializeTheme() {
    const userPreference = localStorage.getItem('theme');
    const systemPreference = window.matchMedia('(prefers-color-scheme: dark)').matches;

    if (userPreference === 'dark' || (!userPreference && systemPreference)) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    applyThemeSheets();
    updateSwitchPosition();
  }

  function applyThemeSheets() {
    const isDark = document.documentElement.classList.contains('dark');
    const lightSheet = document.getElementById('light-theme-css');
    const darkSheet = document.getElementById('dark-theme-css');
    if (lightSheet) lightSheet.disabled = isDark;
    if (darkSheet) darkSheet.disabled = !isDark;
  }

  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    applyThemeSheets();
    updateSwitchPosition();
    if (typeof setTerminalTheme === 'function') {
      setTerminalTheme();
    }
    // Re-apply active link color since it's set via inline style
    const activeLink = document.querySelector('.nav-link.active');
    if (activeLink) {
      activeLink.style.color = isDark ? 'var(--theme-nav-text-active, #ffffff)' : 'var(--theme-nav-text-active, #0a0a0a)';
    }
  }

  function updateSwitchPosition() {
    const isDark = document.documentElement.classList.contains('dark');
    const btn = document.getElementById('theme-toggle');
    const dot = document.querySelector('#theme-toggle .dot');
    if (isDark) {
      dot.classList.add('translate-x-6');
      if (btn) { btn.setAttribute('aria-pressed', 'true'); btn.setAttribute('aria-label', 'Switch to light mode'); }
    } else {
      dot.classList.remove('translate-x-6');
      if (btn) { btn.setAttribute('aria-pressed', 'false'); btn.setAttribute('aria-label', 'Switch to dark mode'); }
    }
  }

  document.getElementById('theme-toggle').addEventListener('click', toggleTheme);
  initializeTheme();
  </script>
<%- include("./modal") %>
