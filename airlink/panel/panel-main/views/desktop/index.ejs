<%- include('./components/header', { title: 'Authentication' }) %>

<main class="bg-white dark:bg-neutral-900 h-screen w-screen flex items-center justify-center">
    <div class="container mx-auto px-4 flex flex-col items-center">
        <!-- Header Text -->
        <div class="text-center mb-12">
            <h1 class="text-neutral-900 dark:text-white text-4xl font-semibold mb-2">Welcome Back</h1>
            <p class="text-neutral-400">Choose your entry point</p>
        </div>
        <!-- Cards Container -->
        <div class="grid md:grid-cols-2 gap-8 w-full max-w-4xl">
            <!-- Login Card -->
            <div class="bg-neutral-50 dark:bg-black/20 p-8 border border-neutral-200 dark:border-neutral-200/20 rounded-2xl shadow-lg backdrop-blur-sm transition-transform duration-300 hover:scale-[1.02]">
                <div class="text-center mb-6">
                    <%- icon('user', { class: 'w-12 h-12 text-neutral-400 mx-auto mb-4' }) %>
                    <h2 class="text-neutral-900 dark:text-white text-2xl font-semibold">Sign In</h2>
                    <p class="text-neutral-400 mt-2">Access your account</p>
                </div>
                <a href="/login" class="block w-full p-3 bg-neutral-100 hover:bg-neutral-300 rounded-lg text-neutral-800 font-semibold text-center transition duration-200">
                    Login
                </a>
            </div>
            <!-- Register Card -->
            <div class="bg-neutral-50 dark:bg-black/20 p-8 border border-neutral-200 dark:border-neutral-200/20 rounded-2xl shadow-lg backdrop-blur-sm transition-transform duration-300 hover:scale-[1.02]">
                <div class="text-center mb-6">
                    <%- icon('user-plus', { class: 'w-12 h-12 text-neutral-400 mx-auto mb-4' }) %>
                    <h2 class="text-neutral-900 dark:text-white text-2xl font-semibold">Create Account</h2>
                    <p class="text-neutral-400 mt-2">Start your journey</p>
                </div>
                <a href="/register" class="block w-full p-3 bg-neutral-100 hover:bg-neutral-300 rounded-lg text-neutral-800 font-semibold text-center transition duration-200">
                    Register
                </a>
            </div>
        </div>
        <!-- Footer Text -->
        <p class="text-neutral-400 mt-12 text-sm">
            Need help? <a href="#" class="text-blue-400 hover:underline">Contact Support</a>
        </p>
    </div>
</main>
<%- include('./components/footer') %>