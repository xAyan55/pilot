<%- include('../components/header', { title: 'Create account' }) %>

<style>
  ::-webkit-scrollbar { display: none; }
  body, html { height: 100%; margin: 0; }

  .auth-split {
    display: flex; min-height: 100vh;
  }
  .auth-panel {
    width: 100%; max-width: 460px; flex-shrink: 0;
    display: flex; flex-direction: column; justify-content: center;
    padding: 48px 40px;
    background: var(--theme-bg-card, #fff);
    border-right: 1px solid var(--theme-border, #e5e5e5);
  }
  html.dark .auth-panel {
    background: var(--theme-bg-card, #141414);
    border-right-color: var(--theme-border-subtle, rgba(255,255,255,0.08));
  }
  .auth-image {
    flex: 1;
    background: url('<%= settings.registerWallpaper || "/assets/wallpapers/register.jpeg" %>') center/cover no-repeat;
  }

  @media (max-width: 768px) {
    .auth-split { display: block; min-height: 100vh; }
    .auth-panel { max-width: 100%; border-right: none; padding: 40px 24px; min-height: 100vh; justify-content: center; }
    .auth-image { display: none; }
  }

  .auth-input {
    width: 100%; padding: 10px 14px; border-radius: 10px;
    border: 1px solid var(--theme-border, #e5e5e5); background: var(--theme-bg-input, #f9fafb);
    font-size: 14px; color: var(--theme-text-strong, #171717); outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box; font-family: inherit;
  }
  html.dark .auth-input {
    background: var(--theme-bg-input, rgba(255,255,255,0.08)); border-color: var(--theme-border-subtle, rgba(255,255,255,0.08)); color: var(--theme-text, #e5e5e5);
  }
  .auth-input:focus { border-color: var(--theme-border, #a3a3a3); box-shadow: 0 0 0 3px var(--theme-border-subtle, rgba(0,0,0,0.06)); }
  html.dark .auth-input:focus { border-color: var(--theme-border-subtle, rgba(255,255,255,0.08)); box-shadow: 0 0 0 3px var(--theme-border-subtle, rgba(255,255,255,0.08)); }
  .auth-input::placeholder { color: var(--theme-text-placeholder, #a3a3a3); }
  html.dark .auth-input::placeholder { color: var(--theme-text-muted, #525252); }
  .auth-input.invalid { border-color: var(--theme-danger, #f87171) !important; }

  .auth-label { display: block; font-size: 13px; font-weight: 500; color: var(--theme-text-muted, #525252); margin-bottom: 6px; }
  html.dark .auth-label { color: var(--theme-text, #a3a3a3); }

  .auth-submit {
    width: 100%; padding: 11px; border-radius: 10px;
    background: var(--theme-text-strong, #171717); color: var(--theme-accent-text, white); font-size: 14px; font-weight: 500;
    border: none; cursor: pointer; transition: background 0.15s;
    font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 8px;
  }
  html.dark .auth-submit { background: var(--theme-bg-input, white); color: var(--theme-bg, #0a0a0a); }
  .auth-submit:hover:not(:disabled) { background: var(--theme-bg-hover, #404040); }
  html.dark .auth-submit:hover:not(:disabled) { background: var(--theme-bg-hover, #e5e5e5); }
  .auth-submit:disabled { opacity: 0.6; cursor: default; }

  .pw-wrapper { position: relative; }
  .pw-toggle {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    background: none; border: none; cursor: pointer; padding: 0; color: var(--theme-text-muted, #a3a3a3); line-height: 0;
  }
  .pw-toggle:hover { color: var(--theme-text-nav, #737373); }
  html.dark .pw-toggle:hover { color: var(--theme-text-strong, #d4d4d4); }

  .pw-strength { height: 3px; border-radius: 2px; background: var(--theme-border, #e5e5e5); margin-top: 8px; overflow: hidden; }
  html.dark .pw-strength { background: var(--theme-border-subtle, rgba(255,255,255,0.08)); }
  .pw-bar { height: 100%; border-radius: 2px; width: 0%; transition: width 0.28s ease, background 0.28s ease; }
  .pw-hint { font-size: 11px; color: var(--theme-text-muted, #a3a3a3); margin-top: 5px; min-height: 14px; transition: color 0.2s; }

  .spinner {
    width: 15px; height: 15px; flex-shrink: 0;
    border: 2px solid var(--theme-border-subtle, rgba(255,255,255,0.08)); border-top-color: var(--theme-accent-text, white);
    border-radius: 50%; animation: spin 0.65s linear infinite; display: none;
  }
  html.dark .spinner { border-color: var(--theme-border, rgba(0,0,0,0.25)); border-top-color: var(--theme-bg, #0a0a0a); }
  .auth-submit.loading .spinner { display: block; }
  .auth-submit.loading .btn-label { display: none; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .auth-panel { opacity: 0; transform: translateX(-12px); transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16,1,0.3,1); }
  .auth-panel.visible { opacity: 1; transform: translateX(0); }
</style>

<div class="auth-split">
  <div class="auth-panel" id="authPanel">

    <div class="mb-8">
      <% if (settings.logo) { %>
      <img src="<%= settings.logo %>" alt="" class="h-10 w-10 rounded-xl object-contain mb-5">
      <% } %>
      <h1 class="text-2xl font-semibold text-neutral-900 dark:text-white">Create account</h1>
      <p class="text-sm text-neutral-500 mt-1"><%= settings.title %></p>
    </div>

    <% if (req.query.err) { %>
    <div class="rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 px-4 py-3 mb-5">
      <p class="text-sm font-medium text-red-700 dark:text-red-400">
        <% if (req.query.err === 'missing_credentials') { %>All fields are required.
        <% } else if (req.query.err === 'invalid_username') { %>Username must be 3–20 characters, letters and numbers only.
        <% } else if (req.query.err === 'user_already_exists') { %>That username or email is already taken.
        <% } else if (req.query.err === 'weak_password') { %>Password needs 8+ chars, at least one letter and one number.
        <% } else { %>Something went wrong. Try again.<% } %>
      </p>
    </div>
    <% } %>

    <form id="registerForm" method="POST" action="/register" autocomplete="on" novalidate>
      <%- include('../components/csrf') %>
      <div class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="auth-label" for="username">Username</label>
            <input id="username" name="username" type="text" autocomplete="username"
              required spellcheck="false" autocapitalize="none" maxlength="20"
              class="auth-input" placeholder="johndoe">
          </div>
          <div>
            <label class="auth-label" for="email">Email</label>
            <input id="email" name="email" type="email" autocomplete="email"
              required class="auth-input" placeholder="you@example.com">
          </div>
        </div>
        <div>
          <label class="auth-label" for="password">Password</label>
          <div class="pw-wrapper">
            <input id="password" name="password" type="password" autocomplete="new-password"
              required class="auth-input" placeholder="••••••••" style="padding-right:40px">
            <button type="button" class="pw-toggle" id="pwToggle" aria-label="Show password">
              <span id="eyeIcon"><%- icon('eye', { width: 16, height: 16 }) %></span>
            </button>
          </div>
          <div class="pw-strength"><div class="pw-bar" id="pwBar"></div></div>
          <p class="pw-hint" id="pwHint">8+ characters, one letter, one number.</p>
        </div>
        <button type="submit" class="auth-submit" id="submitBtn">
          <span class="btn-label">Create account</span>
          <span class="spinner"></span>
        </button>
      </div>
    </form>

    <p class="text-sm text-neutral-500 dark:text-neutral-400 text-center mt-6">
      Already have an account?
      <a href="/login" class="font-medium text-neutral-800 dark:text-neutral-200 hover:underline">Sign in</a>
    </p>

  </div>
  <div class="auth-image"></div>
</div>

<script nonce="<%- nonce %>">
  requestAnimationFrame(function () {
    requestAnimationFrame(function () {
      document.getElementById('authPanel').classList.add('visible');
    });
  });

  var pwToggle = document.getElementById('pwToggle');
  var pwInput  = document.getElementById('password');
  pwToggle.addEventListener('click', function () {
    var show = pwInput.type === 'password';
    pwInput.type = show ? 'text' : 'password';
    document.getElementById('eyeIcon').innerHTML = show
      ? '<path fill-rule="evenodd" d="M3.28 2.22a.75.75 0 0 0-1.06 1.06l14.5 14.5a.75.75 0 1 0 1.06-1.06l-1.745-1.745a10.029 10.029 0 0 0 3.3-4.38 1.651 1.651 0 0 0 0-1.185A10.004 10.004 0 0 0 9.999 3a9.956 9.956 0 0 0-4.744 1.194L3.28 2.22ZM7.752 6.69l1.092 1.092a2.5 2.5 0 0 1 3.374 3.373l1.091 1.092a4 4 0 0 0-5.557-5.557Z" clip-rule="evenodd"/><path d="M10.748 13.93l2.523 2.524a10.065 10.065 0 0 1-5.27 0l-1.978-1.978a4 4 0 0 0 .005-5.53l-.738-.738A8.003 8.003 0 0 0 1.834 9.587a1.651 1.651 0 0 0 0 1.186A10.004 10.004 0 0 0 10 17c1.09 0 2.14-.175 3.124-.497l-2.376-2.573Z"/>'
      : '<path d="M10 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/><path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 0 1 0-1.186A10.004 10.004 0 0 1 10 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0 1 10 17c-4.257 0-7.893-2.66-9.336-6.41ZM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" clip-rule="evenodd"/>';
  });

  pwInput.addEventListener('input', function () {
    var v = pwInput.value;
    var score = [v.length >= 8, /[A-Za-z]/.test(v), /[0-9]/.test(v), /[^A-Za-z0-9]/.test(v)].filter(Boolean).length;
    var colors = ['var(--theme-danger,#ef4444)','var(--theme-warning,#f97316)','var(--theme-warning,#eab308)','var(--theme-success,#22c55e)'];
    var labels = ['Too short','Weak','Fair','Strong'];
    var widths = ['25%','50%','75%','100%'];
    var bar  = document.getElementById('pwBar');
    var hint = document.getElementById('pwHint');
    if (!v) { bar.style.width = '0%'; hint.textContent = '8+ characters, one letter, one number.'; hint.style.color = ''; return; }
    var idx = Math.max(0, score - 1);
    bar.style.width = widths[idx]; bar.style.background = colors[idx];
    hint.textContent = labels[idx]; hint.style.color = colors[idx];
  });

  document.getElementById('registerForm').addEventListener('submit', function (e) {
    var username = document.getElementById('username').value.trim();
    var email    = document.getElementById('email').value.trim();
    var password = document.getElementById('password').value;
    var ok = true;
    ['username','email','password'].forEach(function (id) { document.getElementById(id).classList.remove('invalid'); });
    if (username.length < 3 || !/^[A-Za-z0-9]+$/.test(username)) { document.getElementById('username').classList.add('invalid'); ok = false; }
    if (!email.includes('@') || !email.includes('.')) { document.getElementById('email').classList.add('invalid'); ok = false; }
    if (password.length < 8 || !/[A-Za-z]/.test(password) || !/[0-9]/.test(password)) { document.getElementById('password').classList.add('invalid'); ok = false; }
    if (!ok) { e.preventDefault(); return; }
    document.getElementById('submitBtn').classList.add('loading');
    document.getElementById('submitBtn').disabled = true;
  });

  ['username','email','password'].forEach(function (id) {
    document.getElementById(id).addEventListener('input', function () { this.classList.remove('invalid'); });
  });
</script>

<%- include('../components/footer') %>
