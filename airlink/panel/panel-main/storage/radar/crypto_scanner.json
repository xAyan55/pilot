{
  "name": "Crypto Miner Scanner",
  "description": "Detects cryptocurrency mining software, pool configuration, and miner-related files planted in server volumes.",
  "version": "2.0.0",
  "patterns": [
    {
      "type": "filename",
      "pattern": "(?i)(xmrig|xmr-stak|xmr-node-proxy|ethminer|cgminer|cpuminer|minerd|bfgminer|sgminer|t-rex|gminer|lolminer|nbminer|teamredminer|phoenixminer|claymore|nanominer|srbminer)",
      "severity": "critical",
      "description": "Known cryptocurrency miner binary or executable"
    },
    {
      "type": "extension",
      "pattern": "\\.(json|conf|config|cfg|ini|yml|yaml)$",
      "content": "(?i)(stratum\\+tcp://|stratum\\+ssl://|pool\\.supportxmr\\.com|pool\\.minexmr\\.com|xmrpool\\.eu|nanopool\\.org|dwarfpool\\.com|minergate\\.com|2miners\\.com|f2pool\\.com|antpool\\.com|\"algo\"\\s*:\\s*\"(cryptonight|randomx|kawpow|ethash|autolykos)\")",
      "severity": "critical",
      "description": "Mining pool configuration file with stratum or pool reference"
    },
    {
      "type": "extension",
      "pattern": "\\.(sh|bash|bat|cmd|ps1)$",
      "content": "(?i)(xmrig|stratum\\+tcp|stratum\\+ssl|cryptonight|randomx|monero|--donate-level|--pool|--wallet|hashrate|mining pool)",
      "severity": "critical",
      "description": "Script containing miner launch parameters or pool references"
    },
    {
      "type": "extension",
      "pattern": "\\.jar$",
      "content": "(?i)(stratum\\+tcp|stratum\\+ssl|cryptonight|randomx|nanopool|supportxmr|minergate|hashrate|getwork|submitwork)",
      "severity": "critical",
      "description": "JAR file with mining protocol references"
    },
    {
      "type": "filename",
      "pattern": "(?i)(^|[/\\\\])(miner|xmr|monero|ethereum|bitcoin|litecoin|zcash|ravencoin)[^/\\\\]*\\.(jar|exe|sh|bat|bin|elf)$",
      "severity": "high",
      "description": "File named after a cryptocurrency with an executable extension"
    },
    {
      "type": "filename",
      "pattern": "(?i)(config\\.json|settings\\.json|pools\\.json|wallet\\.json)$",
      "content": "(?i)(stratum|pool_address|wallet_address|\"coin\"\\s*:|\"algo\"\\s*:)",
      "severity": "high",
      "description": "Generic config file containing mining-specific fields"
    },
    {
      "type": "extension",
      "pattern": "\\.(log|txt)$",
      "content": "(?i)(accepted\\s+\\d+/\\d+|rejected\\s+\\d+/\\d+|hashrate|H/s|KH/s|MH/s|GH/s|shares submitted|pool connected)",
      "severity": "medium",
      "description": "Log or text file containing miner output — miner may have already run"
    },
    {
      "type": "filename",
      "pattern": "(?i)(^|[/\\\\])(start_miner|run_miner|mine|start_mining|install_miner)\\.(sh|bat|ps1|cmd)$",
      "severity": "high",
      "description": "Script with a name suggesting miner setup or launch"
    }
  ]
}
