<%- include(components.header, { title: title, user: user }) %>
<%- include(components.toast) %>
<link rel="stylesheet" href="/addons/modrinth/modrinth.css">

<main class="min-h-screen modrinth-addon">
  <%- include(components.template) %>

  <div class="pb-20">
    <% const hasDisabledTypes = modrinthSettings?.disabledProjectTypes?.length > 0;
       const hasBlockedProjects = modrinthSettings?.blockedProjects?.length > 0;
       const shouldShowWarning = modrinthSettings?.modrinthInstallationWarning && (hasDisabledTypes || hasBlockedProjects); %>

    <% if (shouldShowWarning) { %>
    <div class="bg-amber-500/10 border-b border-amber-500/20 px-4 py-3">
      <div class="flex items-start gap-2">
        <svg class="w-4 h-4 text-amber-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
        <div>
          <p class="font-medium text-amber-400 text-sm"><%= modrinthSettings.warningTitle %></p>
          <p class="text-amber-200 text-xs mt-0.5"><%= modrinthSettings.warningMessage %></p>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Search -->
    <div class="px-4 pt-4 pb-3 bg-white dark:bg-[#141414] sticky top-14 z-30 border-b border-neutral-200 dark:border-white/5">
      <form method="GET" action="/modrinth" id="searchForm">
        <div class="flex gap-2 mb-3">
          <div class="flex-1 relative">
            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
              <svg class="w-4 h-4 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
            </div>
            <input type="text" name="q" id="searchInput" value="<%= query %>" placeholder="Search Modrinth..." autocomplete="off" class="w-full pl-9 pr-4 py-2.5 bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-xl text-neutral-900 dark:text-white text-sm placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-neutral-400">
          </div>
          <button type="submit" class="px-4 py-2.5 bg-neutral-800 hover:bg-neutral-700 text-white dark:bg-neutral-200 dark:hover:bg-neutral-300 dark:text-neutral-900 rounded-xl text-sm font-medium transition-colors min-w-[56px]">Go</button>
        </div>
        <div class="flex gap-2 overflow-x-auto no-scrollbar">
          <select name="type" id="typeFilter" class="px-3 py-1.5 bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-xs text-neutral-700 dark:text-neutral-300">
            <option value="all" <%= type === 'all' ? 'selected' : '' %>>All</option>
            <% [{v:'mod',l:'Mods'},{v:'modpack',l:'Modpacks'},{v:'resourcepack',l:'Textures'},{v:'shader',l:'Shaders'},{v:'plugin',l:'Plugins'},{v:'datapack',l:'Data'}].forEach(function(o){ %>
            <option value="<%= o.v %>" <%= type===o.v?'selected':'' %>><%= o.l %></option>
            <% }); %>
          </select>
          <select id="sortFilter" class="px-3 py-1.5 bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg text-xs text-neutral-700 dark:text-neutral-300">
            <option value="relevance">Relevance</option>
            <option value="downloads">Downloads</option>
            <option value="updated">Updated</option>
          </select>
        </div>
      </form>
    </div>

    <!-- Loading / Error / Empty -->
    <div id="loadingEl" class="p-4 space-y-2"><% for(let i=0;i<6;i++){%><div class="sk h-14 w-full rounded-xl"></div><%}%></div>
    <div id="errorEl" style="display:none" class="p-8 text-center"><p id="errorMsg" class="text-sm text-neutral-500"></p><button onclick="loadResults()" class="mt-2 text-xs text-neutral-400 underline bg-transparent border-none">Retry</button></div>
    <div id="emptyEl" style="display:none" class="p-8 text-center"><p class="text-sm text-neutral-500">No results.</p></div>

    <!-- Results list -->
    <div id="resultsList" style="display:none" class="px-4 space-y-2"></div>
  </div>
</main>

<!-- Mobile wizard bottom sheet -->
<div class="mobile-modal-overlay" id="wizardOverlay" role="dialog" aria-modal="true" aria-labelledby="wizTitle">
  <div class="mobile-modal-box">
    <div class="mobile-modal-handle"></div>

    <!-- Header -->
    <div class="flex items-center justify-between px-4 py-3 border-b border-neutral-200 dark:border-white/5 flex-shrink-0">
      <div class="flex items-center gap-2 min-w-0">
        <img id="wizIcon" src="" alt="" class="w-7 h-7 rounded-lg object-cover shrink-0" onerror="this.style.display='none'">
        <p id="wizTitle" class="text-sm font-semibold text-neutral-800 dark:text-white truncate"></p>
        <span id="wizBadge" class="text-[10px] font-medium px-2 py-0.5 rounded-full whitespace-nowrap"></span>
      </div>
      <button onclick="closeWizard()" class="w-7 h-7 flex items-center justify-center rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 text-neutral-400 transition" aria-label="Close">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>

    <!-- Content area (scrollable) -->
    <div class="flex-1 overflow-y-auto px-4 py-4">

      <!-- STEP 1: Details -->
      <div class="wiz-panel active" id="step-details">
        <p id="wizMeta" class="text-[11px] text-neutral-400 dark:text-neutral-500 mb-2"></p>
        <p id="wizDesc" class="text-xs text-neutral-600 dark:text-neutral-400 leading-relaxed mb-3"></p>
        <div id="wizStats" class="flex flex-wrap gap-3 text-xs text-neutral-500 dark:text-neutral-400 mb-3"></div>
        <div id="wizCategories" class="flex flex-wrap gap-1 mb-3"></div>
        <p class="text-[10px] font-medium text-neutral-400 dark:text-neutral-500 uppercase tracking-wider mb-2">Description</p>
        <div id="wizLong" class="md-body"></div>
      </div>

      <!-- STEP 2: Versions -->
      <div class="wiz-panel" id="step-versions">
        <div class="flex items-center justify-between mb-3">
          <p class="text-[10px] font-medium text-neutral-400 dark:text-neutral-500 uppercase tracking-wider">Versions</p>
          <input type="text" id="verSearch" placeholder="Filter..." aria-label="Filter versions" class="w-32 px-2 py-1 text-[11px] rounded-lg border border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-800 text-neutral-800 dark:text-white placeholder-neutral-400 outline-none">
        </div>
        <div id="verList" class="space-y-2"></div>
      </div>

      <!-- STEP 3: Server Picker -->
      <div class="wiz-panel" id="step-server">
        <p class="text-[10px] font-medium text-neutral-400 dark:text-neutral-500 uppercase tracking-wider mb-3">Select server</p>
        <div id="srvList" class="space-y-2"></div>
      </div>

      <!-- STEP 4: Confirm -->
      <div class="wiz-panel" id="step-confirm">
        <p class="text-[10px] font-medium text-neutral-400 dark:text-neutral-500 uppercase tracking-wider mb-3">Confirm</p>
        <div class="bg-neutral-50 dark:bg-neutral-800/40 border border-neutral-200 dark:border-white/5 rounded-lg p-4 mb-3">
          <div class="confirm-row"><span class="text-[11px] text-neutral-500">Project</span><span id="cfnProject" class="text-xs font-medium text-neutral-800 dark:text-white"></span></div>
          <div class="confirm-row"><span class="text-[11px] text-neutral-500">Version</span><span id="cfnVersion" class="text-xs font-medium text-neutral-800 dark:text-white"></span></div>
          <div class="confirm-row"><span class="text-[11px] text-neutral-500">Server</span><span id="cfnServer" class="text-xs font-medium text-neutral-800 dark:text-white"></span></div>
          <div class="confirm-row" style="border-bottom:none"><span class="text-[11px] text-neutral-500">Type</span><span id="cfnType" class="text-xs font-medium text-neutral-800 dark:text-white"></span></div>
        </div>
      </div>

      <!-- STEP 5: Progress -->
      <div class="wiz-panel" id="step-progress">
        <div class="term-box" style="display:block">
          <div class="flex justify-between items-center">
            <span id="progLabel" class="text-[11px] font-medium text-neutral-600 dark:text-neutral-300">Starting...</span>
            <span id="progPct" class="text-[10px] text-neutral-400 font-mono">0%</span>
          </div>
          <div class="prog-track"><div id="progFill" class="prog-fill"></div></div>
          <div id="progLog" class="term-log"></div>
        </div>
      </div>
    </div>

    <!-- Fixed footer action -->
    <div class="px-4 py-3 border-t border-neutral-200 dark:border-white/5 flex-shrink-0">
      <div id="wizErr" style="display:none" class="mb-2 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-500/20 rounded-lg p-2"><p id="wizErrTxt" class="text-[11px] text-red-600 dark:text-red-400"></p></div>
      <button id="wizActionBtn" type="button" class="w-full bg-neutral-800 hover:bg-neutral-700 text-white dark:bg-neutral-200 dark:hover:bg-neutral-300 dark:text-neutral-900 rounded-xl py-3 text-sm font-medium transition">Install</button>
    </div>
  </div>
</div>

<script nonce="<%- nonce %>">
(function() {
  function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function showEl(id) { const e=document.getElementById(id); if(e) e.style.display=''; }
  function hideEl(id) { const e=document.getElementById(id); if(e) e.style.display='none'; }

  const hasDisabledTypes = <%- hasDisabledTypes %>;
  const hasBlockedProjects = <%- hasBlockedProjects %>;
  const disabledProjectTypes = <%- JSON.stringify(modrinthSettings?.disabledProjectTypes || []) %>;
  const blockedProjects = <%- JSON.stringify(modrinthSettings?.blockedProjects || []) %>;

  let allResults = [], currentProject = null, selectedVersion = null, selectedServer = null;
  let allVersions = [], allServers = [], currentStep = 'details';

  async function loadResults() {
    showEl('loadingEl'); hideEl('resultsList'); hideEl('errorEl'); hideEl('emptyEl');
    try {
      const q = document.getElementById('searchInput').value || '';
      const type = document.getElementById('typeFilter').value;
      const sort = document.getElementById('sortFilter').value;
      const res = await fetch('/modrinth/api/search?' + new URLSearchParams({ q, type, sort, limit: '20' }).toString());
      const data = await res.json();
      if (!data.success) throw new Error(data.error || 'Failed');
      allResults = (data.data && data.data.hits) || data.hits || [];
      hideEl('loadingEl');
      renderList(allResults);
    } catch (err) {
      hideEl('loadingEl');
      document.getElementById('errorMsg').textContent = err.message || 'Failed to load.';
      showEl('errorEl');
    }
  }

  function renderList(list) {
    const el = document.getElementById('resultsList');
    if (!list.length) { hideEl('resultsList'); showEl('emptyEl'); return; }
    hideEl('emptyEl'); el.innerHTML = '';
    list.forEach(project => {
      const isDisabled = (hasDisabledTypes && disabledProjectTypes.includes(project.project_type)) || (hasBlockedProjects && blockedProjects.includes(project.project_id));
      const card = document.createElement('div');
      card.className = 'bg-white dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 rounded-xl p-3 flex items-center gap-3' + (isDisabled ? ' opacity-50' : '');
      card.innerHTML =
        `<img src="${esc(project.icon_url || '')}" alt="" class="w-10 h-10 rounded-lg object-cover shrink-0" onerror="this.style.display='none'">` +
        `<div class="min-w-0 flex-1"><p class="text-sm font-medium text-neutral-800 dark:text-white truncate">${esc(project.title)}</p>` +
        (project.description ? `<p class="text-xs text-neutral-500 dark:text-neutral-400 truncate">${esc(project.description)}</p>` : '') +
        `<div class="flex items-center gap-2 mt-1"><span class="text-[10px] text-neutral-400">${(project.downloads||0).toLocaleString()} downloads</span>` +
        `<span class="text-[10px] px-1.5 py-0.5 rounded bg-neutral-100 dark:bg-neutral-700 text-neutral-500">${esc(project.project_type)}</span></div></div>` +
        `<svg class="w-4 h-4 text-neutral-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>`;
      card.addEventListener('click', () => openWizard(project));
      el.appendChild(card);
    });
    showEl('resultsList');
  }

  document.getElementById('searchForm').addEventListener('submit', e => { e.preventDefault(); loadResults(); });
  document.getElementById('typeFilter').addEventListener('change', loadResults);
  document.getElementById('sortFilter').addEventListener('change', loadResults);

  // Wizard
  function goStep(step) {
    currentStep = step;
    document.querySelectorAll('.wiz-panel').forEach(p => p.classList.remove('active'));
    const panel = document.getElementById('step-' + step);
    if (panel) panel.classList.add('active');
    updateActionBtn();
  }

  function updateActionBtn() {
    const btn = document.getElementById('wizActionBtn');
    btn.disabled = false;
    switch (currentStep) {
      case 'details': btn.textContent = 'Install'; btn.className = 'w-full bg-neutral-800 hover:bg-neutral-700 text-white dark:bg-neutral-200 dark:hover:bg-neutral-300 dark:text-neutral-900 rounded-xl py-3 text-sm font-medium transition'; break;
      case 'versions': btn.textContent = selectedVersion ? 'Next' : 'Select a version'; btn.disabled = !selectedVersion; btn.className = 'w-full rounded-xl py-3 text-sm font-medium transition ' + (selectedVersion ? 'bg-neutral-800 hover:bg-neutral-700 text-white dark:bg-neutral-200 dark:hover:bg-neutral-300 dark:text-neutral-900' : 'bg-neutral-200 dark:bg-neutral-700 text-neutral-400 cursor-not-allowed'); break;
      case 'server': btn.textContent = selectedServer ? 'Next' : 'Select a server'; btn.disabled = !selectedServer; btn.className = 'w-full rounded-xl py-3 text-sm font-medium transition ' + (selectedServer ? 'bg-neutral-800 hover:bg-neutral-700 text-white dark:bg-neutral-200 dark:hover:bg-neutral-300 dark:text-neutral-900' : 'bg-neutral-200 dark:bg-neutral-700 text-neutral-400 cursor-not-allowed'); break;
      case 'confirm': btn.textContent = 'Install now'; btn.className = 'w-full rounded-xl bg-neutral-800 hover:bg-neutral-700 text-white dark:bg-neutral-200 dark:hover:bg-neutral-300 dark:text-neutral-900 py-3 text-sm font-medium transition'; break;
      case 'progress': btn.textContent = 'Installing...'; btn.disabled = true; btn.className = 'w-full rounded-xl bg-neutral-200 dark:bg-neutral-700 text-neutral-400 py-3 text-sm font-medium cursor-not-allowed'; break;
    }
  }

  async function openWizard(project) {
    currentProject = project; selectedVersion = null; selectedServer = null;
    const isDisabled = (hasDisabledTypes && disabledProjectTypes.includes(project.project_type)) || (hasBlockedProjects && blockedProjects.includes(project.project_id));
    document.getElementById('wizIcon').src = project.icon_url || '';
    document.getElementById('wizIcon').style.display = project.icon_url ? '' : 'none';
    document.getElementById('wizTitle').textContent = project.title || '';
    const badge = document.getElementById('wizBadge');
    badge.className = 'text-[10px] font-medium px-2 py-0.5 rounded-full whitespace-nowrap ' + (isDisabled ? 'sb-disabled' : 'sb-available');
    badge.textContent = isDisabled ? 'Disabled' : project.project_type;
    document.getElementById('wizMeta').textContent = 'by ' + (project.author || 'Unknown') + ' · ' + (project.downloads || 0).toLocaleString() + ' downloads';
    document.getElementById('wizDesc').textContent = project.description || '';
    document.getElementById('wizStats').innerHTML = `<span>${(project.downloads||0).toLocaleString()} downloads</span><span>${(project.follows||0).toLocaleString()} followers</span>`;
    const catEl = document.getElementById('wizCategories'); catEl.innerHTML = '';
    (project.categories||[]).slice(0,5).forEach(c => { catEl.innerHTML += `<span class="px-2 py-0.5 text-[10px] bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-700 rounded-full">${esc(c)}</span>`; });
    document.getElementById('wizLong').innerHTML = '<p>' + esc(project.description || 'No description.') + '</p>';
    hideEl('wizErr');
    goStep('details');
    document.getElementById('wizardOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeWizard() {
    document.getElementById('wizardOverlay').classList.remove('open');
    document.body.style.overflow = '';
    currentProject = null; selectedVersion = null; selectedServer = null;
  }
  window.closeWizard = closeWizard;
  document.getElementById('wizardOverlay').addEventListener('click', e => { if (e.target === e.currentTarget) closeWizard(); });

  document.getElementById('wizActionBtn').addEventListener('click', async function() {
    if (this.disabled) return;
    switch (currentStep) {
      case 'details': await loadVersions(); break;
      case 'versions': goStep('server'); break;
      case 'server': showConfirm(); goStep('confirm'); break;
      case 'confirm': await startInstall(); break;
    }
  });

  async function loadVersions() {
    if (!currentProject) return;
    const isDisabled = hasDisabledTypes && disabledProjectTypes.includes(currentProject.project_type);
    if (isDisabled) { showToast('Disabled by admin', 'error'); return; }
    const verList = document.getElementById('verList');
    verList.innerHTML = '<div class="sk h-10 w-full"></div><div class="sk h-10 w-full"></div>';
    goStep('versions');
    try {
      const res = await fetch('/modrinth/api/project/' + currentProject.project_id);
      const data = await res.json();
      if (!data.success) throw new Error('Failed');
      allVersions = (data.data && data.data.versions) || data.versions || [];
      renderVersions(allVersions);
    } catch (err) { verList.innerHTML = '<p class="text-xs text-neutral-400 text-center py-4">Failed to load: ' + esc(err.message || 'Unknown') + '</p>'; }
  }

  function renderVersions(versions) {
    const el = document.getElementById('verList'); el.innerHTML = '';
    const q = (document.getElementById('verSearch').value||'').toLowerCase();
    const f = versions.filter(v => !q || (v.name||'').toLowerCase().includes(q) || (v.version_number||'').toLowerCase().includes(q));
    if (!f.length) { el.innerHTML = '<p class="text-xs text-neutral-400 text-center py-4">No matches</p>'; return; }
    f.forEach(v => {
      const d = document.createElement('div');
      d.className = 'ver-card bg-neutral-50 dark:bg-neutral-800/40 border border-neutral-200 dark:border-white/5 rounded-lg p-3';
      d.innerHTML = `<div class="flex items-start justify-between gap-2"><div class="min-w-0"><div class="text-xs font-medium text-neutral-800 dark:text-white truncate">${esc(v.name||'Unknown')}</div><div class="text-neutral-500 text-[11px] font-mono mt-0.5">${esc(v.version_number||'')}</div></div><span class="text-[10px] px-1.5 py-0.5 rounded bg-neutral-200 dark:bg-neutral-700 text-neutral-600 dark:text-neutral-300 shrink-0">${esc(v.version_type||'release')}</span></div><div class="text-[10px] text-neutral-500 mt-1">${(v.game_versions||[]).slice(0,3).map(g=>esc(g)).join(', ')}</div>`;
      d.addEventListener('click', () => { document.querySelectorAll('.ver-card').forEach(c=>c.classList.remove('selected')); d.classList.add('selected'); selectedVersion = v; updateActionBtn(); });
      el.appendChild(d);
    });
  }

  document.getElementById('verSearch').addEventListener('input', () => { if (allVersions.length) renderVersions(allVersions); });

  async function fetchServers() {
    try {
      const res = await fetch('/modrinth/api/servers', { credentials:'include', headers:{'Accept':'application/json'} });
      const data = await res.json();
      if (!data.success || !data.data || !data.data.length) { showToast('No servers', 'error'); return false; }
      allServers = data.data; return true;
    } catch { showToast('Failed to load servers', 'error'); return false; }
  }

  async function goStepServers(step) {
    if (step === 'server' && !allServers.length) {
      const ok = await fetchServers(); if (!ok) return;
      const el = document.getElementById('srvList'); el.innerHTML = '';
      allServers.forEach(s => {
        const c = document.createElement('div');
        c.className = 'srv-card bg-neutral-50 dark:bg-neutral-800/40 border border-neutral-200 dark:border-white/5 rounded-lg p-3 flex items-center gap-3';
        const r = s.status === 'running';
        c.innerHTML = `<span class="relative flex h-2 w-2 shrink-0">${r?'<span class="animate-ping absolute h-full w-full rounded-full bg-neutral-400 opacity-75"></span>':''}<span class="relative inline-flex rounded-full h-2 w-2 ${r?'bg-neutral-500':'bg-neutral-400'}"></span></span><div class="min-w-0 flex-1"><p class="text-xs font-medium text-neutral-800 dark:text-white truncate">${esc(s.name||'Unnamed')}</p><p class="text-[10px] text-neutral-400">${esc(s.status||'')}</p></div>`;
        c.addEventListener('click', () => { document.querySelectorAll('.srv-card').forEach(x=>x.classList.remove('selected')); c.classList.add('selected'); selectedServer = s.id; updateActionBtn(); });
        el.appendChild(c);
      });
    }
    _origGoStep(step);
  }

  function showConfirm() {
    document.getElementById('cfnProject').textContent = currentProject?.title || '';
    document.getElementById('cfnVersion').textContent = selectedVersion?.name || selectedVersion?.version_number || '';
    document.getElementById('cfnServer').textContent = allServers.find(s=>s.id===selectedServer)?.name || '';
    document.getElementById('cfnType').textContent = currentProject?.project_type || '';
  }

  async function startInstall() {
    if (!currentProject || !selectedVersion || !selectedServer) return;
    goStep('progress');
    const log = (text, cls) => { const d=document.createElement('div'); if(cls) d.className=cls; d.textContent=text; const l=document.getElementById('progLog'); l.appendChild(d); l.scrollTop=l.scrollHeight; };
    try {
      const res = await fetch('/modrinth/api/install', { method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'}, credentials:'include', body:JSON.stringify({serverId:selectedServer,projectId:currentProject.project_id,versionId:selectedVersion.id}) });
      const ct = res.headers.get('content-type')||'';
      if (!res.ok || ct.includes('application/json')) { const d=await res.json(); log('Error: '+(d.error||'Server error'),'l-err'); document.getElementById('progLabel').textContent='Failed'; showToast(d.error||'Failed','error'); updateActionBtn(); return; }
      const reader=res.body.getReader(), dec=new TextDecoder(); let buf='';
      outer:while(true){const{done:end,value}=await reader.read();if(end)break;buf+=dec.decode(value,{stream:true});const parts=buf.split('\n\n');buf=parts.pop();for(const part of parts){const raw=part.replace(/^data:\s*/m,'').trim();if(!raw)continue;let evt;try{evt=JSON.parse(raw);}catch{continue;}if(evt.type==='progress'){document.getElementById('progFill').style.width=(evt.progress||0)+'%';document.getElementById('progPct').textContent=(evt.progress||0)+'%';document.getElementById('progLabel').textContent=evt.stage||'Installing...';if(evt.message)log(evt.message,'l-step');}else if(evt.type==='log'){log(evt.message,evt.level==='error'?'l-err':evt.level==='success'?'l-ok':'l-output');}else if(evt.type==='complete'){document.getElementById('progFill').style.width='100%';document.getElementById('progPct').textContent='100%';document.getElementById('progLabel').textContent='Installed';log(evt.message||'Done!','l-ok');showToast(evt.message||'Installed!','success');updateActionBtn();break outer;}else if(evt.type==='error'){log('Error: '+evt.message,'l-err');document.getElementById('progLabel').textContent='Failed';showToast(evt.message,'error');updateActionBtn();break outer;}}}
    } catch(err){log('Error: '+err.message,'l-err');document.getElementById('progLabel').textContent='Failed';showToast('Failed','error');updateActionBtn();}
  }

  const _origGoStep = goStep;
  goStep = function(step) { if(step==='server') goStepServers(step); else _origGoStep(step); };

  loadResults();
})();
</script>

