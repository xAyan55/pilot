# Discord Bot Credentials
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# MintyHost LXC Control Panel REST API endpoint
# Use public domain or local IP (without trailing slash)
PANEL_URL=http://127.0.0.1:5000

# Global Admin API Key created in the dashboard (requires 'admin' role key)
PANEL_API_KEY=your_admin_api_key_here

# Discord Role ID required for administrative slash commands (e.g. creating VPS, user management)
ADMIN_ROLE_ID=your_admin_role_id_here

