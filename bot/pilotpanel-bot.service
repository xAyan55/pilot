[Unit]
Description=PilotPanel Discord Bot
After=network.target pilotpanel.service

[Service]
User=root
WorkingDirectory=/var/www/pilotpanel/bot
EnvironmentFile=/var/www/pilotpanel/.env
ExecStart=/var/www/pilotpanel/bot/venv/bin/python bot.py
Restart=always
RestartSec=5
Environment=PATH=/var/www/pilotpanel/bot/venv/bin:/usr/bin:/bin
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
