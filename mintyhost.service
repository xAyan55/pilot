[Unit]
Description=MintyHost LXC Control Panel
After=network.target

[Service]
User=root
WorkingDirectory=/root/lxc
ExecStart=/root/lxc/venv/bin/python app.py
Restart=always
RestartSec=5
Environment=PATH=/root/lxc/venv/bin:/usr/bin:/bin
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
